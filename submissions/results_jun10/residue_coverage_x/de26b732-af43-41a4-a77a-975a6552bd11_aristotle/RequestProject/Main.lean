namespace Erdos124

/-! ## Helper lemmas -/

/-- In a finite additive group, a submonoid is automatically closed under negation. -/
lemma neg_mem_of_finite {G : Type*} [AddGroup G] [Finite G]
    (S : AddSubmonoid G) {x : G} (hx : x ∈ S) : -x ∈ S := by
  have hpos : 0 < addOrderOf x := addOrderOf_pos x
  have h0 : addOrderOf x • x = 0 := addOrderOf_nsmul_eq_zero x
  have e : (addOrderOf x - 1) • x + x = 0 := by
    have : (addOrderOf x - 1 + 1) • x = 0 := by
      rw [Nat.sub_add_cancel hpos]; exact h0
    rwa [add_nsmul, one_nsmul] at this
  have key : (addOrderOf x - 1) • x = -x := eq_neg_of_add_eq_zero_left e
  rw [← key]
  exact nsmul_mem hx _

/-- The generators for base `d` and threshold `J`: the residues `d^j` for `j ≥ J`. -/
def gens (M J d : ℕ) : Set (ZMod M) := {x | ∃ j, J ≤ j ∧ (d : ZMod M) ^ j = x}

/--
Eventual periodicity, uniform over a finite set of bases: there exist a threshold `J ≥ k`
    and a period `t ≥ 1` such that for every base `d ∈ D` and exponent `j ≥ J`, the residue
    `d^(j+t)` equals `d^j` in `ZMod M`.
-/
lemma exists_uniform_period (D : Finset ℕ) (M k : ℕ) (hM : 0 < M) :
    ∃ J t : ℕ, k ≤ J ∧ 1 ≤ t ∧ ∀ d ∈ D, ∀ j, J ≤ j →
      (d : ZMod M) ^ (j + t) = (d : ZMod M) ^ j := by
  -- For each d ∈ D: the map ℕ → ZMod M, n ↦ (d:ZMod M)^n cannot be injective (infinite domain, finite codomain), so there exist a < b with (d:ZMod M)^a = (d:ZMod M)^b.
  have h_eventual_period (d : ℕ) : ∃ (s t : ℕ), 0 < t ∧ ∀ (j : ℕ), s ≤ j → (d : (ZMod M)) ^ (j + t) = (d : (ZMod M)) ^ j := by
    -- The sequence of powers of $d$ modulo $M$ is finite, so it must eventually repeat.
    have h_finite : Set.Finite (Set.range (fun n => (d : (ZMod M)) ^ n)) := by
      cases M <;> [ aesop; exact Set.toFinite _ ];
    -- By the pigeonhole principle, since the sequence is finite, there must exist indices $i < j$ such that $(d : (ZMod M)) ^ i = (d : (ZMod M)) ^ j$.
    obtain ⟨i, j, hij, h_eq⟩ : ∃ i j : ℕ, i < j ∧ (d : (ZMod M)) ^ i = (d : (ZMod M)) ^ j := by
      contrapose! h_finite;
      exact Set.infinite_range_of_injective fun i j hij => le_antisymm ( le_of_not_gt fun hi => h_finite _ _ hi hij.symm ) ( le_of_not_gt fun hj => h_finite _ _ hj hij );
    refine' ⟨ i, j - i, tsub_pos_of_lt hij, fun n hn => _ ⟩;
    induction hn <;> simp_all +decide [ pow_add, Nat.succ_add, le_of_lt ];
  choose s t ht ht' using h_eventual_period;
  refine' ⟨ k + Finset.sup D s, Finset.prod D t, _, _, _ ⟩ <;> norm_num;
  · exact Finset.prod_pos fun x hx => ht x;
  · intro d hd j hj; rw [ ← Nat.mul_div_cancel' ( show t d ∣ D.prod t from Finset.dvd_prod_of_mem _ hd ) ] ; induction' ( D.prod t ) / t d with m IH <;> simp_all +decide [ Nat.mul_succ, ← add_assoc ] ;
    rw [ ht' d _ ( by nlinarith [ Finset.le_sup ( f := s ) hd ] ), IH ]

/--
Iterated periodicity: with a single period `t`, shifting by any multiple of `t` keeps the
    residue fixed (for exponents past the threshold).
-/
lemma pow_add_mul_period (M J t d : ℕ)
    (hper : ∀ j, J ≤ j → (d : ZMod M) ^ (j + t) = (d : ZMod M) ^ j) :
    ∀ N j, J ≤ j → (d : ZMod M) ^ (j + N * t) = (d : ZMod M) ^ j := by
  exact fun N j hj => Nat.recOn N ( by norm_num ) fun N ih => by rw [ Nat.succ_mul, ← add_assoc, hper _ ( by nlinarith ), ih ] ;

/--
Realizability: every element of the additive submonoid generated by `{d^j : j ≥ J}` is an
    honest subset-sum `∑_{j ∈ S} d^j` over a finite set `S` of exponents `≥ J`.
-/
lemma realizable (M J t d : ℕ)
    (hper : ∀ j, J ≤ j → (d : ZMod M) ^ (j + t) = (d : ZMod M) ^ j) (ht : 1 ≤ t)
    {x : ZMod M} (hx : x ∈ AddSubmonoid.closure (gens M J d)) :
    ∃ S : Finset ℕ, (∀ j ∈ S, J ≤ j) ∧ ∑ j ∈ S, (d : ZMod M) ^ j = x := by
  refine' AddSubmonoid.closure_induction _ _ _ hx;
  · rintro x ⟨ j, hj, rfl ⟩ ; exact ⟨ { j }, by simpa using hj ⟩ ;
  · exact ⟨ ∅, by norm_num ⟩;
  · rintro x y hx hy ⟨ S, hS₁, hS₂ ⟩ ⟨ T, hT₁, hT₂ ⟩;
    -- Let $N$ be a number such that $N \cdot t > \max(S)$.
    obtain ⟨N, hN⟩ : ∃ N : ℕ, N * t > S.sup id := by
      exact ⟨ S.sup id + 1, by nlinarith ⟩;
    refine' ⟨ S ∪ Finset.image ( fun j => j + N * t ) T, _, _ ⟩ <;> simp_all +decide;
    · grind;
    · rw [ Finset.sum_union, hS₂, ← hT₂, Finset.sum_image ];
      · exact congrArg _ ( Finset.sum_congr rfl fun j hj => pow_add_mul_period M J t d hper N j (hT₁ j hj) );
      · aesop_cat;
      · norm_num [ Finset.disjoint_right ];
        exact fun j hj₁ hj₂ => not_lt_of_ge ( Finset.le_sup ( f := id ) hj₂ ) ( lt_add_of_nonneg_of_lt ( Nat.zero_le _ ) hN )

/--
Membership in a finite supremum of submonoids decomposes as a sum of pieces.
-/
lemma mem_finsetSup_decomp {G : Type*} [AddCommMonoid G] {ι : Type*}
    (D : Finset ι) (S : ι → AddSubmonoid G) {x : G}
    (hx : x ∈ ⨆ d ∈ D, S d) :
    ∃ y : ι → G, (∀ d ∈ D, y d ∈ S d) ∧ x = ∑ d ∈ D, y d := by
  induction' D using Finset.induction with d D hD ih generalizing x;
  · aesop;
  · rw [ Finset.iSup_insert ] at hx;
    rcases AddSubmonoid.mem_sup.mp hx with ⟨ y, hy, z, hz, rfl ⟩;
    obtain ⟨ w, hw₁, hw₂ ⟩ := ih hz; use fun x => if x = d then y else w x; simp_all +decide [ Finset.sum_insert hD ] ;
    exact ⟨ fun a ha => by aesop, by rw [ Finset.sum_congr rfl fun a ha => if_neg ( by aesop ) ] ⟩

/--
A submonoid `H` of `ZMod M` (closed under negation) that, for every prime `p ∣ M`, contains
    an element not divisible by `p`, is the whole group.
-/
lemma submonoid_top_of_witness (M : ℕ) (hM : 0 < M) (H : AddSubmonoid (ZMod M))
    (hneg : ∀ x ∈ H, -x ∈ H)
    (hw : ∀ p : ℕ, p.Prime → p ∣ M → ∃ x ∈ H, ¬ (p ∣ (ZMod.val x))) :
    H = ⊤ := by
  -- By `Int.subgroup_cyclic`, A = AddSubgroup.closure {g} = `AddSubgroup.zmultiples g` for some g : ℤ.
  obtain ⟨g, hg⟩ : ∃ g : ℤ, {n : ℤ | (n : ZMod M) ∈ H} = AddSubgroup.zmultiples g := by
    have hA : ∃ A : AddSubgroup ℤ, {n : ℤ | (n : ZMod M) ∈ H} = A := by
      refine' ⟨ _, _ ⟩;
      refine' { carrier := { n : ℤ | ( n : ZMod M ) ∈ H }, zero_mem' := _, add_mem' := _, neg_mem' := _ };
      exacts [ fun { a b } ha hb => by simpa using H.add_mem ha hb, by simp, fun { x } hx => by simpa using hneg _ hx, rfl ];
    obtain ⟨ A, hA ⟩ := hA;
    obtain ⟨ g, hg ⟩ := AddSubgroup.isAddCyclic A;
    use g.val; ext n; simp [hA];
    exact ⟨ fun hn => by obtain ⟨ k, hk ⟩ := hg ⟨ n, hn ⟩ ; exact ⟨ k, by simpa [ Subtype.ext_iff ] using hk ⟩, fun hn => by obtain ⟨ k, hk ⟩ := hn; exact hk.symm ▸ AddSubgroup.zsmul_mem _ g.2 _ ⟩;
  -- Note (M : ℤ) ∈ A because ((M:ℤ) : ZMod M) = (0:ZMod M) ∈ H (use `ZMod.natCast_self`). So g ∣ (M:ℤ).
  have hg_div_M : g ∣ M := by
    replace hg := Set.ext_iff.mp hg M; simp_all +decide [ AddSubgroup.mem_zmultiples_iff ] ;
    exact dvd_of_mul_left_eq _ hg.choose_spec;
  -- Claim g.natAbs = 1: Suppose not. Since g ∣ M and M > 0, g ≠ 0, so g.natAbs ≥ 2, hence has a prime factor q. Then q ∣ g.natAbs ∣ M (g ∣ M as integers gives g.natAbs ∣ M). So q is a prime dividing M; apply the witness for q to get x with ¬ q ∣ ZMod.val x, but g ∣ (ZMod.val x:ℤ) and q ∣ g.natAbs ∣ (ZMod.val x) — contradiction.
  have hg_natAbs_one : Int.natAbs g = 1 := by
    by_contra hg_natAbs_ne_one
    obtain ⟨q, hq_prime, hq_div_g⟩ : ∃ q : ℕ, Nat.Prime q ∧ q ∣ Int.natAbs g := by
      exact Nat.exists_prime_and_dvd hg_natAbs_ne_one;
    obtain ⟨ x, hx₁, hx₂ ⟩ := hw q hq_prime ( Nat.dvd_trans hq_div_g ( Int.natAbs_dvd_natAbs.mpr hg_div_M ) ) ; have := hg.symm.subset ( AddSubgroup.mem_zmultiples_iff.mpr ⟨ x.val, rfl ⟩ ) ; simp_all +decide [ ← Int.natCast_dvd_natCast ] ;
    replace hg := Set.ext_iff.mp hg ( x.val ) ; simp_all +decide [ AddSubgroup.mem_zmultiples_iff ] ;
    exact hx₂ <| dvd_trans hq_div_g <| hg.mp ( by cases M <;> aesop ) |> fun ⟨ k, hk ⟩ => hk ▸ dvd_mul_left _ _;
  rw [ Int.natAbs_eq_iff ] at hg_natAbs_one;
  rcases hg_natAbs_one with ( rfl | rfl ) <;> simp_all +decide [ Set.ext_iff ]; all_goals ext x; specialize hg x.val; cases M <;> aesop;

/--
If `gcd(D) = 1` then for every prime `p` there is a base `d ∈ D` not divisible by `p`.
-/
lemma per_prime_witness (D : Finset ℕ) (hgcd : D.gcd id = 1)
    {p : ℕ} (hp : p.Prime) : ∃ d ∈ D, ¬ (p ∣ d) := by
  by_contra h; simp_all +decide [ Finset.gcd_eq_gcd_image ] ;
  exact Nat.Prime.not_dvd_one hp ( hgcd ▸ Finset.dvd_gcd fun x hx => by aesop )

/-! ## The two directions -/

/--
Necessity: full residue coverage forces `gcd(D) = 1`.
-/
lemma necessity
    (D : Finset ℕ) (k : ℕ) (hk : k ≠ 0)
    (hcov : ∀ M : ℕ, 0 < M →
      ∀ r : ZMod M, ∃ f : ℕ → Finset ℕ,
        (∀ d ∈ D, (f d).Nonempty → ∀ j ∈ f d, k ≤ j) ∧
        (∑ d ∈ D, ∑ j ∈ f d, (d : ZMod M) ^ j) = r) :
    D.gcd id = 1 := by
  contrapose! hcov;
  obtain ⟨ p, hp₁, hp₂ ⟩ := Nat.exists_prime_and_dvd hcov;
  refine' ⟨ p, hp₁.pos, 1, fun f hf => _ ⟩;
  -- Since $p \mid d$ for all $d \in D$, we have $d^j \equiv 0 \pmod{p}$ for all $j \geq 1$.
  have h_zero : ∀ d ∈ D, ∀ j ≥ 1, (d : ZMod p) ^ j = 0 := by
    intro d hd j hj; haveI := Fact.mk hp₁; simp_all +decide [ ← ZMod.natCast_eq_zero_iff, Finset.dvd_gcd_iff ] ;
    linarith;
  rw [ Finset.sum_eq_zero ] <;> norm_num;
  · haveI := Fact.mk hp₁; norm_num;
  · exact fun d hd => Finset.sum_eq_zero fun j hj => h_zero d hd j ( by linarith [ hf d hd ( Finset.nonempty_of_ne_empty ( by aesop_cat ) ) j hj, Nat.pos_of_ne_zero hk ] )

/--
Sufficiency: `gcd(D) = 1` yields full residue coverage at every modulus and every `k ≥ 1`.
-/
lemma sufficiency
    (D : Finset ℕ) (k : ℕ)
    (hgcd : D.gcd id = 1) :
    ∀ M : ℕ, 0 < M →
      ∀ r : ZMod M, ∃ f : ℕ → Finset ℕ,
        (∀ d ∈ D, (f d).Nonempty → ∀ j ∈ f d, k ≤ j) ∧
        (∑ d ∈ D, ∑ j ∈ f d, (d : ZMod M) ^ j) = r := by
  intro M hM;
  -- Obtain (J, t, hJk : k ≤ J, ht : 1 ≤ t, hper) from `exists_uniform_period D M k hM`.
  obtain ⟨J, t, hJk, ht, hper⟩ := exists_uniform_period D M k hM;
  -- By `submonoid_top_of_witness`, $H = \top$.
  have hH_top : ⨆ d ∈ D, AddSubmonoid.closure (gens M J d) = ⊤ := by
    apply submonoid_top_of_witness M hM;
    · intro x hx; exact (by
      convert neg_mem_of_finite _ hx;
      cases M <;> [ aesop_cat; infer_instance ]);
    · intro p hp hpm
      obtain ⟨d, hdD, hd⟩ : ∃ d ∈ D, ¬(p ∣ d) := per_prime_witness D hgcd hp;
      refine' ⟨ _, _, _ ⟩;
      exact ( d : ZMod M ) ^ J;
      · exact AddSubmonoid.mem_iSup_of_mem d ( AddSubmonoid.mem_iSup_of_mem hdD ( AddSubmonoid.subset_closure ⟨ J, le_rfl, rfl ⟩ ) );
      · have h_cast : (d ^ J : ZMod M).val ≡ d ^ J [MOD p] := by
          simp +decide [ ← ZMod.natCast_eq_natCast_iff ];
          cases M <;> aesop;
        exact fun h => hd <| hp.dvd_of_dvd_pow <| Nat.dvd_of_mod_eq_zero <| h_cast.symm.trans <| Nat.modEq_zero_iff_dvd.mpr h;
  intro r
  obtain ⟨y, hy⟩ := mem_finsetSup_decomp D (fun d => AddSubmonoid.closure (gens M J d)) (by
  aesop : r ∈ ⨆ d ∈ D, AddSubmonoid.closure (gens M J d));
  choose! S hS using fun d hd => realizable M J t d ( hper d hd ) ht ( hy.1 d hd );
  exact ⟨ S, fun d hd hd' j hj => le_trans hJk ( hS d hd |>.1 j hj ), by rw [ hy.2, Finset.sum_congr rfl fun d hd => hS d hd |>.2 ] ⟩

end Erdos124

/-- **Erdős 124 — Residue Coverage Lemma for the BEGL96 sumset.**
For a finite set `D` of integers `≥ 3` and any `k ≥ 1`, the BEGL96 sumset `Σ(D,k)` covers every
residue class modulo every modulus `M` if and only if `gcd(D) = 1`.

Note: the hypotheses `hD : ∀ d ∈ D, 3 ≤ d` and `hne : D.Nonempty` are kept because they are part
of the requested statement, but they turn out to be unnecessary for the proof — the equivalence
holds for an arbitrary finite `D : Finset ℕ` and any `k ≠ 0`. -/
theorem erdos124_residue_coverage
    (D : Finset ℕ) (hD : ∀ d ∈ D, 3 ≤ d) (hne : D.Nonempty) (k : ℕ) (hk : k ≠ 0) :
    (∀ M : ℕ, 0 < M →
      ∀ r : ZMod M, ∃ f : ℕ → Finset ℕ,
        (∀ d ∈ D, (f d).Nonempty → ∀ j ∈ f d, k ≤ j) ∧
        (∑ d ∈ D, ∑ j ∈ f d, (d : ZMod M) ^ j) = r)
    ↔ D.gcd id = 1 := by
  constructor
  · intro hcov
    exact Erdos124.necessity D k hk hcov
  · intro hgcd
    exact Erdos124.sufficiency D k hgcd