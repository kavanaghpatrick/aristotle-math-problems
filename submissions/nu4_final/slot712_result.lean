The case n=2u^2, n+3d=v^2 leads to a contradiction for coprime n, d.
-/
lemma erdos_672_case2_impossible (n d u v : ℕ) (hn : n > 0) (hd : d > 0) (hcd : n.gcd d = 1) (hd_odd : Odd d)
  (h_n : n = 2 * u^2) (h_n3d : n + 3 * d = v^2) : False := by
    -- Since $v$ is a multiple of 3, let $v = 3j$ for some integer $j$.
    obtain ⟨j, rfl⟩ : ∃ j, v = 3 * j := by
      exact Nat.dvd_of_mod_eq_zero ( by have := congr_arg ( · % 3 ) h_n3d; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod, h_n ] at this; have := Nat.mod_lt u zero_lt_three; have := Nat.mod_lt v zero_lt_three; interval_cases u % 3 <;> interval_cases v % 3 <;> trivial );
    -- From $2 * u^2 + 3 * d = 9 * j^2$, we can see that $u$ must be divisible by 3. Let $u = 3k$ for some integer $k$.
    obtain ⟨k, rfl⟩ : ∃ k, u = 3 * k := by
      exact Nat.dvd_of_mod_eq_zero ( by have := congr_arg ( · % 3 ) h_n3d; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod, h_n ] at this; have := Nat.mod_lt u zero_lt_three; interval_cases u % 3 <;> trivial );
    simp_all +decide [ mul_pow, Nat.coprime_mul_iff_left, Nat.coprime_mul_iff_right ];
    exact absurd ( Nat.dvd_gcd ( by decide : 3 ∣ 9 ) ( show 3 ∣ d by omega ) ) ( by aesop )

/-
A pair (x, y) is DoublePythagorean if x, y > 0 and both x^2 + y^2 and x^2 + 4y^2 are squares.
-/
def DoublePythagorean (x y : ℕ) : Prop :=
  x > 0 ∧ y > 0 ∧ IsSquare (x^2 + y^2) ∧ IsSquare (x^2 + 4 * y^2)

/-
If (x, y) is a double Pythagorean solution and x is even, then (y, x/2) is also a solution.
-/
lemma double_pythagorean_map (x y : ℕ) (h : DoublePythagorean x y) (hx_even : Even x) :
  DoublePythagorean y (x / 2) := by
    obtain ⟨ k, hk ⟩ := hx_even; simp_all +decide [ DoublePythagorean ] ;
    norm_num [ ← two_mul, Nat.add_div ] at *;
    exact ⟨ h.1, by obtain ⟨ x, hx ⟩ := h.2.2.2; exact ⟨ x / 2, by nlinarith [ Nat.div_mul_cancel ( show 2 ∣ x from even_iff_two_dvd.mp ( by simpa [ parity_simps ] using congrArg Even hx ) ) ] ⟩, by obtain ⟨ x, hx ⟩ := h.2.2.1; exact ⟨ x, by linarith ⟩ ⟩ ;

/-
If (x, y) is a double Pythagorean solution, x and y cannot both be odd.
-/
lemma double_pythagorean_parity (x y : ℕ) (h : DoublePythagorean x y) :
  ¬(Odd x ∧ Odd y) := by
    rcases h with ⟨ hx_pos, hy_pos, hx_sq, hy_sq ⟩ ; rcases hx_sq with ⟨ z, hz ⟩ ; rcases hy_sq with ⟨ w, hw ⟩ ; replace hz := congr_arg ( · % 4 ) hz ; replace hw := congr_arg ( · % 4 ) hw ; rcases Nat.even_or_odd' x with ⟨ k, rfl | rfl ⟩ <;> rcases Nat.even_or_odd' y with ⟨ l, rfl | rfl ⟩ <;> rcases Nat.even_or_odd' z with ⟨ m, rfl | rfl ⟩ <;> rcases Nat.even_or_odd' w with ⟨ n, rfl | rfl ⟩ <;> ring_nf at * <;> norm_num [ Nat.add_mod, Nat.mul_mod ] at *;

/-
If x^2 + y^2 = z^2 with x odd, y even, coprime, then x = m^2 - n^2, y = 2mn.
-/
lemma pythagorean_parametrization (x y z : ℕ) (h_eq : x^2 + y^2 = z^2) (hx_odd : Odd x) (hy_even : Even y) (h_coprime : x.gcd y = 1) :
  ∃ m n : ℕ, m.gcd n = 1 ∧ (Odd m ∧ Even n ∨ Even m ∧ Odd n) ∧
  x = m^2 - n^2 ∧ y = 2 * m * n ∧ z = m^2 + n^2 := by
    -- Since $x$ is odd and $y$ is even, we can write $x = m^2 - n^2$ and $y = 2mn$ for some coprime integers $m$ and $n$.
    obtain ⟨m, n, h_coprime, x_eq, y_eq⟩ : ∃ m n : ℕ, Nat.gcd m n = 1 ∧ x = m^2 - n^2 ∧ y = 2 * m * n := by
      obtain ⟨ m, rfl ⟩ := hy_even;
      -- Since $x$ is odd and $z^2 - x^2 = (z - x)(z + x) = 4m^2$, we can write $z - x = 2a$ and $z + x = 2b$ for some integers $a$ and $b$ such that $ab = m^2$.
      obtain ⟨a, b, hab⟩ : ∃ a b : ℕ, a * b = m^2 ∧ z - x = 2 * a ∧ z + x = 2 * b := by
        exact ⟨ ( z - x ) / 2, ( z + x ) / 2, by nlinarith only [ Nat.div_mul_cancel ( show 2 ∣ z - x from even_iff_two_dvd.mp <| by rw [ Nat.even_sub <| by nlinarith ] ; replace h_eq := congr_arg Even h_eq ; simp_all +decide [ parity_simps ] ), Nat.div_mul_cancel ( show 2 ∣ z + x from even_iff_two_dvd.mp <| by rw [ Nat.even_add ] ; replace h_eq := congr_arg Even h_eq ; simp_all +decide [ parity_simps ] ), Nat.sub_add_cancel <| show x ≤ z from by nlinarith, h_eq ], by rw [ Nat.mul_div_cancel' <| even_iff_two_dvd.mp <| by rw [ Nat.even_sub <| by nlinarith ] ; replace h_eq := congr_arg Even h_eq ; simp_all +decide [ parity_simps ] ], by rw [ Nat.mul_div_cancel' <| even_iff_two_dvd.mp <| by rw [ Nat.even_add ] ; replace h_eq := congr_arg Even h_eq ; simp_all +decide [ parity_simps ] ] ⟩;
      -- Since $a$ and $b$ are coprime and $ab = m^2$, we can write $a = u^2$ and $b = v^2$ for some coprime integers $u$ and $v$.
      obtain ⟨u, v, huv⟩ : ∃ u v : ℕ, a = u^2 ∧ b = v^2 ∧ Nat.gcd u v = 1 := by
        have h_coprime_ab : Nat.gcd a b = 1 := by
          by_contra h_contra;
          -- If $a$ and $b$ are not coprime, then there exists a prime $p$ such that $p$ divides both $a$ and $b$.
          obtain ⟨p, hp_prime, hp_div_a, hp_div_b⟩ : ∃ p : ℕ, Nat.Prime p ∧ p ∣ a ∧ p ∣ b := by
            exact Nat.Prime.not_coprime_iff_dvd.mp h_contra;
          -- If $p$ divides both $a$ and $b$, then $p$ divides $m$, since $ab = m^2$.
          have hp_div_m : p ∣ m := by
            exact hp_prime.dvd_of_dvd_pow <| hab.1 ▸ dvd_mul_of_dvd_left hp_div_a _;
          exact Nat.Prime.not_dvd_one hp_prime ( h_coprime ▸ Nat.dvd_gcd ( show p ∣ x from by convert Nat.dvd_sub' ( hp_div_b ) ( hp_div_a ) using 1; rw [ Nat.sub_eq_of_eq_add ] ; linarith [ Nat.sub_add_cancel ( show x ≤ z from by nlinarith only [ h_eq ] ) ] ) ( show p ∣ m + m from dvd_add hp_div_m hp_div_m ) );
        have h_sq : ∃ u v : ℕ, a = u^2 ∧ b = v^2 := by
          have h_sq : ∀ {a b : ℕ}, a * b = m^2 → Nat.gcd a b = 1 → ∃ u : ℕ, a = u^2 := by
            intro a b hab h_coprime_ab; exact exists_eq_pow_of_mul_eq_pow ( by aesop ) hab;
          exact Exists.elim ( h_sq hab.1 h_coprime_ab ) fun u hu => Exists.elim ( h_sq ( by rw [ mul_comm, hab.1 ] ) ( Nat.Coprime.symm h_coprime_ab ) ) fun v hv => ⟨ u, v, hu, hv ⟩;
        obtain ⟨ u, v, rfl, rfl ⟩ := h_sq; exact ⟨ u, v, rfl, rfl, by simpa [ Nat.coprime_comm ] using h_coprime_ab ⟩ ;
      -- Since $u$ and $v$ are coprime and $ab = m^2$, we can write $m = uv$.
      have hm : m = u * v := by
        rw [ ← sq_eq_sq₀ ?_ ?_ ] <;> first | positivity | nlinarith only [ hab.1, huv ] ;
      exact ⟨ v, u, Nat.gcd_comm _ _ ▸ huv.2.2, eq_tsub_of_add_eq <| by linarith [ Nat.sub_add_cancel <| show x ≤ z from by nlinarith only [ h_eq ] ], by linarith ⟩;
    refine ⟨ m, n, h_coprime, ?_, x_eq, y_eq, ?_ ⟩;
    · cases Nat.mod_two_eq_zero_or_one m <;> cases Nat.mod_two_eq_zero_or_one n <;> simp_all +decide [ Nat.even_iff, Nat.odd_iff, Nat.pow_mod ];
      · have := Nat.dvd_gcd ( Nat.dvd_of_mod_eq_zero ‹m % 2 = 0› ) ( Nat.dvd_of_mod_eq_zero ‹n % 2 = 0› ) ; aesop;
      · cases le_total ( m ^ 2 ) ( n ^ 2 ) <;> simp_all +decide [ Nat.sq_sub_sq, Nat.add_mod, Nat.mul_mod ];
    · rw [ ← sq_eq_sq₀ ?_ ?_ ] <;> first | positivity | nlinarith only [ Nat.sub_add_cancel ( show n ^ 2 ≤ m ^ 2 from le_of_lt ( Nat.lt_of_sub_ne_zero ( by aesop_cat ) ) ), h_eq, x_eq, y_eq ] ;