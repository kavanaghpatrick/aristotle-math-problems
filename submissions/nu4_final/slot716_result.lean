    -- By definition of $jacobianMatrix$, we know that $(jacobianMatrix Q x).mulVec y = 2 • (algebra_mul Q x y)$.
    have h_jacobian_left_mul : (jacobianMatrix Q x) = 2 • (LinearMap.toMatrix' (algebraLeftMul Q x ‹_›)) := by
      ext i j
      generalize_proofs at *;
      simp +decide [ Matrix.mulVec, dotProduct, LinearMap.toMatrix' ];
      convert congr_fun ( congr_arg ( fun f => f ( Pi.single j 1 ) ) ( jacobian_eq_two_left_mul Q hpoly hhom x ) ) i using 1 ; norm_num [ algebraLeftMul ]
    generalize_proofs at *;
    obtain ⟨ k, hk ⟩ := hnil x;
    use k;
    simp_all +decide [ two_smul, smul_pow ];
    simp_all +decide [ ← two_smul ℂ, smul_pow ]

/-
An algebra is nilpotent if there exists a K such that any product of length K is zero.
-/
def listProd {n : ℕ} (mul : (Fin n → ℂ) → (Fin n → ℂ) → (Fin n → ℂ)) : List (Fin n → ℂ) → (Fin n → ℂ)
  | [] => 0
  | x :: xs => mul x (listProd mul xs)

def IsNilpotentAlgebra {n : ℕ} (mul : (Fin n → ℂ) → (Fin n → ℂ) → (Fin n → ℂ)) : Prop :=
  ∃ K : ℕ, ∀ L : List (Fin n → ℂ), L.length ≥ K → listProd mul L = 0

/-
If the Jacobian of a quadratic homogeneous map is nilpotent, then the associated algebra is nilpotent.
-/
theorem nilpotent_jacobian_implies_nilpotent_algebra {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hpoly : IsPolynomialMap Q) (hhom : IsQuadraticHomogeneous Q)
  (hnil : HasNilpotentJacobian Q) :
  IsNilpotentAlgebra (algebra_mul Q) := by
    -- By definition of `IsNilpotentAlgebra`, we need to show that there exists a $K$ such that any product of length $K$ is zero.
    use n + 1;
    intro L hL
    have h_nilpotent : ∀ x : Fin n → ℂ, IsNilpotent (LinearMap.toMatrix' (algebraLeftMul Q x ((algebra_mul_bilinear Q hpoly hhom).2 x))) := by
      exact?;
    -- By definition of `listProd`, we can write it as a composition of linear maps.
    have h_listProd_as_comp : ∀ L : List (Fin n → ℂ), listProd (algebra_mul Q) L = (List.foldr (fun x y => algebraLeftMul Q x ((algebra_mul_bilinear Q hpoly hhom).2 x) ∘ₗ y) (LinearMap.id) L) 0 := by
      intro L
      induction' L with x L ih
      simp [listProd];
      convert congr_arg ( fun y => algebra_mul Q x y ) ih using 1;
    induction' L with x L ih <;> aesop

/-
The sequence of approximations to the inverse map.
-/
def inverseApprox {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ)) (y : Fin n → ℂ) : ℕ → (Fin n → ℂ)
  | 0 => y
  | k + 1 => y - Q (inverseApprox Q y k)

/-
The submodule spanned by all products of length at least d.
-/
def SpanOfProducts {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ)) (d : ℕ) : Submodule ℂ (Fin n → ℂ) :=
  Submodule.span ℂ { v | ∃ L : List (Fin n → ℂ), L.length ≥ d ∧ v = listProd (algebra_mul Q) L }

/-
If the algebra is nilpotent, then the span of products of length at least K is zero.
-/
theorem span_of_products_zero_of_nilpotent {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hnil : IsNilpotentAlgebra (algebra_mul Q)) :
  ∃ K, ∀ d ≥ K, SpanOfProducts Q d = ⊥ := by
    obtain ⟨ K, hK ⟩ := hnil;
    use K;
    intro d hd;
    exact Submodule.span_eq_bot.mpr fun v hv => by obtain ⟨ L, hL₁, rfl ⟩ := hv; exact hK L ( by linarith ) ;

/-
The algebra multiplication as a bilinear map (LinearMap).
-/
def algebraMulLinear {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hpoly : IsPolynomialMap Q) (hhom : IsQuadraticHomogeneous Q) :
  (Fin n → ℂ) →ₗ[ℂ] (Fin n → ℂ) →ₗ[ℂ] (Fin n → ℂ) :=
  LinearMap.mk₂ ℂ (algebra_mul Q)
    (fun x y z => ((algebra_mul_bilinear Q hpoly hhom).1 z).map_add x y)
    (fun c x y => ((algebra_mul_bilinear Q hpoly hhom).1 y).map_smul c x)
    (fun x y z => ((algebra_mul_bilinear Q hpoly hhom).2 x).map_add y z)
    (fun c x y => ((algebra_mul_bilinear Q hpoly hhom).2 x).map_smul c y)

/-
The span of products is antitone with respect to the length lower bound.
-/
theorem span_of_products_antitone {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ)) :
  Antitone (SpanOfProducts Q) := by
    -- If $d_1 \leq d_2$, then any product of length at least $d_2$ is also a product of length at least $d_1$, hence the span of the products of length at least $d_2$ is contained in the span of the products of length at least $d_1$.
    intros d1 d2 hd
    apply Submodule.span_mono;
    exact fun v hv => by obtain ⟨ L, hL1, rfl ⟩ := hv; exact ⟨ L, le_trans hd hL1, rfl ⟩ ;

/-
Multiplying a product of length at least d by x on the left results in a product of length at least d+1, which is in the span.
-/
theorem mul_left_mem_span_succ {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (d : ℕ) (x : Fin n → ℂ) (L : List (Fin n → ℂ)) (hL : L.length ≥ d) :
  algebra_mul Q x (listProd (algebra_mul Q) L) ∈ SpanOfProducts Q (d + 1) := by
    exact Submodule.subset_span ⟨ x :: L, by simp +arith +decide; linarith, rfl ⟩

/-
Multiplying an element of the span by a vector on the left increases the degree by 1.
-/
theorem span_of_products_mul_left {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hpoly : IsPolynomialMap Q) (hhom : IsQuadraticHomogeneous Q)
  (d : ℕ) (x : Fin n → ℂ) (v : Fin n → ℂ)
  (hv : v ∈ SpanOfProducts Q d) :
  algebra_mul Q x v ∈ SpanOfProducts Q (d + 1) := by
    revert hv
    apply Submodule.span_induction
    · rintro v ⟨L, hL, rfl⟩
      exact mul_left_mem_span_succ Q d x L hL
    · rw [ (algebra_mul_bilinear Q hpoly hhom).2 x |>.map_zero ]
      exact Submodule.zero_mem _
    · intro v₁ v₂ h₁ h₂ ih₁ ih₂
      rw [ (algebra_mul_bilinear Q hpoly hhom).2 x |>.map_add ]
      exact Submodule.add_mem _ ih₁ ih₂
    · intro c v hv ih
      rw [ (algebra_mul_bilinear Q hpoly hhom).2 x |>.map_smul ]
      exact Submodule.smul_mem _ c ih

/-
Multiplying an element of the span by a vector on the left increases the degree by 1.
-/
theorem span_of_products_mul_left_v2 {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hpoly : IsPolynomialMap Q) (hhom : IsQuadraticHomogeneous Q)
  (d : ℕ) (x : Fin n → ℂ) (v : Fin n → ℂ)
  (hv : v ∈ SpanOfProducts Q d) :
  algebra_mul Q x v ∈ SpanOfProducts Q (d + 1) := by
    let L_x := algebraLeftMul Q x ((algebra_mul_bilinear Q hpoly hhom).2 x)
    have h_map : Submodule.map L_x (SpanOfProducts Q d) ≤ SpanOfProducts Q (d + 1) := by
      rw [SpanOfProducts, Submodule.map_span]
      apply Submodule.span_mono
      rintro _ ⟨v, ⟨L, hL, rfl⟩, rfl⟩
      exact ⟨x :: L, by simp; linarith, rfl⟩
    exact h_map (Submodule.mem_map_of_mem hv)

/-
If u - v is in the span of products of degree d, then Q(u) - Q(v) is in the span of products of degree d+1.
-/
theorem Q_diff_mem_span_succ {n : ℕ} (Q : (Fin n → ℂ) → (Fin n → ℂ))
  (hpoly : IsPolynomialMap Q) (hhom : IsQuadraticHomogeneous Q)
  (d : ℕ) (u v : Fin n → ℂ)
  (h : u - v ∈ SpanOfProducts Q d) :
  Q u - Q v ∈ SpanOfProducts Q (d + 1) := by
    -- Using the expansion $Q(a+b) = Q(a) + Q(b) + 2 \cdot \text{algebra\_mul}(a, b)$, we get:
    have h_expand : Q (v + (u - v)) - Q v = Q (u - v) + 2 • algebra_mul Q v (u - v) := by
      unfold algebra_mul; ring;
      unfold associatedBilinearMap; ext i; norm_num; ring;
    -- Since $u - v$ is in the span of products of degree $d$, $Q(u - v)$ is in the span of products of degree $2d$, which is in the span of products of degree $d + 1$.
    have h_Q_uv : Q (u - v) ∈ SpanOfProducts Q (d + 1) := by
      -- By definition of $Q$, we know that $Q(u - v) = \text{algebra\_mul}(u - v, u - v)$.
      have h_Q_uv_def : Q (u - v) = algebra_mul Q (u - v) (u - v) := by
        have := Q_eq_half_jacobian_mul_self Q hpoly hhom ( u - v );
        rw [ this, jacobian_eq_two_bilinear Q hpoly hhom ] ; norm_num [ two_smul ];
        ext; norm_num [ algebra_mul ] ; ring;
      convert span_of_products_mul_left_v2 Q hpoly hhom d ( u - v ) ( u - v ) h using 1;
    convert Submodule.add_mem _ h_Q_uv ( Submodule.smul_mem _ 2 ( span_of_products_mul_left_v2 Q hpoly hhom d v ( u - v ) h ) ) using 1 ; aesop

/-
A tree structure to represent products in the algebra, along with functions to calculate the size of the tree and evaluate it.
-/
inductive AlgebraTree (V : Type*)
  | leaf (v : V)
  | node (l r : AlgebraTree V)

def treeSize {V : Type*} : AlgebraTree V → ℕ
  | AlgebraTree.leaf _ => 1
  | AlgebraTree.node l r => treeSize l + treeSize r

def evalTree {n : ℕ} (mul : (Fin n → ℂ) → (Fin n → ℂ) → (Fin n → ℂ)) : AlgebraTree (Fin n → ℂ) → (Fin n → ℂ)
  | AlgebraTree.leaf v => v
  | AlgebraTree.node l r => mul (evalTree mul l) (evalTree mul r)