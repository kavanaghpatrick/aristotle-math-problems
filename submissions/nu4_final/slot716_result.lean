/-
A map F is a polynomial map if there exists a tuple of polynomials P such that F(x) is the evaluation of P at x.
-/
def IsPolynomialMap {n : ℕ} (F : (Fin n → ℂ) → (Fin n → ℂ)) : Prop :=
  ∃ P : Fin n → MvPolynomial (Fin n) ℂ, ∀ x, F x = fun i => MvPolynomial.eval x (P i)

/-
The polynomial representation of a map F. If F is a polynomial map, this returns the polynomials; otherwise it returns 0.
-/
noncomputable def polynomialRep {n : ℕ} (F : (Fin n → ℂ) → (Fin n → ℂ)) : Fin n → MvPolynomial (Fin n) ℂ :=
  if h : IsPolynomialMap F then Classical.choose h else 0

/-
The degree of a polynomial map is the maximum of the total degrees of its component polynomials.
-/
noncomputable def PolyDegree {n : ℕ} (F : (Fin n → ℂ) → (Fin n → ℂ)) : ℕ :=
  Finset.sup Finset.univ (fun i => (polynomialRep F i).totalDegree)

/-
The Jacobian matrix of a polynomial map F at a point x is the matrix of partial derivatives of the component polynomials evaluated at x.
-/
