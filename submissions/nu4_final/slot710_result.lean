        have h_val_desc : padicValNat p (Nat.descFactorial n (k + 1)) = padicValNat p (Nat.factorial (k + 1)) + padicValNat p (Nat.choose n (k + 1)) := by
          by_cases h : n < k + 1 <;> simp_all +decide [ Nat.descFactorial_eq_factorial_mul_choose ];
          · contrapose! hn;
            rw [ Nat.ModEq, Nat.mod_eq_of_lt, Nat.mod_eq_of_lt ] <;> norm_num;
            · refine' ne_of_lt ( lt_tsub_iff_left.mpr _ );
              refine' lt_of_lt_of_le _ ( Finset.prod_le_prod_of_subset_of_one_le' ( Finset.singleton_subset_iff.mpr <| Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr <| Nat.lt_succ_of_le hp, hp_prime ⟩ ) fun _ _ _ => Nat.one_le_pow _ _ <| Nat.Prime.pos <| by aesop ) ; norm_num;
              refine' lt_of_lt_of_le ( add_lt_add_left h 1 ) _;
              exact Nat.recOn k ( by norm_num; linarith [ hp_prime.two_le ] ) fun n ihn => by rw [ Nat.pow_succ' ] ; nlinarith [ hp_prime.two_le, Nat.pow_le_pow_right hp_prime.one_lt.le ( by linarith : n + 1 ≥ 1 ) ] ;
            · exact fun i hi hi' => pow_pos hi'.pos _;
            · refine' lt_of_lt_of_le h _;
              refine' le_trans _ ( Nat.le_of_dvd ( Finset.prod_pos fun p hp => pow_pos ( Nat.Prime.pos ( by aesop ) ) _ ) ( Finset.dvd_prod_of_mem _ ( show 2 ∈ Finset.filter Nat.Prime ( Finset.range ( k + 2 ) ) from Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr ( by linarith [ show k > 0 from Nat.pos_of_ne_zero ( by aesop_cat ) ] ), Nat.prime_two ⟩ ) ) );
              exact Nat.recOn k ( by norm_num ) fun n ihn => by norm_num [ Nat.pow_succ' ] at ihn ⊢ ; linarith;
          · have h_val_desc : padicValNat p (Nat.descFactorial n (k + 1)) = padicValNat p (Nat.factorial (k + 1) * Nat.choose n (k + 1)) := by
              rw [ Nat.descFactorial_eq_factorial_mul_choose ];
            haveI := Fact.mk hp_prime; rw [ padicValNat.mul ] at h_val_desc <;> simp_all +decide [ Nat.factorial_ne_zero, Nat.choose_eq_zero_iff ] ;
            convert h_val_desc using 1;
            rw [ Nat.descFactorial_eq_factorial_mul_choose ];
        have h_val_central : padicValNat p (Nat.centralBinom n) ≥ k + 1 := by
          convert valuation_ge_of_mod_eq_neg_one h_mod using 1;
          exact ⟨ hp_prime ⟩;
        have h_val_factorial : padicValNat p (Nat.factorial (k + 1)) ≤ k + 1 := by
          have h_val_factorial : padicValNat p (Nat.factorial (k + 1)) = ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (k + 1) / p ^ i := by
            haveI := Fact.mk hp_prime; rw [ padicValNat_factorial ] ; aesop;
          have h_sum_le : ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (k + 1) / p ^ i ≤ (k + 1) * (∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (1 / p ^ i : ℝ)) := by
            norm_num [ Finset.mul_sum _ _ _ ];
            exact Finset.sum_le_sum fun i hi => by rw [ ← div_eq_mul_inv ] ; rw [ le_div_iff₀ ( pow_pos ( Nat.cast_pos.mpr hp_prime.pos ) _ ) ] ; norm_cast; linarith [ Nat.div_mul_le_self ( k + 1 ) ( p ^ i ) ] ;
          have h_sum_le : ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (1 / p ^ i : ℝ) < 1 := by
            ring_nf;
            erw [ geom_sum_Ico ] <;> norm_num;
            · rw [ div_lt_iff_of_neg ] <;> nlinarith only [ show ( p : ℝ ) ≥ 2 by exact_mod_cast hp_prime.two_le, inv_pos.mpr ( show ( p : ℝ ) > 0 by exact_mod_cast hp_prime.pos ), inv_pos.mpr ( show ( p ^ ( 1 + Nat.log p ( 1 + k ) ) : ℝ ) > 0 by exact_mod_cast pow_pos hp_prime.pos _ ), mul_inv_cancel₀ ( show ( p : ℝ ) ≠ 0 by exact_mod_cast hp_prime.ne_zero ), mul_inv_cancel₀ ( show ( p ^ ( 1 + Nat.log p ( 1 + k ) ) : ℝ ) ≠ 0 by exact_mod_cast pow_ne_zero _ hp_prime.ne_zero ), pow_le_pow_right₀ ( show ( p : ℝ ) ≥ 1 by exact_mod_cast hp_prime.one_lt.le ) ( show 1 + Nat.log p ( 1 + k ) ≥ 1 by norm_num ) ];
            · exact hp_prime.ne_one;
          exact h_val_factorial.symm ▸ Nat.le_of_lt_succ ( by rw [ ← @Nat.cast_lt ℝ ] ; push_cast at *; nlinarith );
        linarith

/-
For a prime p > k+1 and n >= k, p divides at most one term in the product n(n-1)...(n-k).
-/
lemma at_most_one_dvd_descFactorial {n k p : ℕ} [Fact (Nat.Prime p)] (hp : k + 1 < p) (hn : n ≥ k) :
  ({i ∈ Finset.range (k + 1) | p ∣ n - i}.card ≤ 1) := by
    by_contra h_contra
    obtain ⟨i, j, hij, hi_div, hj_div⟩ : ∃ i j : ℕ, i ∈ Finset.range (k + 1) ∧ j ∈ Finset.range (k + 1) ∧ i < j ∧ p ∣ (n - i) ∧ p ∣ (n - j) := by
      obtain ⟨ i, hi, j, hj, hij ⟩ := Finset.one_lt_card.mp ( lt_of_not_ge h_contra ) ; cases lt_trichotomy i j <;> aesop;
    have h_diff : p ∣ (j - i) := by
      convert Nat.dvd_sub' hj_div.2.1 hj_div.2.2 using 1 ; rw [ tsub_right_comm, Nat.sub_sub_self ( by linarith [ Finset.mem_range.mp hij, Finset.mem_range.mp hi_div ] ) ];
    linarith [ Nat.le_of_dvd ( Nat.sub_pos_of_lt hj_div.1 ) h_diff, Nat.sub_add_cancel hj_div.1.le, Finset.mem_range.mp hij, Finset.mem_range.mp hi_div ]

#check Nat.factorization_le_iff_dvd
#check Nat.descFactorial_pos
#check Nat.centralBinom_pos

/-
Explicit version of the small primes lemma using the constructed modulus.
-/
lemma small_primes_ok_explicit (k : Nat) :
  ∀ n, n ≡ (erdos_modulus k) - 1 [MOD erdos_modulus k] →
    ∀ p, p ≤ k + 1 → Nat.Prime p →
      padicValNat p (n.descFactorial (k + 1)) ≤ padicValNat p (Nat.centralBinom n) := by
        intros n hn p hp hp_prime
        have h_cong : n ≡ p^(k+1) - 1 [MOD p^(k+1)] := by
          refine' hn.of_dvd _ |> Nat.ModEq.trans <| Nat.ModEq.symm <| Nat.modEq_of_dvd _;
          · exact Finset.dvd_prod_of_mem _ ( Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr ( by linarith ), hp_prime ⟩ );
          · simp +decide [ Nat.cast_sub ( show 1 ≤ erdos_modulus k from erdos_modulus_pos k ), Nat.cast_sub ( show 1 ≤ p ^ ( k + 1 ) from Nat.one_le_pow _ _ hp_prime.pos ) ];
            exact_mod_cast Finset.dvd_prod_of_mem _ ( Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr ( by linarith ), hp_prime ⟩ );
        -- By the properties of the p-adic valuation, we know that $v_p(\binom{n}{k+1}) = 0$.
        have h_val_zero : padicValNat p (Nat.choose n (k + 1)) = 0 := by
          convert valuation_choose_eq_zero_of_mod_eq_neg_one h_cong using 1;
          exact ⟨ hp_prime ⟩;
        -- By the properties of the p-adic valuation, we know that $v_p(n^{\underline{k+1}}) = v_p((k+1)!) + v_p(\binom{n}{k+1})$.
        have h_val_desc : padicValNat p (Nat.descFactorial n (k + 1)) = padicValNat p (Nat.factorial (k + 1)) + padicValNat p (Nat.choose n (k + 1)) := by
          by_cases h : n < k + 1 <;> simp_all +decide [ Nat.descFactorial_eq_factorial_mul_choose ];
          · contrapose! h_cong;
            rw [ Nat.ModEq, Nat.mod_eq_of_lt, Nat.mod_eq_of_lt ] <;> norm_num;
            · refine' ne_of_lt ( lt_tsub_iff_left.mpr _ );
              refine' lt_of_lt_of_le ( add_lt_add_left h 1 ) _;
              exact Nat.recOn k ( by norm_num; linarith [ hp_prime.two_le ] ) fun n ihn => by rw [ Nat.pow_succ' ] ; nlinarith [ hp_prime.two_le ] ;
            · exact pow_pos hp_prime.pos _;
            · exact lt_of_lt_of_le h ( Nat.le_of_lt ( Nat.recOn ( k + 1 ) ( by norm_num ) fun n ihn => by rw [ pow_succ' ] ; nlinarith [ Nat.Prime.one_lt hp_prime ] ) );
          · have h_val_desc : padicValNat p (Nat.descFactorial n (k + 1)) = padicValNat p (Nat.factorial (k + 1) * Nat.choose n (k + 1)) := by
              rw [ Nat.descFactorial_eq_factorial_mul_choose ];
            haveI := Fact.mk hp_prime; rw [ padicValNat.mul ] at h_val_desc <;> simp_all +decide [ Nat.factorial_ne_zero, Nat.choose_eq_zero_iff ] ;
            convert h_val_desc using 1;
            rw [ Nat.descFactorial_eq_factorial_mul_choose ];
        -- By the properties of the p-adic valuation, we know that $v_p((k+1)!) \leq k$.
        have h_val_fact : padicValNat p (Nat.factorial (k + 1)) ≤ k := by
          have h_val_fact : padicValNat p (Nat.factorial (k + 1)) = ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (k + 1) / p^i := by
            haveI := Fact.mk hp_prime; rw [ padicValNat_factorial ] ; aesop;
          -- Each term in the sum $\sum_{i=1}^{\infty} \left\lfloor \frac{k+1}{p^i} \right\rfloor$ is less than or equal to $\frac{k+1}{p^i}$, and there are at most $\log_p(k+1)$ such terms.
          have h_sum_bound : ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (k + 1) / p^i ≤ (k + 1) * (∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (1 / p^i : ℝ)) := by
            norm_num [ Finset.mul_sum _ _ _ ];
            exact Finset.sum_le_sum fun i hi => by rw [ ← div_eq_mul_inv ] ; rw [ le_div_iff₀ ( pow_pos ( Nat.cast_pos.mpr hp_prime.pos ) _ ) ] ; norm_cast; linarith [ Nat.div_mul_le_self ( k + 1 ) ( p ^ i ) ] ;
          -- The series $\sum_{i=1}^{\infty} \frac{1}{p^i}$ is a geometric series with sum $\frac{1}{p-1}$.
          have h_geo_series : ∑ i ∈ Finset.Ico 1 (Nat.log p (k + 1) + 1), (1 / p^i : ℝ) < 1 := by
            ring_nf;
            erw [ geom_sum_Ico ] <;> norm_num;
            · rw [ div_lt_iff_of_neg ] <;> nlinarith only [ show ( p : ℝ ) ≥ 2 by exact_mod_cast hp_prime.two_le, inv_pos.mpr ( show ( p : ℝ ) > 0 by exact_mod_cast hp_prime.pos ), inv_pos.mpr ( show ( p ^ ( 1 + Nat.log p ( 1 + k ) ) : ℝ ) > 0 by exact_mod_cast pow_pos hp_prime.pos _ ), mul_inv_cancel₀ ( show ( p : ℝ ) ≠ 0 by exact_mod_cast hp_prime.ne_zero ), mul_inv_cancel₀ ( show ( p ^ ( 1 + Nat.log p ( 1 + k ) ) : ℝ ) ≠ 0 by exact_mod_cast pow_ne_zero _ hp_prime.ne_zero ), pow_le_pow_right₀ ( show ( p : ℝ ) ≥ 1 by exact_mod_cast hp_prime.one_lt.le ) ( show 1 + Nat.log p ( 1 + k ) ≥ 1 by norm_num ) ];
            · exact hp_prime.ne_one;
          exact h_val_fact.symm ▸ Nat.le_of_lt_succ ( by rw [ ← @Nat.cast_lt ℝ ] ; push_cast at *; nlinarith );
        have h_val_binom : padicValNat p (Nat.centralBinom n) ≥ k + 1 := by
          convert valuation_ge_of_mod_eq_neg_one h_cong using 1;
          exact ⟨ hp_prime ⟩;
        linarith

/-
For p > k+1, the p-adic valuation of the descending factorial is the maximum of the valuations of the factors.
-/
lemma valuation_descFactorial_eq_max_valuation {n k p : ℕ} [Fact (Nat.Prime p)] (hp : k + 1 < p) (hn : n ≥ k) :
  padicValNat p (n.descFactorial (k + 1)) = (Finset.range (k + 1)).sup (fun i => padicValNat p (n - i)) := by
    -- By `at_most_one_dvd_descFactorial`, at most one term $n-i$ is divisible by $p$.
    have h_at_most_one_dvd : (Finset.filter (fun i => p ∣ n - i) (Finset.range (k + 1))).card ≤ 1 := by
      exact?;
    -- Consider two cases: either there is no $i$ such that $p \mid n - i$, or there is exactly one such $i$.
    by_cases h_no_dvd : ∀ i ∈ Finset.range (k + 1), ¬p ∣ n - i;
    · rw [ Nat.descFactorial_eq_prod_range ];
      rw [ padicValNat.eq_zero_of_not_dvd ];
      · rw [ eq_comm, Finset.sup_congr rfl fun i hi => by rw [ padicValNat.eq_zero_of_not_dvd ( h_no_dvd i hi ) ] ] ; norm_num;
      · simp_all +decide [ Nat.Prime.dvd_iff_not_coprime Fact.out, Nat.coprime_prod_right_iff ];
    · obtain ⟨i, hi⟩ : ∃ i ∈ Finset.range (k + 1), p ∣ n - i ∧ ∀ j ∈ Finset.range (k + 1), j ≠ i → ¬p ∣ n - j := by
        simp +zetaDelta at *;
        obtain ⟨ i, hi, hi' ⟩ := h_no_dvd; exact ⟨ i, hi, hi', fun j hj hj' hj'' => h_at_most_one_dvd.not_lt <| Finset.one_lt_card.2 ⟨ i, by aesop, j, by aesop ⟩ ⟩ ;
      -- In this case, the p-adic valuation of the descending factorial is equal to the p-adic valuation of $n - i$.
      have h_val_eq : padicValNat p (Finset.prod (Finset.range (k + 1)) (fun j => n - j)) = padicValNat p (n - i) := by
        have h_val_eq : padicValNat p (Finset.prod (Finset.erase (Finset.range (k + 1)) i) (fun j => n - j)) = 0 := by
          simp_all +decide [ Nat.Prime.dvd_iff_not_coprime Fact.out, Nat.coprime_prod_right_iff ];
        have h_val_eq : padicValNat p (Finset.prod (Finset.range (k + 1)) (fun j => n - j)) = padicValNat p ((n - i) * Finset.prod (Finset.erase (Finset.range (k + 1)) i) (fun j => n - j)) := by
          rw [ mul_comm, Finset.prod_erase_mul _ _ hi.1 ];
        by_cases hi' : n - i = 0 <;> by_cases hi'' : ∏ j ∈ Finset.erase ( Finset.range ( k + 1 ) ) i, ( n - j ) = 0 <;> simp_all +decide [ padicValNat.mul ];
        simp_all +decide [ Finset.prod_eq_zero_iff ];
        obtain ⟨ a, ⟨ ha₁, ha₂ ⟩, ha₃ ⟩ := hi''; specialize hi; have := hi.2.2 a ha₂; simp_all +decide [ Nat.sub_eq_iff_eq_add ] ;
      convert h_val_eq using 1;
      · rw [ Nat.descFactorial_eq_prod_range ];
      · refine' le_antisymm _ _ <;> simp_all +decide [ Finset.sup_le_iff ];
        · intro j hj; by_cases hj' : j = i <;> simp_all +decide [ padicValNat.eq_zero_of_not_dvd ] ;
        · exact Finset.le_sup ( f := fun i => padicValNat p ( n - i ) ) ( Finset.mem_range.mpr hi.1 )

/-
a divides b iff the p-adic valuation of a is less than or equal to the p-adic valuation of b for all primes p.
-/
lemma dvd_iff_forall_padicValNat_le {a b : ℕ} (ha : a ≠ 0) (hb : b ≠ 0) :
  a ∣ b ↔ ∀ p : ℕ, Nat.Prime p → padicValNat p a ≤ padicValNat p b := by
    constructor <;> intro h <;> simp_all +decide [ ← Nat.factorization_le_iff_dvd ];
    · intro p pp; have := h p; simp_all +decide [ Nat.factorization ] ;
    · intro p; by_cases hp : Nat.Prime p <;> simp_all +decide [ Nat.factorization ] ;

/-
For k >= 1, the Erdos modulus is at least 2.
-/
lemma erdos_modulus_ge_two (k : Nat) (hk : k ≥ 1) : erdos_modulus k ≥ 2 := by
  exact le_trans ( by decide ) ( Nat.le_of_dvd ( erdos_modulus_pos k ) ( Finset.dvd_prod_of_mem _ ( Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr ( by linarith ), Nat.prime_two ⟩ ) |> dvd_trans ( pow_dvd_pow _ ( Nat.succ_le_succ hk ) ) ) )