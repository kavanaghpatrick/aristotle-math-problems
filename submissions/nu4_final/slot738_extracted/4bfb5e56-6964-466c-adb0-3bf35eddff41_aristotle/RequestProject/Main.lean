            ·
              by_cases h6 : n ≤ 850
              · have hi : n - 801 < brocardDataChunk6.length := by rw [brocardChunk6_len]; omega
                have hentry := checkListB_get 801 brocardDataChunk6 brocardCheck6 (n - 801) hi
                rw [show 801 + (n - 801) = n from by omega] at hentry
                exact checkEntryB_implies n brocardDataChunk6[n - 801] hentry
              ·
                by_cases h7 : n ≤ 900
                · have hi : n - 851 < brocardDataChunk7.length := by rw [brocardChunk7_len]; omega
                  have hentry := checkListB_get 851 brocardDataChunk7 brocardCheck7 (n - 851) hi
                  rw [show 851 + (n - 851) = n from by omega] at hentry
                  exact checkEntryB_implies n brocardDataChunk7[n - 851] hentry
                ·
                  by_cases h8 : n ≤ 950
                  · have hi : n - 901 < brocardDataChunk8.length := by rw [brocardChunk8_len]; omega
                    have hentry := checkListB_get 901 brocardDataChunk8 brocardCheck8 (n - 901) hi
