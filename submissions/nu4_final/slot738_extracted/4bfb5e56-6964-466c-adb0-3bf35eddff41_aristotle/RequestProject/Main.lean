import Mathlib

set_option maxHeartbeats 800000

/-!
# Brocard's Conjecture for n ∈ [501, 1000]

We verify Brocard's conjecture computationally for all n in the range [501, 1000]:
for every such n, there are at least 4 primes strictly between p_n² and p_{n+1}²,
where p_k denotes the k-th prime (0-indexed via `Nat.nth Nat.Prime`).

## Proof strategy

The proof uses a witness-based approach:
1. For each n, we provide 4 explicit primes in the interval (p_n², p_{n+1}²).
2. A computable Bool checker verifies primality, prime-count correctness, and bounds.
3. `native_decide` confirms the check passes (10 chunks of 50 entries each).
4. A bridging lemma connects verified entries to the `Nat.nth`-based statement via `Nat.nth_count`.
-/

section Helpers

private lemma nth_prime_of_count {m n : ℕ} (hp : Nat.Prime m) (hc : Nat.count Nat.Prime m = n) :
    Nat.nth Nat.Prime n = m := by
  rw [← hc]; exact Nat.nth_count hp

private lemma four_le_card_filter_of_witnesses {a b w1 w2 w3 w4 : ℕ}
    (h1 : a < w1) (h12 : w1 < w2) (h23 : w2 < w3) (h34 : w3 < w4) (h4 : w4 < b)
    (hp1 : Nat.Prime w1) (hp2 : Nat.Prime w2) (hp3 : Nat.Prime w3) (hp4 : Nat.Prime w4) :
    4 ≤ ((Finset.Ioo a b).filter Nat.Prime).card := by
  have sub : ({w1, w2, w3, w4} : Finset ℕ) ⊆ (Finset.Ioo a b).filter Nat.Prime := by
    intro x hx; simp only [Finset.mem_insert, Finset.mem_singleton] at hx; rw [Finset.mem_filter]
    rcases hx with rfl | rfl | rfl | rfl <;>
      exact ⟨Finset.mem_Ioo.mpr ⟨by omega, by omega⟩, by assumption⟩
  have hcard : ({w1, w2, w3, w4} : Finset ℕ).card = 4 := by
    have : w1 ∉ ({w2, w3, w4} : Finset ℕ) := by
      simp only [Finset.mem_insert, Finset.mem_singleton]; omega
    have : w2 ∉ ({w3, w4} : Finset ℕ) := by
      simp only [Finset.mem_insert, Finset.mem_singleton]; omega
    have : w3 ∉ ({w4} : Finset ℕ) := by
      simp only [Finset.mem_singleton]; omega
    rw [Finset.card_insert_of_notMem ‹w1 ∉ _›, Finset.card_insert_of_notMem ‹w2 ∉ _›,
        Finset.card_insert_of_notMem ‹w3 ∉ _›, Finset.card_singleton]
  linarith [Finset.card_le_card sub]

end Helpers

section Check

private def checkEntryB (n : ℕ) (entry : ℕ × ℕ × ℕ × ℕ × ℕ × ℕ) : Bool :=
  let p := entry.1; let q := entry.2.1
  let w1 := entry.2.2.1; let w2 := entry.2.2.2.1
  let w3 := entry.2.2.2.2.1; let w4 := entry.2.2.2.2.2
  decide (Nat.Prime p) && decide (Nat.count Nat.Prime p = n) &&
  decide (Nat.Prime q) && decide (Nat.count Nat.Prime q = n + 1) &&
  decide (Nat.Prime w1) && decide (Nat.Prime w2) &&
  decide (Nat.Prime w3) && decide (Nat.Prime w4) &&
  decide (p ^ 2 < w1) && decide (w1 < w2) && decide (w2 < w3) &&
  decide (w3 < w4) && decide (w4 < q ^ 2)

private lemma checkEntryB_implies (n : ℕ) (entry : ℕ × ℕ × ℕ × ℕ × ℕ × ℕ)
    (h : checkEntryB n entry = true) :
    4 ≤ ((Finset.Ioo (n.nth Nat.Prime ^ 2) ((n+1).nth Nat.Prime ^ 2)).filter
      Nat.Prime).card := by
  simp only [checkEntryB, Bool.and_eq_true, decide_eq_true_eq] at h
  obtain ⟨⟨⟨⟨⟨⟨⟨⟨⟨⟨⟨⟨hp, hcp⟩, hq⟩, hcq⟩, hw1⟩, hw2⟩, hw3⟩, hw4⟩, hlt1⟩, hlt12⟩, hlt23⟩, hlt34⟩, hlt4⟩ := h
  rw [nth_prime_of_count hp hcp, nth_prime_of_count hq hcq]
  exact four_le_card_filter_of_witnesses hlt1 hlt12 hlt23 hlt34 hlt4 hw1 hw2 hw3 hw4

private def checkListB : ℕ → List (ℕ × ℕ × ℕ × ℕ × ℕ × ℕ) → Bool
  | _, [] => true
  | n, entry :: rest => checkEntryB n entry && checkListB (n + 1) rest

private lemma checkListB_get (n : ℕ) (data : List (ℕ × ℕ × ℕ × ℕ × ℕ × ℕ))
    (h : checkListB n data = true) (i : ℕ) (hi : i < data.length) :
    checkEntryB (n + i) data[i] = true := by
  induction data generalizing n i with
  | nil => exact absurd hi (by simp)
  | cons head tail ih =>
    simp only [checkListB, Bool.and_eq_true] at h
    cases i with
    | zero => simpa using h.1
    | succ j =>
      have := ih (n + 1) h.2 j (by simpa using hi)
      simpa [show n + (j + 1) = n + 1 + j from by omega] using this

end Check

