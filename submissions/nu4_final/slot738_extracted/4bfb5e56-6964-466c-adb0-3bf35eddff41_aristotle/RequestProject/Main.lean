section MainTheorem

/-- **Brocard's Conjecture for n ∈ [501, 1000]**: For every n in this range,
    between the squares of the n-th and (n+1)-th primes there are at least
    four prime numbers. -/
theorem brocard_conjecture_extended_501_1000 :
    ∀ n : ℕ, 501 ≤ n → n ≤ 1000 →
      4 ≤ ((Finset.Ioo (n.nth Nat.Prime ^ 2) ((n+1).nth Nat.Prime ^ 2)).filter
        Nat.Prime).card := by
  intro n hn1 hn2
  by_cases h0 : n ≤ 550
  · have hi : n - 501 < brocardDataChunk0.length := by rw [brocardChunk0_len]; omega
    have hentry := checkListB_get 501 brocardDataChunk0 brocardCheck0 (n - 501) hi
    rw [show 501 + (n - 501) = n from by omega] at hentry
    exact checkEntryB_implies n brocardDataChunk0[n - 501] hentry
  ·
    by_cases h1 : n ≤ 600
    · have hi : n - 551 < brocardDataChunk1.length := by rw [brocardChunk1_len]; omega
      have hentry := checkListB_get 551 brocardDataChunk1 brocardCheck1 (n - 551) hi
      rw [show 551 + (n - 551) = n from by omega] at hentry
      exact checkEntryB_implies n brocardDataChunk1[n - 551] hentry
    ·
      by_cases h2 : n ≤ 650
      · have hi : n - 601 < brocardDataChunk2.length := by rw [brocardChunk2_len]; omega
        have hentry := checkListB_get 601 brocardDataChunk2 brocardCheck2 (n - 601) hi
        rw [show 601 + (n - 601) = n from by omega] at hentry
        exact checkEntryB_implies n brocardDataChunk2[n - 601] hentry
      ·
        by_cases h3 : n ≤ 700
        · have hi : n - 651 < brocardDataChunk3.length := by rw [brocardChunk3_len]; omega
          have hentry := checkListB_get 651 brocardDataChunk3 brocardCheck3 (n - 651) hi
          rw [show 651 + (n - 651) = n from by omega] at hentry
          exact checkEntryB_implies n brocardDataChunk3[n - 651] hentry
        ·
          by_cases h4 : n ≤ 750
          · have hi : n - 701 < brocardDataChunk4.length := by rw [brocardChunk4_len]; omega
            have hentry := checkListB_get 701 brocardDataChunk4 brocardCheck4 (n - 701) hi
            rw [show 701 + (n - 701) = n from by omega] at hentry
            exact checkEntryB_implies n brocardDataChunk4[n - 701] hentry
          ·
            by_cases h5 : n ≤ 800
            · have hi : n - 751 < brocardDataChunk5.length := by rw [brocardChunk5_len]; omega
              have hentry := checkListB_get 751 brocardDataChunk5 brocardCheck5 (n - 751) hi
              rw [show 751 + (n - 751) = n from by omega] at hentry
