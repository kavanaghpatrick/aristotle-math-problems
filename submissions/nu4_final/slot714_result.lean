def list_le (l1 l2 : List ℕ) : Bool :=
  match l1, l2 with
  | [], [] => true
  | [], _ => true
  | _, [] => false
  | h1::t1, h2::t2 => if h1 < h2 then true else if h1 > h2 then false else list_le t1 t2

def sig_le (s1 s2 : List (List ℕ)) : Bool :=
  match s1, s2 with
  | [], [] => true
  | [], _ => true
  | _, [] => false
  | h1::t1, h2::t2 => if list_le h1 h2 && !(list_le h2 h1) then true else if list_le h2 h1 && !(list_le h1 h2) then false else sig_le t1 t2

