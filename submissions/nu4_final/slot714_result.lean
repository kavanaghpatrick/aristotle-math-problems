/-
Two natural numbers x and y are an Erdos 850 solution if they are distinct and x, x+1, x+2 have the same prime factors as y, y+1, y+2 respectively.
-/
def is_erdos_850_solution (x y : ℕ) : Prop :=
  x ≠ y ∧
  x.primeFactors = y.primeFactors ∧
  (x + 1).primeFactors = (y + 1).primeFactors ∧
  (x + 2).primeFactors = (y + 2).primeFactors

/-
The Erdos 850 conjecture states that there exist infinitely many natural numbers x such that for some y, x and y form an Erdos 850 solution.
-/
def erdos_850_conjecture : Prop :=
  ∀ N, ∃ x > N, ∃ y, is_erdos_850_solution x y