  -- x_5 = ...
  -- We can just check all odd values mod 8.
  rw [ h_period ] ; ( rw [ ← Nat.mod_add_div k 8 ] ; norm_num [ Nat.add_mod, Nat.mul_mod ] ; have := Nat.mod_lt k ( by norm_num : 0 < 8 ) ; interval_cases k % 8 <;> trivial; )

/-
$x_n \pmod{19}$ takes values in a specific set.
-/
lemma pell8_x_mod_19 (n : ℕ) : Pell8_x n % 19 ∈ ({1, 3, 17, 4, 7, 0, 12, 15, 2, 16, 18} : Set ℕ) := by
  rcases n with ( _ | _ | _ | n ) <;> simp_all +arith +decide;
  have h_recurrence : Pell8_x (n + 3) ^ 2 - 8 * Pell8_y (n + 3) ^ 2 = 1 := by
    exact pell8_solutions _;
  rw [ Nat.sub_eq_iff_eq_add ] at h_recurrence;
  · replace h_recurrence := congr_arg ( · % 19 ) h_recurrence ; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at h_recurrence ⊢ ; have := Nat.mod_lt ( Pell8_x ( n + 3 ) ) ( by decide : 0 < 19 ) ; have := Nat.mod_lt ( Pell8_y ( n + 3 ) ) ( by decide : 0 < 19 ) ; interval_cases Pell8_x ( n + 3 ) % 19 <;> interval_cases Pell8_y ( n + 3 ) % 19 <;> simp +decide at h_recurrence ⊢;
  · exact le_of_lt ( Nat.lt_of_sub_eq_succ h_recurrence )

/-
$x_n \equiv 3 \pmod{17}$ iff $n \equiv 1, 7 \pmod 8$.
-/
lemma pell8_x_mod_17_eq_3_iff (n : ℕ) : Pell8_x n % 17 = 3 ↔ n % 8 = 1 ∨ n % 8 = 7 := by
  -- We will prove this using induction on $n$.
  have h_induction : ∀ n, Pell8_x n % 17 = if n % 8 = 0 then 1 else if n % 8 = 1 then 3 else if n % 8 = 2 then 0 else if n % 8 = 3 then 14 else if n % 8 = 4 then 16 else if n % 8 = 5 then 14 else if n % 8 = 6 then 0 else 3 := by
    intro n; induction' n using Nat.strong_induction_on with n ih; rcases n with ( _ | _ | _ | _ | _ | _ | _ | _ | n ) <;> simp +arith +decide [ * ] ;
    -- By definition of $Pell8_x$, we have $Pell8_x (n + 8) = 6 * Pell8_x (n + 7) - Pell8_x (n + 6)$.
    have h_recurrence : Pell8_x (n + 8) = 6 * Pell8_x (n + 7) - Pell8_x (n + 6) := by
      exact?;
    zify [ h_recurrence ];
    rw [ Nat.cast_sub ] <;> norm_num [ Int.add_emod, Int.sub_emod, Int.mul_emod ] ; norm_cast ; simp +arith +decide [ * ] ;
    · rw [ ← Nat.mod_add_div n 8 ] ; have := Nat.mod_lt n ( by decide : 0 < 8 ) ; interval_cases n % 8 <;> norm_num [ Nat.add_mod, Nat.mul_mod, Int.subNatNat_eq_coe ] ;
      all_goals norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mul_mod ] ;
    · -- By definition of $Pell8_x$, we know that $Pell8_x (n + 7) \geq Pell8_x (n + 6)$.
      have h_monotone : ∀ n, Pell8_x (n + 1) ≥ Pell8_x n := by
        intro n; induction n <;> simp +arith +decide [ * ] ;
        rename_i n hn;
        exact Nat.le_sub_of_add_le ( by linarith! [ show Pell8_x ( n + 1 ) ≥ Pell8_x n from hn ] );
      linarith [ h_monotone ( n + 6 ), h_monotone ( n + 7 ) ];
  grind

/-
If $x_n \equiv 14 \pmod{17}$, then $3x_n \neq k^2 + 5$.
-/
lemma pell8_x_3n_neq_k_sq_plus_5_of_mod_17_eq_14 (n k : ℕ) (h_mod : Pell8_x n % 17 = 14) : 3 * Pell8_x n ≠ k^2 + 5 := by
  exact ne_of_apply_ne ( · % 17 ) ( by norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod, h_mod ] ; have := Nat.mod_lt k ( by decide : 0 < 17 ) ; interval_cases k % 17 <;> trivial )

/-
The sequence $x_n \pmod{17}$ has period 8.
-/
lemma pell8_x_mod_17_period (n : ℕ) : Pell8_x (n + 8) % 17 = Pell8_x n % 17 := by
  induction' n using Nat.strong_induction_on with n ih;
  rcases n with ( _ | _ | n ) <;> simp +arith +decide [ *, Nat.add_mod, Nat.mul_mod ] at *;
  rw [ show Pell8_x ( n + 10 ) = 6 * Pell8_x ( n + 9 ) - Pell8_x ( n + 8 ) from rfl, show Pell8_x ( n + 2 ) = 6 * Pell8_x ( n + 1 ) - Pell8_x n from rfl ];
  zify;
  rw [ Nat.cast_sub, Nat.cast_sub ] <;> norm_num [ Int.sub_emod, Int.mul_emod, ih ];
  · grind;
  · linarith [ show Pell8_x ( n + 1 ) ≥ Pell8_x n from Nat.recOn n ( by decide ) fun n ihn => by { rw [ show Pell8_x ( n + 2 ) = 6 * Pell8_x ( n + 1 ) - Pell8_x n from rfl ] ; exact le_tsub_of_add_le_left <| by linarith } ];
  · -- By definition of Pell8_x, we know that Pell8_x (n + 9) ≥ Pell8_x (n + 8).
    have h_pell8_x_mono : ∀ n, Pell8_x (n + 1) ≥ Pell8_x n := by
      intro n;
      induction' n with n ih;
      · decide;
      · exact le_tsub_of_add_le_left ( by linarith! [ show Pell8_x ( n + 1 ) ≥ Pell8_x n from ih ] );
    linarith [ h_pell8_x_mono ( n + 8 ), h_pell8_x_mono ( n + 9 ) ]