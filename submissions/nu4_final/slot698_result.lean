def Pell8_x (n : ℕ) : ℕ :=
  match n with
  | 0 => 1
  | 1 => 3
  | n + 2 => 6 * Pell8_x (n + 1) - Pell8_x n

def Pell8_y (n : ℕ) : ℕ :=
  match n with
  | 0 => 0
  | 1 => 1
  | n + 2 => 6 * Pell8_y (n + 1) - Pell8_y n

