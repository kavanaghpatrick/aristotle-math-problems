/-
The product of k terms of an arithmetic progression (with gcd(n,d)=1) cannot be a perfect l-th power.
-/
def Erdos672With (k l : ℕ) : Prop :=
  ∀ n d : ℕ, n > 0 → d > 0 → n.gcd d = 1 →
  ¬ ∃ y : ℕ, (∏ i ∈ Finset.range k, (n + i * d)) = y ^ l

/-
If $U V = d^4$ and $U + V = 2(A + d^2)$ with $\gcd(A, d) = 1$, then $\gcd(U, V)$ is 1 or 2.
-/
lemma erdos_672_gcd_lemma (A d U V : ℕ) (hA : A > 0) (hd : d > 0) (hcop : A.gcd d = 1)
    (hUV : U * V = d^4) (hsum : U + V = 2 * (A + d^2)) :
    (U.gcd V = 1) ∨ (U.gcd V = 2) := by
  -- Let $g = \gcd(U, V)$. Then $g$ divides $U+V = 2(A+d^2)$ and $g$ divides $UV = d^4$.
  let g := Nat.gcd U V
  have hg1 : g ∣ 2 * (A + d ^ 2) := by
    exact hsum ▸ Nat.dvd_add ( Nat.gcd_dvd_left _ _ ) ( Nat.gcd_dvd_right _ _ )
  have hg2 : g ∣ d ^ 4 := by
    exact hUV ▸ dvd_mul_of_dvd_left ( Nat.gcd_dvd_left _ _ ) _
  have hg3 : g ∣ 2 * Nat.gcd (A + d ^ 2) (d ^ 4) := by
    rw [ ← Nat.gcd_mul_left ];
    exact Nat.dvd_gcd hg1 ( hg2.mul_left 2 );
  simp_all +decide [ Nat.Coprime, Nat.Coprime.gcd_eq_one ];
  rwa [ Nat.dvd_prime Nat.prime_two ] at hg3

