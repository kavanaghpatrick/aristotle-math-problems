      -- By the induction hypothesis, there exists $n$ such that $x' = Pell8_x n$ and $y' = Pell8_y n$.
      obtain ⟨n, hn⟩ : ∃ n : ℕ, x' = Pell8_x n ∧ y' = Pell8_y n := by
