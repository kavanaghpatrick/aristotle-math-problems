    -- 36(1) + 1 - 12(x_{k+1}x_k - 8y_{k+1}y_k) = 1
    -- 37 - 12(x_{k+1}x_k - 8y_{k+1}y_k) = 1
    -- 36 = 12(x_{k+1}x_k - 8y_{k+1}y_k)
    -- 3 = x_{k+1}x_k - 8y_{k+1}y_k
