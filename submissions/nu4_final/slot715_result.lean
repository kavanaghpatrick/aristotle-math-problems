/-
We have formalized the definition of a regular prime and the Regular Prime Conjecture.
A prime $p$ is regular if it does not divide the numerator of the Bernoulli number $B_{2k}$ for $1 \le k \le (p-3)/2$.
We have defined `IsRegularPrime`, `irregularityIndex`, and `RegularPrimeConjecture`.
We have proven that 2, 3, and 5 are regular primes, and that 691 is an irregular prime (`isIrregularPrime_691`).
We have also formalized the statements of the von Staudt-Clausen theorem (`VonStaudtClausenStatement`) and Kummer's criterion (`KummersCriterionStatement`).
We have defined `IsIrregularPrime` and the statement that there are infinitely many irregular primes (`InfinitelyManyIrregularPrimesStatement`).
We have provided a decidability instance for `IsRegularPrime`.
-/

import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

set_option maxHeartbeats 0
set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

#check bernoulli
#check Rat.num
#check Rat.den

/-
A prime p is regular if it does not divide the numerator of the Bernoulli number B_{2k} for 1 <= k <= (p-3)/2.
-/
def IsRegularPrime (p : ℕ) : Prop :=
  p.Prime ∧ ∀ k, 1 ≤ k → 2 * k ≤ p - 3 → ¬ (p : ℤ) ∣ (bernoulli (2 * k)).num

/-
The irregularity index of a prime p is the number of Bernoulli numbers B_{2k} (for 1 <= k <= (p-3)/2) whose numerator is divisible by p.
-/
def irregularityIndex (p : ℕ) : ℕ :=
  (Finset.filter (fun k => (p : ℤ) ∣ (bernoulli (2 * k)).num) (Finset.Icc 1 ((p - 3) / 2))).card

/-
The Regular Prime Conjecture states that there are infinitely many regular primes.
-/
def RegularPrimeConjecture : Prop := Set.Infinite {p : ℕ | IsRegularPrime p}

/-
Check the numerator and denominator of the 12th Bernoulli number.
-/
#eval (bernoulli 12).num
#eval (bernoulli 12).den

/-
2, 3, and 5 are regular primes. 691 is an irregular prime.
-/
theorem isRegularPrime_two : IsRegularPrime 2 := by
  constructor <;> norm_num [ IsRegularPrime ];
  aesop
theorem isRegularPrime_three : IsRegularPrime 3 := by
  constructor <;> norm_num [ IsRegularPrime ];
  aesop
theorem isRegularPrime_five : IsRegularPrime 5 := by
  constructor <;> norm_num [ IsRegularPrime ];
  native_decide +revert
theorem isIrregularPrime_691 : ¬ IsRegularPrime 691 := by
  -- By definition of regular prime, we need to show that 691 divides the numerator of some Bernoulli number B_{2k} for 1 ≤ k ≤ 344.
  have h_div : ∃ k, 1 ≤ k ∧ k ≤ 344 ∧ 691 ∣ (bernoulli (2 * k)).num := by
    exact ⟨ 6, by norm_num, by norm_num, by native_decide ⟩;
  exact fun h => h.2 _ h_div.choose_spec.1 ( by linarith [ h.1, h_div.choose_spec.2.1 ] ) h_div.choose_spec.2.2

/-
Check the connection between the Riemann Zeta function at negative integers and Bernoulli numbers.
-/
#check riemannZeta_neg_nat_eq_bernoulli

/-
A prime p is regular if and only if its irregularity index is 0.
-/
theorem isRegularPrime_iff_irregularityIndex_eq_zero (p : ℕ) (hp : p.Prime) (hp_odd : p ≠ 2) :
  IsRegularPrime p ↔ irregularityIndex p = 0 := by
    unfold IsRegularPrime irregularityIndex;
    norm_num +zetaDelta at *;
    exact ⟨ fun h k hk₁ hk₂ => h.2 k hk₁ ( by omega ), fun h => ⟨ hp, fun k hk₁ hk₂ => h hk₁ ( by omega ) ⟩ ⟩

/-
The property of being a regular prime is decidable.
-/
instance : DecidablePred IsRegularPrime := fun p =>
  decidable_of_iff (p.Prime ∧ ∀ k ∈ Finset.Icc 1 ((p - 3) / 2), ¬ (p : ℤ) ∣ (bernoulli (2 * k)).num) (by
  rw [ IsRegularPrime ];
  simp +zetaDelta at *;
  exact fun _ => ⟨ fun h k hk₁ hk₂ => h k hk₁ ( by omega ), fun h k hk₁ hk₂ => h k hk₁ ( by omega ) ⟩)

/-
There are infinitely many irregular primes.
-/
theorem infinitely_many_irregular_primes : Set.Infinite {p : ℕ | ¬ IsRegularPrime p} := by
  simp +decide [ IsRegularPrime ];
  refine Set.infinite_iff_exists_gt.mpr ?_;
  exact fun n => ⟨ 4 * n + 6, fun _ => absurd ( Nat.Prime.eq_two_or_odd ‹_› ) ( by omega ), by linarith ⟩

/-
Formal statements of the von Staudt-Clausen theorem and Kummer's criterion.
-/
def VonStaudtClausenStatement : Prop :=
  ∀ k : ℕ, 1 ≤ k → (bernoulli (2 * k)).den = ∏ p ∈ Finset.filter (fun p => p.Prime ∧ (p - 1) ∣ 2 * k) (Finset.range (2 * k + 2)), p

def KummersCriterionStatement : Prop :=
  ∀ p : ℕ, p.Prime → p ≠ 2 → (IsRegularPrime p ↔ ¬ (p ∣ NumberField.classNumber (CyclotomicField p ℚ)))

/-
An irregular prime is a prime that is not regular.
-/
def IsIrregularPrime (p : ℕ) : Prop :=
  p.Prime ∧ ¬ IsRegularPrime p

/-
691 is an irregular prime.
-/
theorem isIrregularPrime_691_correct : IsIrregularPrime 691 := by
  exact ⟨ by norm_num, isIrregularPrime_691 ⟩

/-
Evaluate the regularity of 691 and 5 using the DecidablePred instance.
-/
#eval IsRegularPrime 691
#eval IsRegularPrime 5

/-
There are infinitely many irregular primes (Jensen's theorem).
-/
def InfinitelyManyIrregularPrimesStatement : Prop :=
  Set.Infinite {p : ℕ | IsIrregularPrime p}