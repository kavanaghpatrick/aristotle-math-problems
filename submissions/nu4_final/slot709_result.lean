/-
Search procedure for the ceiling method.
-/
def search_ceiling_method (n : Nat) (limit : Nat) : Bool :=
  (List.range limit).any (fun j => check_ceiling_method n j)

lemma search_ceiling_method_correct (n limit : Nat) (hn : n >= 2) : search_ceiling_method n limit = true -> is_erdos_straus n := by
  intro h
  unfold search_ceiling_method at h
  obtain ⟨j, hj⟩ := List.any_eq_true.mp h
  exact check_ceiling_method_correct n j hn hj.right

/-
Verification of Erdos-Straus for a range of integers.
-/
def check_erdos_straus_range (limit : Nat) : Bool :=
  (List.range limit).all (fun n => if n < 2 then true else search_ceiling_method n 100)

lemma check_erdos_straus_range_correct (limit : Nat) : check_erdos_straus_range limit = true -> forall n, n < limit -> 2 <= n -> is_erdos_straus n := by
  intro h n hn hn';
  -- By definition of `check_erdos_straus_range`, if it returns true, then `search_ceiling_method n 100` must also be true.
  have h_search : search_ceiling_method n 100 = true := by
    unfold check_erdos_straus_range at h;
    grind;
  exact?

