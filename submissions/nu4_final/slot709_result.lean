/-
Formalization of the ceiling method strategy.
-/
def satisfies_ceiling_method (n j : Nat) : Prop :=
  let x := (n + 3) / 4 + j
  4 * x > n /\
  let A := 4 * x - n
  let B := n * x
  exists d, d ∣ B^2 /\ (d + B) % A = 0 /\ d ∣ B * ((d + B) / A)

lemma erdos_straus_of_ceiling_method (n j : Nat) (hn : n >= 2) : satisfies_ceiling_method n j -> is_erdos_straus n := by
  intro h;
  rcases h with ⟨ x, hx ⟩;
  obtain ⟨ d, hd₁, hd₂, hd₃ ⟩ := hx;
  convert erdos_straus_of_divisor n ( ( n + 3 ) / 4 + j ) d hn x hd₁ hd₂ hd₃ using 1

