-/
lemma erdos_straus_of_divisor (n x d : Nat) (hn : n >= 2) (hxn : 4 * x > n) (hd : d ∣ (n * x)^2) (hmod : (d + n * x) % (4 * x - n) = 0) (hz : d ∣ (n * x) * ((d + n * x) / (4 * x - n))) : is_erdos_straus n := by
