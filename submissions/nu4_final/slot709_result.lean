/-
The statement of the Erdos-Straus conjecture as a proposition.
-/
def ErdosStrausConjectureStatement : Prop :=
  forall n, 2 <= n -> is_erdos_straus n

/-
Reduction of the Erdos-Straus conjecture to the case n = 1 mod 24.
-/
lemma erdos_straus_reduction : (forall n, n % 24 = 1 -> is_erdos_straus n) -> (forall n, 2 <= n -> is_erdos_straus n) := by
  intro h;
  -- By the provided solution, we can reduce the problem to checking primes. Hence, we can consider the cases where n is 1 mod 24.
  have h_cases : ∀ n, 2 ≤ n → (n % 2 = 0 ∨ n % 4 = 3 ∨ n % 8 = 5 ∨ n % 12 = 5 ∨ n % 20 = 17 ∨ n % 3 = 2 ∨ n % 24 = 1) → is_erdos_straus n := by
    intro n hn h_cases
    obtain h_even | h_mod4 | h_mod8 | h_mod12 | h_mod20 | h_mod3 | h_mod24 := h_cases;
    exact?;
    exact?;
    · exact?;
    · exact?;
    · exact is_erdos_straus_mod_20_17 n h_mod20;
    · exact?;
    · exact h n h_mod24;
  -- By the pigeonhole principle, for any $n \geq 2$, one of the cases in $h_cases$ must hold.
  intros n hn
  by_contra h_contra;
  -- If n is divisible by 3, then we can write n as 3k for some integer k.
  obtain ⟨k, rfl⟩ : ∃ k, n = 3 * k := by
    by_cases h3 : n % 3 = 0;
    · exact Nat.dvd_of_mod_eq_zero h3;
    · exact False.elim <| h_contra <| h_cases n hn <| by omega;
  exact h_contra <| is_erdos_straus_mul_right 3 k ( by linarith ) ( by exact is_erdos_straus_three )

/-
Computable verification of the ceiling method.
-/
def check_ceiling_method (n j : Nat) : Bool :=
  let x := (n + 3) / 4 + j
  if 4 * x <= n then false else
  let A := 4 * x - n
  let B := n * x
  let d_candidates := (Nat.divisors (B^2)).filter (fun d => (d + B) % A == 0 && (B * ((d + B) / A)) % d == 0)
  d_candidates.card != 0

lemma check_ceiling_method_correct (n j : Nat) (hn : n >= 2) : check_ceiling_method n j = true -> is_erdos_straus n := by
  unfold check_ceiling_method;
  simp +zetaDelta at *;
  intro h1 x hx1 hx2 hx3 hx4 hx5; apply_rules [ erdos_straus_of_divisor ] ;
  exact Nat.dvd_of_mod_eq_zero hx5

