/-
Definition of the Erdos-Straus property: 4/n = 1/x + 1/y + 1/z.
-/
def is_erdos_straus (n : Nat) :=
  exists x y z : Nat, 0 < x /\ 0 < y /\ 0 < z /\
    4 * x * y * z = n * (y * z + x * z + x * y)

/-
If n satisfies the Erdos-Straus property, then any multiple n*k (for k > 0) also satisfies it.
-/
lemma is_erdos_straus_mul_right (n k : Nat) (hk : k > 0) : is_erdos_straus n -> is_erdos_straus (n * k) := by
  rintro ⟨ x, y, z, hx, hy, hz, h ⟩;
  use x * k, y * k, z * k;
  exact ⟨ mul_pos hx hk, mul_pos hy hk, mul_pos hz hk, by nlinarith [ pow_pos hk 3 ] ⟩

/-
Reduction to primes: if the Erdos-Straus conjecture holds for all primes, it holds for all integers n >= 2.
-/
lemma erdos_straus_of_primes : (forall p, Nat.Prime p -> is_erdos_straus p) -> (forall n, 2 <= n -> is_erdos_straus n) := by
  -- By the hypothesis, the property holds for all primes.
  intro h
  intro n hn
  obtain ⟨p, hp⟩ : ∃ p : ℕ, Nat.Prime p ∧ p ∣ n := by
    exact Nat.exists_prime_and_dvd ( by linarith );
  obtain ⟨ k, rfl ⟩ := hp.2; exact is_erdos_straus_mul_right p k ( Nat.pos_of_ne_zero ( by aesop_cat ) ) ( h p hp.1 ) ;

/-
Base case p=2 for Erdos-Straus.
-/
lemma is_erdos_straus_two : is_erdos_straus 2 := by
  -- Let's choose $x = 1$, $y = 2$, and $z = 2$.
  use 1, 2, 2
  norm_num

/-
