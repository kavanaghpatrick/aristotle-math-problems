#!/usr/bin/env bash
# mk — Math-forge Knowledge Base CLI
# Usage: mk <command> [args...]

set -uo pipefail

# Resolve symlinks to find the real script location
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# 3-level DB path resolution
if [ -n "${MATH_FORGE_DB:-}" ]; then
    DB="$MATH_FORGE_DB"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    DB="${CLAUDE_PLUGIN_ROOT}/data/knowledge.db"
else
    DB="${SCRIPT_DIR}/../data/knowledge.db"
fi

# Also need tracking.db for cross-queries
if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
    TRACKING_DB="${CLAUDE_PROJECT_DIR}/submissions/tracking.db"
else
    TRACKING_DB="${SCRIPT_DIR}/../../submissions/tracking.db"
fi

# Color support (TTY-aware)
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[0;33m'
    CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'
else
    GREEN=''; RED=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

escape_sql() {
    printf '%s' "$1" | sed "s/'/''/g"
}

run_sql() {
    local db="$1"; shift
    local output
    output=$(sqlite3 "$db" "$@" 2>&1)
    local rc=$?
    if [ $rc -ne 0 ]; then
        echo "[math-forge] ERROR: sqlite3 failed: $output" >&2
        return $rc
    fi
    [ -n "$output" ] && printf '%s\n' "$output"
    return 0
}

# Normalize problem ID: strip spaces, underscores, lowercase
normalize_problem() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[ _-]//g'
}

# Check DB exists
check_db() {
    if [ ! -f "$DB" ]; then
        echo "[math-forge] ERROR: knowledge.db not found at $DB" >&2
        echo "Run: math-forge/scripts/bootstrap.sh or mk init" >&2
        return 1
    fi
}

SCHEMA_PATH="${SCRIPT_DIR}/../data/schema.sql"

case "${1:-help}" in
    search)
        shift
        check_db || exit 1
        if [ $# -eq 0 ]; then
            echo "Usage: mk search <query> [--limit N] [--domain D]"
            exit 1
        fi
        # Parse args
        QUERY=""
        LIMIT=5
        DOMAIN=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --limit) LIMIT="$2"; shift 2 ;;
                --domain) DOMAIN="$2"; shift 2 ;;
                *) QUERY="$QUERY $1"; shift ;;
            esac
        done
        QUERY=$(echo "$QUERY" | sed 's/^ //')
        ESCAPED_Q=$(escape_sql "$QUERY")

        DOMAIN_FILTER=""
        if [ -n "$DOMAIN" ]; then
            ESCAPED_D=$(escape_sql "$DOMAIN")
            DOMAIN_FILTER="AND f.domain_id = '${ESCAPED_D}'"
        fi

        RESULT=$(run_sql "$DB" -header -separator '|' "
            SELECT f.id,
                   CASE f.finding_type
                       WHEN 'theorem' THEN '[PROVEN]'
                       WHEN 'technique' THEN '[TECHNIQUE]'
                       WHEN 'failure' THEN '[FAILED]'
                       WHEN 'false_lemma' THEN '[FALSE]'
                       WHEN 'computation' THEN '[COMPUTED]'
                       WHEN 'insight' THEN '[INSIGHT]'
                       ELSE '[' || UPPER(f.finding_type) || ']'
                   END as badge,
                   f.title,
                   COALESCE(f.proof_technique, SUBSTR(f.description, 1, 120)) as detail,
                   'Domain: ' || COALESCE(f.domain_id, '?') || ' | Slot: ' || COALESCE(f.source_slot, '?') as meta
            FROM findings_fts fts
            JOIN findings f ON f.id = fts.rowid
            WHERE findings_fts MATCH '{title description theorem_statement proof_technique tags why_failed}:${ESCAPED_Q}'
            ${DOMAIN_FILTER}
            ORDER BY bm25(findings_fts, 10.0, 5.0, 1.0, 5.0, 3.0, 2.0, 3.0)
            LIMIT ${LIMIT};
        ")

        if [ -z "$RESULT" ] || [ "$RESULT" = "id|badge|title|detail|meta" ]; then
            echo "[math-forge] No findings matching '${QUERY}'"
            echo "  Try broader terms or run: mk stats"
        else
            echo "[math-forge] Search: '${QUERY}' (top ${LIMIT})"
            echo "---"
            # Skip header, format each row
            echo "$RESULT" | tail -n +2 | while IFS='|' read -r id badge title detail meta; do
                printf "  #%-3s %-12s %s\n" "$id" "$badge" "$title"
                printf "       %s\n" "$detail"
                printf "       %s\n" "$meta"
            done
            TOTAL=$(run_sql "$DB" "SELECT COUNT(*) FROM findings_fts WHERE findings_fts MATCH '{title description theorem_statement proof_technique tags why_failed}:${ESCAPED_Q}';")
            if [ "${TOTAL:-0}" -gt "$LIMIT" ]; then
                echo "---"
                echo "  Showing ${LIMIT} of ${TOTAL} results. Use --limit N for more."
            fi
        fi
        ;;

    find)
        shift
        check_db || exit 1
        if [ $# -eq 0 ]; then
            echo "Usage: mk find <problem-id>"
            exit 1
        fi
        PROBLEM=$(escape_sql "$1")

        echo "[math-forge] Problem: ${1}"
        echo "==="

        # Problem summary
        SUMMARY=$(run_sql "$DB" -header -column "SELECT id, name, domain_id, status, submission_count, proven_count, failed_count FROM problems WHERE id LIKE '%${PROBLEM}%' LIMIT 1;")
        if [ -n "$SUMMARY" ]; then
            echo "$SUMMARY"
        else
            echo "  (No problem record found — showing findings only)"
        fi
        echo ""

        # Findings grouped by type
        echo "--- Findings ---"
        run_sql "$DB" -header -column "
            SELECT finding_type as type, title, COALESCE(CAST(source_slot AS TEXT), '') as slot, confidence
            FROM findings WHERE problem_id LIKE '%${PROBLEM}%'
            ORDER BY finding_type, created_at DESC;
        "

        echo ""
        echo "--- Strategies ---"
        run_sql "$DB" -header -column "
            SELECT approach_name, outcome, attempts, COALESCE(CAST(submission_slot AS TEXT), '') as slot, learned
            FROM strategies WHERE problem_id LIKE '%${PROBLEM}%'
            ORDER BY outcome, last_attempted DESC;
        "

        # Cross-DB: false_lemmas from tracking.db
        if [ -f "$TRACKING_DB" ]; then
            echo ""
            echo "--- False Lemmas (tracking.db) ---"
            run_sql "$TRACKING_DB" -header -column "
                SELECT lemma_name, why_false, counterexample
                FROM false_lemmas
                WHERE lemma_name LIKE '%${PROBLEM}%' OR impact LIKE '%${PROBLEM}%';
            "
        fi
        ;;

    strategies)
        shift
        check_db || exit 1
        DOMAIN_FILTER=""
        if [ $# -gt 0 ]; then
            ESCAPED_D=$(escape_sql "$1")
            DOMAIN_FILTER="AND domain_id = '${ESCAPED_D}'"
        fi
        echo "[math-forge] Proven techniques"
        echo "---"
        run_sql "$DB" -header -column "
            SELECT proof_technique, COUNT(*) as cnt,
                   GROUP_CONCAT(DISTINCT source_slot) as slots,
                   domain_id
            FROM findings
            WHERE finding_type = 'theorem' AND confidence = 'verified'
              AND proof_technique IS NOT NULL
              ${DOMAIN_FILTER}
            GROUP BY proof_technique, domain_id
            ORDER BY cnt DESC;
        "
        ;;

    failed)
        shift
        check_db || exit 1
        KEYWORD=""
        if [ $# -gt 0 ]; then
            KEYWORD=$(escape_sql "$1")
        fi

        echo "[math-forge] Failed approaches"
        echo "---"

        if [ -n "$KEYWORD" ]; then
            run_sql "$DB" -header -column "
                SELECT title, why_failed, avoid_pattern, COALESCE(CAST(source_slot AS TEXT), '') as slot, problem_id
                FROM findings
                WHERE finding_type IN ('failure', 'false_lemma')
                  AND (title LIKE '%${KEYWORD}%' OR why_failed LIKE '%${KEYWORD}%' OR problem_id LIKE '%${KEYWORD}%')
                ORDER BY created_at DESC;
            "
        else
            run_sql "$DB" -header -column "
                SELECT title, why_failed, avoid_pattern, COALESCE(CAST(source_slot AS TEXT), '') as slot, problem_id
                FROM findings
                WHERE finding_type IN ('failure', 'false_lemma')
                ORDER BY created_at DESC;
            "
        fi

        echo ""
        printf "${YELLOW}WARNING: Do NOT repeat approaches listed above without a fundamentally new angle.${RESET}\n"
        ;;

    stats)
        check_db || exit 1
        echo "[math-forge] Knowledge Base Dashboard"
        echo "==="

        # Finding counts by type
        echo "Findings by type:"
        run_sql "$DB" "SELECT '  ' || finding_type || ': ' || COUNT(*) FROM findings GROUP BY finding_type ORDER BY COUNT(*) DESC;"

        echo ""
        echo "Findings by domain:"
        run_sql "$DB" "SELECT '  ' || COALESCE(domain_id, 'unknown') || ': ' || COUNT(*) FROM findings GROUP BY domain_id ORDER BY COUNT(*) DESC;"

        TOTAL=$(run_sql "$DB" "SELECT COUNT(*) FROM findings;")
        NEWEST=$(run_sql "$DB" "SELECT MAX(created_at) FROM findings;")
        echo ""
        echo "Total findings: ${TOTAL:-0}"
        echo "Latest: ${NEWEST:-never}"

        # Strategy outcomes
        STRAT_COUNT=$(run_sql "$DB" "SELECT COUNT(*) FROM strategies;")
        if [ "${STRAT_COUNT:-0}" -gt 0 ]; then
            echo ""
            echo "Strategy outcomes:"
            run_sql "$DB" "SELECT '  ' || outcome || ': ' || COUNT(*) FROM strategies GROUP BY outcome ORDER BY COUNT(*) DESC;"
        fi

        # Problem count
        PROB_COUNT=$(run_sql "$DB" "SELECT COUNT(*) FROM problems;")
        echo ""
        echo "Problems tracked: ${PROB_COUNT:-0}"
        ;;

    init)
        if [ -f "$DB" ]; then
            echo "[math-forge] knowledge.db already exists at $DB"
        else
            if [ -f "$SCHEMA_PATH" ]; then
                sqlite3 "$DB" < "$SCHEMA_PATH"
                echo "[math-forge] Created knowledge.db"
            else
                echo "[math-forge] ERROR: schema.sql not found at $SCHEMA_PATH" >&2
                exit 1
            fi
        fi
        # Run migration if tracking.db exists
        MIGRATE_SCRIPT="${SCRIPT_DIR}/migrate_tracking.py"
        if [ -f "$MIGRATE_SCRIPT" ] && [ -f "$TRACKING_DB" ]; then
            echo "[math-forge] Running migration from tracking.db..."
            python3 "$MIGRATE_SCRIPT" --tracking-db "$TRACKING_DB" --knowledge-db "$DB"
        fi
        ;;

    submit)
        shift
        if [ $# -eq 0 ]; then
            echo "Usage: mk submit <file> [--yes] [--bare-only] [other safe_aristotle_submit.py args...]"
            echo ""
            echo "  Convenience wrapper around safe_aristotle_submit.py with"
            echo "  upfront lane detection (U1, 2026-05-30):"
            echo ""
            echo "    <stem>.fusion.json present  -> 'Will use FUSION lane'"
            echo "    <stem>.closure.json present -> 'Will use BARE lane (+ recommendation)'"
            echo "    no companion file           -> 'Will use BARE lane'"
            echo ""
            echo "  Flags:"
            echo "    --yes        Skip the interactive confirmation prompt."
            echo "    --bare-only  Force BARE lane even if a .fusion.json exists."
            echo "                 Logs BARE_OVERRIDE for audit."
            echo "    (all other flags are passed through to safe_aristotle_submit.py)"
            exit 1
        fi
        SUBMIT_SCRIPT="${SCRIPT_DIR}/../../scripts/safe_aristotle_submit.py"
        if [ ! -f "$SUBMIT_SCRIPT" ]; then
            echo "[math-forge] ERROR: safe_aristotle_submit.py not found at $SUBMIT_SCRIPT" >&2
            exit 1
        fi

        # Parse args: first non-flag arg is the sketch file. --yes is consumed
        # locally; --bare-only is consumed locally for the pre-check banner
        # and ALSO passed through.
        SKETCH_FILE=""
        YES_FLAG="no"
        BARE_ONLY="no"
        FUSION_FLAG="no"
        REMAINING_ARGS=()
        for arg in "$@"; do
            case "$arg" in
                --yes|-y) YES_FLAG="yes" ;;
                --bare-only)
                    BARE_ONLY="yes"
                    REMAINING_ARGS+=("$arg")
                    ;;
                --fusion-lane)
                    FUSION_FLAG="yes"
                    REMAINING_ARGS+=("$arg")
                    ;;
                --*) REMAINING_ARGS+=("$arg") ;;
                *)
                    if [ -z "$SKETCH_FILE" ]; then
                        SKETCH_FILE="$arg"
                    fi
                    REMAINING_ARGS+=("$arg")
                    ;;
            esac
        done

        if [ -z "$SKETCH_FILE" ]; then
            echo "${RED}[mk submit] ERROR: no sketch file in arguments.${RESET}" >&2
            echo "Usage: mk submit <file> [--yes] [--bare-only] [args...]" >&2
            exit 1
        fi

        if [ ! -f "$SKETCH_FILE" ]; then
            echo "${RED}[mk submit] ERROR: sketch file not found: $SKETCH_FILE${RESET}" >&2
            exit 1
        fi

        # Pre-check companion files. Strip the suffix and look for siblings.
        # Use Bash parameter expansion to drop the last extension.
        SKETCH_STEM="${SKETCH_FILE%.*}"
        FUSION_COMPANION="${SKETCH_STEM}.fusion.json"
        CLOSURE_COMPANION="${SKETCH_STEM}.closure.json"

        echo "${BOLD}${CYAN}[mk submit] Lane pre-check${RESET}"
        echo "  Sketch:   $SKETCH_FILE"
        echo "  Fusion companion:  $([ -f "$FUSION_COMPANION" ] && echo "FOUND ($FUSION_COMPANION)" || echo "absent")"
        echo "  Closure companion: $([ -f "$CLOSURE_COMPANION" ] && echo "FOUND ($CLOSURE_COMPANION)" || echo "absent")"

        if [ "$BARE_ONLY" = "yes" ]; then
            LANE_BANNER="${YELLOW}Will use BARE lane (forced by --bare-only)${RESET}"
        elif [ "$FUSION_FLAG" = "yes" ]; then
            LANE_BANNER="${GREEN}Will use FUSION lane (explicit --fusion-lane)${RESET}"
        elif [ -f "$FUSION_COMPANION" ]; then
            LANE_BANNER="${GREEN}Will use FUSION lane (auto-detected via .fusion.json)${RESET}"
        elif [ -f "$CLOSURE_COMPANION" ]; then
            LANE_BANNER="${YELLOW}Will use BARE lane (closure-only companion — recommendation may follow)${RESET}"
        else
            LANE_BANNER="${YELLOW}Will use BARE lane (no companion file)${RESET}"
        fi
        echo "  -> $LANE_BANNER"
        echo ""

        # Interactive confirmation unless --yes
        if [ "$YES_FLAG" != "yes" ]; then
            if [ -t 0 ] && [ -t 1 ]; then
                read -p "Proceed with submission? [y/N] " confirm
                if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && [ "$confirm" != "yes" ]; then
                    echo "${YELLOW}[mk submit] Aborted by user.${RESET}"
                    exit 0
                fi
            else
                # Non-interactive without --yes: refuse to submit silently.
                echo "${RED}[mk submit] ERROR: non-interactive session without --yes. Aborting.${RESET}" >&2
                echo "  Re-run with --yes to confirm submission, or invoke in a TTY." >&2
                exit 2
            fi
        fi

        python3 "$SUBMIT_SCRIPT" "${REMAINING_ARGS[@]}"
        ;;

    status)
        shift
        FETCH_SCRIPT="${SCRIPT_DIR}/../../scripts/aristotle_fetch.py"
        if [ ! -f "$FETCH_SCRIPT" ]; then
            echo "[math-forge] ERROR: aristotle_fetch.py not found at $FETCH_SCRIPT" >&2
            exit 1
        fi
        python3 "$FETCH_SCRIPT" status "$@"
        ;;

    partials)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found at $TRACKING_DB" >&2
            exit 1
        fi
        # Canonical status enum (2026-05-28): partials live in 'compiled_partial'.
        # 'near_miss'/'completed' were legacy buckets that collapsed into
        # compiled_partial (sorry>=1) or compiled_no_advance (sorry=0).
        echo "[math-forge] Near-miss submissions (sorry=1)"
        echo "---"
        run_sql "$TRACKING_DB" -header -column "
            SELECT filename, sorry_count, proven_count, notes, completed_at
            FROM submissions
            WHERE sorry_count = 1 AND status = 'compiled_partial'
            ORDER BY completed_at DESC;
        "
        ;;

    resubmittable)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found at $TRACKING_DB" >&2
            exit 1
        fi
        # Canonical status enum (2026-05-28): a resubmittable row has an
        # artifact (output_file) and modest sorry count. 'compile_failed' may
        # also be resubmittable if Aristotle couldn't load the file.
        echo "[math-forge] Resubmittable submissions"
        echo "---"
        run_sql "$TRACKING_DB" -header -column "
            SELECT filename, status, sorry_count, proven_count,
                   COALESCE(output_file, '') as output,
                   COALESCE(SUBSTR(notes, 1, 80), '') as notes
            FROM submissions
            WHERE status IN ('compiled_partial', 'compile_failed')
              AND sorry_count >= 1
              AND sorry_count <= 3
              AND output_file IS NOT NULL
            ORDER BY sorry_count ASC, completed_at DESC;
        "
        ;;

    query)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found at $TRACKING_DB" >&2
            exit 1
        fi
        if [ $# -eq 0 ]; then
            echo "Usage: mk query <sql>"
            echo "  Runs read-only SQL against tracking.db."
            echo "  Example: mk query \"SELECT COUNT(*) FROM submissions WHERE status='compiled_no_advance'\""
            exit 1
        fi
        SQL="$1"
        # Safety: reject non-SELECT statements
        UPPER_SQL=$(echo "$SQL" | tr '[:lower:]' '[:upper:]' | sed 's/^[[:space:]]*//')
        case "$UPPER_SQL" in
            SELECT*|WITH*|EXPLAIN*|PRAGMA*)
                run_sql "$TRACKING_DB" -header -column "$SQL"
                ;;
            *)
                echo "[math-forge] ERROR: mk query only allows SELECT/WITH/EXPLAIN/PRAGMA statements." >&2
                echo "  For writes, use sqlite3 directly." >&2
                exit 1
                ;;
        esac
        ;;

    context)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found at $TRACKING_DB" >&2
            exit 1
        fi
        if [ $# -eq 0 ]; then
            echo "Usage: mk context <problem-id>"
            echo "  Lists prior Aristotle result files for passing as context."
            exit 1
        fi
        PROBLEM=$(escape_sql "$1")

        echo "[math-forge] Context files for '${1}':"
        echo "---"

        # Canonical status enum (2026-05-28): include any row with an
        # artifact that isn't 'compile_failed' and wasn't explicitly marked
        # invalid (verified=0). This mirrors gather_context() in
        # safe_aristotle_submit.py — gate on artifact presence, not status,
        # so future status renames don't silently kill auto-context.
        RESULTS=$(run_sql "$TRACKING_DB" "
            SELECT output_file, status, proven_count
            FROM submissions
            WHERE (problem_id LIKE '%${PROBLEM}%'
                   OR filename LIKE '%${PROBLEM}%')
              AND output_file IS NOT NULL
              AND output_file != ''
              AND status != 'compile_failed'
              AND (verified IS NULL OR verified != 0)
            ORDER BY submitted_at DESC;
        ")

        if [ -z "$RESULTS" ]; then
            echo "  (No prior results found)"
            echo ""
            echo "This is the first submission for this problem."
        else
            CONTEXT_ARGS=""
            while IFS='|' read -r filepath status proven; do
                if [ -f "$filepath" ]; then
                    LINES=$(wc -l < "$filepath" | tr -d ' ')
                    printf "  %s (%s, %s lines)\n" "$filepath" "$status" "$LINES"
                    CONTEXT_ARGS="${CONTEXT_ARGS} --context ${filepath}"
                else
                    printf "  %s (MISSING — file not found)\n" "$filepath"
                fi
            done <<< "$RESULTS"
            echo "---"
            echo "Submit with:${CONTEXT_ARGS}"
        fi
        ;;

    gaps)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found at $TRACKING_DB" >&2
            exit 1
        fi

        echo "[math-forge] Open Gaps Being Targeted"
        echo "==="

        # Canonical status enum (2026-05-28). 'best_status' ranks rows by
        # how close to gap resolution they came: compiled_advance >
        # compiled_no_advance > compiled_partial > disproven > compile_failed
        # > submitted. SQLite MAX over a CASE-mapped numeric column gives
        # the ordering; we map back to the label for display.
        run_sql "$TRACKING_DB" -header -column "
            SELECT
                COALESCE(problem_id, filename) as problem,
                COALESCE(gap_statement, SUBSTR(notes, 1, 60)) as gap,
                COUNT(*) as subs,
                CASE MAX(CASE status
                            WHEN 'compiled_advance' THEN 6
                            WHEN 'compiled_no_advance' THEN 5
                            WHEN 'compiled_partial' THEN 4
                            WHEN 'disproven' THEN 3
                            WHEN 'compile_failed' THEN 2
                            WHEN 'submitted' THEN 1
                            ELSE 0 END)
                    WHEN 6 THEN 'compiled_advance'
                    WHEN 5 THEN 'compiled_no_advance'
                    WHEN 4 THEN 'compiled_partial'
                    WHEN 3 THEN 'disproven'
                    WHEN 2 THEN 'compile_failed'
                    WHEN 1 THEN 'submitted'
                    ELSE '?' END as best_status,
                MAX(CASE WHEN target_resolved = 1 THEN 'YES' ELSE '' END) as resolved
            FROM submissions
            WHERE submission_type = 'gap_targeting'
               OR submission_type IS NULL
            GROUP BY COALESCE(problem_id, filename)
            HAVING COUNT(*) > 0
            ORDER BY subs DESC
            LIMIT 30;
        "

        RESOLVED=$(run_sql "$TRACKING_DB" "
            SELECT COUNT(DISTINCT COALESCE(problem_id, filename))
            FROM submissions WHERE target_resolved = 1;
        ")
        echo ""
        echo "Gaps resolved: ${RESOLVED:-0}"
        ;;

    codex)
        shift
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found" >&2; exit 1
        fi
        PROBLEM="${1:-}"
        if [ -z "$PROBLEM" ]; then
            echo "[math-forge] Codex proof history (all)"; echo "---"
            run_sql "$TRACKING_DB" -header -column "
                SELECT problem_id, iterations, sorry_count,
                       CASE compiled WHEN 1 THEN 'YES' ELSE 'no' END as compiled,
                       model, wall_time_seconds as secs, created_at
                FROM codex_proofs ORDER BY created_at DESC LIMIT 20;"
        else
            ESCAPED=$(escape_sql "$PROBLEM")
            echo "[math-forge] Codex proofs for '${PROBLEM}'"; echo "---"
            run_sql "$TRACKING_DB" -header -column "
                SELECT id, iterations, sorry_count,
                       CASE compiled WHEN 1 THEN 'YES' ELSE 'no' END as compiled,
                       reasoning_effort, wall_time_seconds as secs, lean_file, created_at
                FROM codex_proofs WHERE problem_id LIKE '%${ESCAPED}%'
                ORDER BY created_at DESC;"
        fi
        ;;

    codex-best)
        shift
        if [ $# -eq 0 ]; then echo "Usage: mk codex-best <problem-id>"; exit 1; fi
        if [ ! -f "$TRACKING_DB" ]; then
            echo "[math-forge] ERROR: tracking.db not found" >&2; exit 1
        fi
        ESCAPED=$(escape_sql "$1")
        BEST=$(run_sql "$TRACKING_DB" "SELECT lean_file FROM codex_proofs WHERE problem_id LIKE '%${ESCAPED}%' AND compiled=1 ORDER BY sorry_count ASC, created_at DESC LIMIT 1;")
        if [ -n "$BEST" ]; then
            echo "$BEST"
        else
            echo "[math-forge] No compiled Codex proof for '${1}'" >&2; exit 1
        fi
        ;;

    debate)
        shift
        # Convenience wrapper: mk debate <problem-id> <template> [--rounds N] [--models grok,gemini,codex]
        # Delegates to scripts/debate_fusion.py for cross-domain technique scouting.
        DEBATE_FUSION="${SCRIPT_DIR}/../../scripts/debate_fusion.py"
        if [ ! -f "$DEBATE_FUSION" ]; then
            echo "[math-forge] ERROR: debate_fusion.py not found at $DEBATE_FUSION" >&2
            exit 1
        fi
        if [ $# -lt 2 ]; then
            echo "Usage: mk debate <problem-id> <template> [--rounds N] [--models M1,M2,M3]"
            echo ""
            echo "Available templates:"
            echo "  technique_scout       — 5 cross-domain techniques per AI per round"
            echo "  adjacent_analog       — 3-5 structurally isomorphic closed problems"
            echo "  tao_simulator         — Tao's first 3 moves (roleplay)"
            echo "  bias_flush            — adversarial critique of our default toolkit"
            echo "  bridge_lemma          — factor the problem via a single bridge lemma"
            echo "  obstruction_diagnosis — why has the problem resisted attack?"
            echo ""
            echo "Examples:"
            echo "  mk debate erdos_938 technique_scout"
            echo "  mk debate erdos_938 bridge_lemma --rounds 2"
            echo "  mk debate erdos_938 bias_flush --models gemini,codex"
            exit 1
        fi
        PROBLEM_ID="$1"; shift
        TEMPLATE="$1"; shift
        python3 "$DEBATE_FUSION" "$PROBLEM_ID" --template "$TEMPLATE" "$@"
        ;;

    fusion)
        shift
        if [ $# -eq 0 ]; then
            echo "Usage: mk fusion <problem-id> [--force] [--max-papers N] [--keywords \"a,b,c\"]"
            echo "Runs Stages 1-3 of the research-fusion pipeline (I6/I8 design):"
            echo "  Stage 1: arXiv literature breadth + erdosproblems.com excerpt"
            echo "  Stage 2: 3-AI analogy mining (Grok+Gemini+Codex parallel debate)"
            echo "  Stage 3: Codex technique-transfer cards w/ fit_score"
            echo ""
            echo "Outputs:    research_fusion/runs/<problem-id>/{01..03}_*.md / .json"
            echo "Aggregated: research_fusion/runs/<problem-id>/fusion_candidate.json"
            exit 1
        fi
        PROBLEM_ID="$1"; shift
        # Locate project root (one level up from math-forge/).
        if [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
            PROJECT_ROOT="$CLAUDE_PROJECT_DIR"
        else
            PROJECT_ROOT="${SCRIPT_DIR}/../.."
        fi
        # Pass-through flags.
        FORCE=""
        MAX_PAPERS=""
        KEYWORDS_FLAG=""
        KEYWORDS_VAL=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --force) FORCE="--force"; shift ;;
                --max-papers) MAX_PAPERS="$2"; shift 2 ;;
                --keywords) KEYWORDS_FLAG="--keywords"; KEYWORDS_VAL="$2"; shift 2 ;;
                *) echo "[math-forge] unknown flag: $1"; exit 1 ;;
            esac
        done
        echo -e "${CYAN}${BOLD}[mk fusion]${RESET} running Stages 1-3 for ${BOLD}${PROBLEM_ID}${RESET}"
        echo -e "${CYAN}---${RESET}"
        echo -e "${CYAN}[stage 1]${RESET} literature breadth (arXiv + erdosproblems.com)"
        STAGE1_ARGS=(--problem-id "$PROBLEM_ID")
        [ -n "$FORCE" ] && STAGE1_ARGS+=("$FORCE")
        [ -n "$MAX_PAPERS" ] && STAGE1_ARGS+=(--max-papers "$MAX_PAPERS")
        [ -n "$KEYWORDS_FLAG" ] && STAGE1_ARGS+=("$KEYWORDS_FLAG" "$KEYWORDS_VAL")
        (cd "$PROJECT_ROOT" && python3 -m research_fusion.stage1_literature "${STAGE1_ARGS[@]}") \
            || { echo -e "${RED}[mk fusion] Stage 1 failed${RESET}"; exit 1; }
        echo -e "${CYAN}[stage 2]${RESET} analogy mining (Grok+Gemini+Codex parallel debate)"
        STAGE2_ARGS=(--problem-id "$PROBLEM_ID")
        [ -n "$FORCE" ] && STAGE2_ARGS+=("$FORCE")
        (cd "$PROJECT_ROOT" && python3 -m research_fusion.stage2_analogy "${STAGE2_ARGS[@]}") \
            || { echo -e "${RED}[mk fusion] Stage 2 failed${RESET}"; exit 1; }
        echo -e "${CYAN}[stage 3]${RESET} technique transfer (Codex deep-think cards)"
        STAGE3_ARGS=(--problem-id "$PROBLEM_ID")
        [ -n "$FORCE" ] && STAGE3_ARGS+=("$FORCE")
        (cd "$PROJECT_ROOT" && python3 -m research_fusion.stage3_techniques "${STAGE3_ARGS[@]}") \
            || { echo -e "${RED}[mk fusion] Stage 3 failed${RESET}"; exit 1; }
        echo ""
        echo -e "${GREEN}${BOLD}[mk fusion] DONE${RESET}"
        echo "Dossier directory: ${PROJECT_ROOT}/research_fusion/runs/${PROBLEM_ID}/"
        echo ""
        FC="${PROJECT_ROOT}/research_fusion/runs/${PROBLEM_ID}/fusion_candidate.json"
        if [ -f "$FC" ]; then
            python3 - "$FC" <<'PYEOF'
import json, sys
fc = json.load(open(sys.argv[1]))
print(f"problem_id:    {fc['problem_id']}")
print(f"generated_at:  {fc['generated_at']}")
print(f"papers:        {fc['literature']['paper_count']} across {len(fc['literature']['domains_covered'])} domains")
print(f"analogs (top): {len(fc['analogies']['top_analogs'])}")
for a in fc['analogies']['top_analogs'][:3]:
    print(f"  - {a['analog_id']}: {a['analog_problem']} [{a['analog_domain']}] tech={a['named_technique']}")
print(f"technique cards: {len(fc['technique_cards'])}")
for c in fc['technique_cards']:
    print(f"  - rank{c.get('rank','?')}: {c['name']} fit={c.get('fit_score',0):.3f} (analog {c.get('source_analog_id','?')})")
PYEOF
        else
            echo "[math-forge] WARNING: fusion_candidate.json not found at $FC"
        fi
        ;;

    help|*)
        echo "mk — Math-forge Knowledge Base CLI"
        echo ""
        echo "Knowledge commands:"
        echo "  search <query> [--limit N] [--domain D]  Search findings (FTS5 + BM25)"
        echo "  find <problem-id>                         Problem-level knowledge report"
        echo "  strategies [domain]                       Proven techniques by frequency"
        echo "  failed [keyword]                          Failed approaches (don't repeat these!)"
        echo "  stats                                     KB dashboard"
        echo "  init                                      Initialize/bootstrap knowledge.db"
        echo ""
        echo "Codex commands:"
        echo "  codex [problem-id]                        Codex proof history (all or by problem)"
        echo "  codex-best <problem-id>                   Best compiled Codex proof path"
        echo ""
        echo "Research-fusion commands:"
        echo "  fusion <problem-id> [--force]             Run Stages 1-3 (lit/analogy/technique)"
        echo "  debate <problem-id> <template>            Run a templated 3-AI debate"
        echo ""
        echo "Pipeline commands:"
        echo "  submit <file> [args...]                   Submit sketch to Aristotle"
        echo "  status [uuid-or-slot]                     Aristotle queue status"
        echo "  context <problem-id>                      Prior Aristotle results for auto-context"
        echo "  gaps                                       Open gaps being targeted + status"
        echo "  partials                                   Near-miss submissions (sorry=1)"
        echo "  resubmittable                              Resubmission candidates"
        echo "  query <sql>                                Read-only SQL on tracking.db"
        echo ""
        echo "Cross-domain debate commands:"
        echo "  debate <problem-id> <template>            Run a cross-domain technique-scouting debate"
        echo "    Templates: technique_scout, adjacent_analog, tao_simulator,"
        echo "               bias_flush, bridge_lemma, obstruction_diagnosis"
        echo ""
        echo "  help                                      Show this help"
        echo ""
        echo "Examples:"
        echo "  mk search \"cubic residue\"                 Find findings about cubic residues"
        echo "  mk find ft_p3                             Everything we know about FT p=3"
        echo "  mk failed tuza                            Failed approaches for Tuza"
        echo "  mk strategies nt                          NT proof techniques"
        echo "  mk submit sketch.txt --informal           Submit a sketch"
        echo "  mk status                                 Check Aristotle queue"
        echo "  mk partials                               List near-miss results"
        echo "  mk query \"SELECT * FROM submissions WHERE target_resolved=1\""
        ;;
esac
