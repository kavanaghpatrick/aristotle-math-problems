{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fusion_candidate.schema.json",
  "title": "FusionCandidate",
  "description": "Aggregated Stage-1..3 output — the dossier Stage 4 consumes.",
  "type": "object",
  "required": ["problem_id", "generated_at", "literature", "analogies",
               "technique_cards"],
  "additionalProperties": false,
  "properties": {
    "problem_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "literature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_count", "domains_covered", "path"],
      "properties": {
        "paper_count": {"type": "integer", "minimum": 0, "maximum": 50},
        "domains_covered": {
          "type": "array", "items": {"type": "string"}
        },
        "path": {"type": "string"},
        "papers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "arxiv_id", "year"],
            "properties": {
              "title": {"type": "string"},
              "authors": {"type": "array", "items": {"type": "string"}},
              "arxiv_id": {"type": ["string", "null"]},
              "year": {"type": ["integer", "null"]},
              "domain_tag": {"type": "string"},
              "summary": {"type": "string"},
              "url": {"type": ["string", "null"], "format": "uri"}
            }
          }
        }
      }
    },
    "analogies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "top_analogs"],
      "properties": {
        "path": {"type": "string"},
        "models_consulted": {
          "type": "array", "items": {"type": "string"}
        },
        "top_analogs": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["analog_id", "analog_problem", "analog_domain",
                         "named_technique", "structural_map",
                         "obstruction", "confidence"],
            "properties": {
              "analog_id": {"type": "string"},
              "analog_problem": {"type": "string"},
              "analog_domain": {"type": "string"},
              "named_technique": {"type": "string"},
              "structural_map": {"type": "string"},
              "obstruction": {"type": "string"},
              "confidence": {"type": "integer", "minimum": 1, "maximum": 5},
              "supporters": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Models that surfaced this analog."
              }
            }
          }
        }
      }
    },
    "technique_cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {"$ref": "technique_card.schema.json"}
    },
    "honest_disclaimer": {
      "type": "string",
      "description": "Mandatory free-form note on what the dossier does NOT claim."
    }
  }
}
