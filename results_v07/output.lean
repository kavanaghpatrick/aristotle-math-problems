def IsRegularPrime (p : ℕ) : Prop :=
  p.Prime ∧ ¬ (p ∣ NumberField.classNumber (CyclotomicField p ℚ))

def RegularPrimeConjecture : Prop := Set.Infinite {p : ℕ | IsRegularPrime p}

/-
$\mathbb{Q}$ is a cyclotomic extension of order 2 over $\mathbb{Q}$.
-/
theorem isCyclotomicExtension_two_rat : IsCyclotomicExtension {2} ℚ ℚ := by
  constructor ; norm_num;
  · use -1;
    norm_num [ IsPrimitiveRoot.iff ];
    intro l hl hl'; interval_cases l ; norm_num;
  · exact fun x => Subalgebra.algebraMap_mem _ x

/-
The cyclotomic field of order 2 over $\mathbb{Q}$ is isomorphic to $\mathbb{Q}$.
-/
noncomputable def cyclotomicField_two_equiv_rat : CyclotomicField 2 ℚ ≃ₐ[ℚ] ℚ := by
  letI : IsCyclotomicExtension {2} ℚ ℚ := isCyclotomicExtension_two_rat
  exact IsCyclotomicExtension.algEquiv {2} ℚ (CyclotomicField 2 ℚ) ℚ

/-
The ring of integers of the 2nd cyclotomic field is isomorphic to $\mathbb{Z}$.
-/
noncomputable def ringOfIntegers_cyclotomic_two_equiv_int : NumberField.RingOfIntegers (CyclotomicField 2 ℚ) ≃+* ℤ := by
  let e : CyclotomicField 2 ℚ ≃+* ℚ := cyclotomicField_two_equiv_rat.toRingEquiv
  let e' : NumberField.RingOfIntegers (CyclotomicField 2 ℚ) ≃+* NumberField.RingOfIntegers ℚ := NumberField.RingOfIntegers.mapRingEquiv e
  let e'' : NumberField.RingOfIntegers ℚ ≃+* ℤ := NumberField.RingOfIntegers.equiv ℤ
  exact e'.trans e''

/-
If $R$ and $S$ are isomorphic commutative rings and $S$ is a principal ideal ring, then $R$ is also a principal ideal ring.
-/
theorem isPrincipalIdealRing_of_ringEquiv {R S : Type*} [CommRing R] [CommRing S] (e : R ≃+* S) [IsPrincipalIdealRing S] : IsPrincipalIdealRing R := by
  refine' ⟨ fun I => _ ⟩;
  obtain ⟨ x, hx ⟩ := ‹IsPrincipalIdealRing S›.principal ( Ideal.map e I );
  refine' ⟨ e.symm x, _ ⟩;
  convert congr_arg ( Ideal.map e.symm ) hx using 1;
  · simp +decide [ Ideal.comap, SetLike.ext_iff ];
  · simp +decide [ Ideal.map_span ]

/-
2 is a regular prime.
-/
theorem isRegularPrime_two : IsRegularPrime 2 := by
  have h_iso : NumberField.RingOfIntegers (CyclotomicField 2 ℚ) ≃+* ℤ := ringOfIntegers_cyclotomic_two_equiv_int
  have h_pid : IsPrincipalIdealRing (NumberField.RingOfIntegers (CyclotomicField 2 ℚ)) := isPrincipalIdealRing_of_ringEquiv h_iso
  have h_class_num : NumberField.classNumber (CyclotomicField 2 ℚ) = 1 := by
    rw [NumberField.classNumber_eq_one_iff]
    exact h_pid
  rw [IsRegularPrime, h_class_num]
  norm_num