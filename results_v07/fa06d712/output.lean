  -- The proper unitary divisors of 1 are the empty set, so their sum is 0.
  simp [Erdos1052.properUnitaryDivisors]

lemma Erdos1052.no_odd_unitary_perfect (n : ℕ) (h : Erdos1052.IsUnitaryPerfect n) : ¬ Odd n := by
  -- If the cardinality of the prime factors is at most 1, then $n$ must be a prime power.
  by_cases h_card : n.primeFactors.card ≤ 1;
  · interval_cases _ : n.primeFactors.card <;> simp_all +decide [ Nat.primeFactors_pow ];
    · cases ‹_› <;> simp_all +decide [ Erdos1052.IsUnitaryPerfect ];
    · -- If $n$ has exactly one prime factor $p$, then $n = p^r$ for some $r$.
      obtain ⟨p, r, hp, hr⟩ : ∃ p r : ℕ, n = p^r ∧ p.Prime := by
        rw [ Finset.card_eq_one ] at *;
        -- Since the prime factors of $n$ are exactly $\{p\}$, we can write $n$ as $p^r$ for some $r$.
        obtain ⟨p, hp⟩ : ∃ p : ℕ, n.primeFactors = {p} := by
          tauto;
        exact ⟨ p, n.factorization p, by nth_rw 1 [ ← Nat.factorization_prod_pow_eq_self ( show n ≠ 0 by rintro rfl; simp_all +decide [ Erdos1052.IsUnitaryPerfect ] ) ] ; rw [ Finsupp.prod ] ; aesop, Nat.prime_of_mem_primeFactors <| hp.symm ▸ Finset.mem_singleton_self _ ⟩;
      -- Substitute n = p^r into the unitary sigma function and simplify.
      have h_unitary_sigma : Erdos1052.unitarySigma n = 1 + p^r := by
        rw [ hp, Erdos1052.unitarySigma_eq_prod_prime_factors ];
        · rcases r with ( _ | r ) <;> simp_all +decide [ Nat.primeFactors_pow ];
        · exact pow_ne_zero _ hr.ne_zero;
      have := Erdos1052.isUnitaryPerfect_iff_unitarySigma_eq_two_mul n ( Nat.pos_of_ne_zero ( by aesop ) ) ; simp_all +decide [ parity_simps ] ;
      linarith [ pow_lt_pow_right₀ hr.one_lt ( show r > 0 from Nat.pos_of_ne_zero ( by aesop_cat ) ) ];
  · contrapose! h_card; have := Erdos1052.card_primeFactors_le_one_of_odd_isUnitaryPerfect n; aesop;

