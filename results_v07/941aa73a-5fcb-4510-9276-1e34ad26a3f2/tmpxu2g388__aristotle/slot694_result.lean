      use erdos_m cs;
      refine' ⟨ _, fun k l h => _ ⟩;
      · -- By definition of $erdos_m$, we know that $erdos_m cs \equiv 1 \pmod{6}$.
        have h_mod_6 : (erdos_m cs) % 6 = 1 := by
          exact erdos_m_props cs |>.1;
        exact Nat.Coprime.symm ( Nat.Coprime.gcd_eq_one <| by rw [ ← Nat.mod_add_div ( erdos_m cs ) 6, h_mod_6 ] ; norm_num );
      · obtain ⟨ p, hp₁, hp₂ ⟩ := erdos_m_divisible cs k l;
        -- Since $p$ divides $2^k * 3^l * erdos_m cs + 1$ and $p$ is in the list of primes of the covering system, we have $p \leq erdos_m cs$.
