          have hp_le_erdos_m : p ∣ List.prod ((erdos_covering_system cs).map Prod.fst) := by
            exact List.dvd_prod ( by unfold erdos_covering_system; aesop );
          exact Nat.le_trans ( Nat.le_of_dvd ( Nat.pos_of_ne_zero ( by
            simp +decide [ erdos_covering_system ];
            intro x hx; have := cs.h_primes 0 x hx; norm_num at this; ) ) hp_le_erdos_m ) ( Nat.le_add_left _ _ );
