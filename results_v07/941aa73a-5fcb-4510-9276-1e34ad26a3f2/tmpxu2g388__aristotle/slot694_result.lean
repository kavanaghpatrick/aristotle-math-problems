/-
If a covering system exists, then there is a solution to Erdos 203.
-/
theorem erdos_203_final_proof (cs : CoveringSystem) :
    ∃ m, m.Coprime 6 ∧ ∀ k l, ¬ (2^k * 3^l * m + 1).Prime := by
      convert erdos_203_of_covering cs using 1

/-
Formal statement of Erdos 203.
-/
def Erdos203Prop : Prop := ∃ m, m.Coprime 6 ∧ ∀ k l, ¬ (2^k * 3^l * m + 1).Prime

theorem erdos_203 : Erdos203Prop ↔
    ∃ m, m.Coprime 6 ∧ ∀ k l, ¬ (2^k * 3^l * m + 1).Prime := by
  rfl

/-
The Erdos 203 conjecture statement.
-/
def Erdos203Conjecture : Prop := ∃ m, m.Coprime 6 ∧ ∀ k l, ¬ (2^k * 3^l * m + 1).Prime

/-
PROBLEM
Bridge lemma: m.Coprime 6 implies m > 0 for natural numbers.

PROVIDED SOLUTION
If m = 0, then gcd(m, 6) = gcd(0, 6) = 6 ≠ 1, contradicting m.Coprime 6. So m > 0.
-/
lemma pos_of_coprime_six {m : ℕ} (h : m.Coprime 6) : m > 0 := by
  exact Nat.pos_of_ne_zero fun contra => by simp_all +decide ;

/-
PROBLEM
Conditional version with m > 0: if a CoveringSystem exists, then Erdős 203 holds
with the positivity condition.

PROVIDED SOLUTION
Use erdos_203_of_covering cs to get ⟨m, hcop, hcomp⟩. Then show m > 0 using pos_of_coprime_six hcop. Return ⟨m, pos_of_coprime_six hcop, hcop, hcomp⟩.
-/
theorem erdos_203_of_covering_pos (cs : CoveringSystem) :
    ∃ m : ℕ, m > 0 ∧ m.Coprime 6 ∧
    ∀ k l : ℕ, ¬ (2^k * 3^l * m + 1).Prime := by
  convert erdos_203_of_covering cs using 1;
  grind

/-
The target theorem: Erdős Problem 203.
There exists a positive integer m coprime to 6 such that
2^k * 3^l * m + 1 is composite for every k, l ≥ 0.

Status: OPEN. The conditional direction (CoveringSystem → result) is proved above
(erdos_203_of_covering_pos). The gap is constructing or proving existence of such
