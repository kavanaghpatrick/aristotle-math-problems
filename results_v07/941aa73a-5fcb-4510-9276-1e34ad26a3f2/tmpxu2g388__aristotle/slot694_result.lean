        refine' Nat.le_of_dvd ( Nat.pos_of_ne_zero _ ) ( List.dvd_prod _ );
        · simp +decide [ erdos_covering_system ];
          intro x hx; have := cs.h_primes 0 x hx; norm_num at this;
        · unfold erdos_covering_system; aesop;
      nlinarith [ show 0 < 2 ^ k * 3 ^ l by positivity ]

