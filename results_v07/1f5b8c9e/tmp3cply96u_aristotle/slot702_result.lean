/-
The only solutions to 3^c - 2^b = 1 in positive integers are (c=1, b=1) and (c=2, b=3).
-/
lemma pow_three_sub_pow_two_eq_one_solutions (c b : ℕ) (hc : c > 0) (hb : b > 0) (h : 3^c - 2^b = 1) : (c = 1 ∧ b = 1) ∨ (c = 2 ∧ b = 3) := by
  rw [ Nat.sub_eq_iff_eq_add ] at h;
  · rcases c with ( _ | _ | c ) <;> rcases b with ( _ | _ | _ | _ | b ) <;> norm_num [ Nat.pow_succ' ] at *;
    · grind;
    · omega;
    · norm_num [ show c = 0 by exact Nat.pow_right_injective ( show 1 < 3 by decide ) ( by linarith ) ] at *;
    · have := congr_arg ( · % 16 ) h ; ring_nf at this ⊢ ; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rw [ ← Nat.mod_add_div c 4 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt c four_pos; interval_cases c % 4 <;> norm_num at *;
      have := congr_arg ( · % 5 ) h ; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rw [ ← Nat.mod_add_div b 4 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt b four_pos; interval_cases b % 4 <;> norm_num at *;
  · exact le_of_lt ( Nat.lt_of_sub_eq_succ h )

/-
There are no solutions to the Erdos 850 problem with x = 7. We use the fact that y is a power of 7, y+1 is a power of 2, and y+2 is a power of 3. We show that the only solutions to 3^c - 2^b = 1 are (1,1) and (2,3). (1,1) implies y=1, which is impossible. (2,3) implies y=7, which contradicts x!=y.
-/
theorem no_solution_x_7 : ∀ y, ¬ is_erdos_850_solution 7 y := by
  intro y hy
  obtain ⟨hp1, hp2, hp3⟩ := hy;
  -- Since $y$ is a power of $7$, we can write $y = 7^k$ for some integer $k$.
  obtain ⟨k, rfl⟩ : ∃ k, y = 7^k := by
    have h_pow_of_7 : y.primeFactors = {7} := by
      exact hp2.symm.trans ( by native_decide );
    rw [ ← Nat.factorization_prod_pow_eq_self ( show y ≠ 0 by rintro rfl; norm_num at * ) ] ; rw [ Finsupp.prod ] ; aesop;
  -- Since $y+1$ is a power of $2$, we can write $7^k + 1 = 2^m$ for some integer $m$.
  obtain ⟨m, hm⟩ : ∃ m, 7^k + 1 = 2^m := by
    -- Since the prime factors of $7^k + 1$ are $\{2\}$, it must be a power of $2$.
    have h_pow_two : ∀ {n : ℕ}, n.primeFactors = {2} → ∃ m, n = 2^m := by
      intro n hn; rw [ ← Nat.factorization_prod_pow_eq_self ( show n ≠ 0 by rintro rfl; simp +decide at hn ) ] ; rw [ Finsupp.prod ] ; aesop;
    exact h_pow_two <| hp3.1.symm.trans <| by native_decide;
  rcases m with ( _ | _ | _ | _ | m ) <;> rcases k with ( _ | _ | _ | _ | k ) <;> norm_num [ Nat.pow_succ', ← mul_assoc, Nat.mul_mod ] at *;
  any_goals omega;
  have := congr_arg ( · % 16 ) hm; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
  rcases Nat.even_or_odd' k with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this

/-
There are no solutions to the Erdos 850 problem with x = 8. We use the fact that y is a power of 2 and y+1 is a power of 3. We show that the only solutions to 3^b - 2^a = 1 are (1,1) and (2,3). (1,1) implies y=2, which fails the third condition. (2,3) implies y=8, which contradicts x!=y.
-/
theorem no_solution_x_8 : ∀ y, ¬ is_erdos_850_solution 8 y := by
  intro y hy;
  -- Since $y$ is a power of $2$, we can write $y = 2^a$ for some $a$.
  obtain ⟨a, ha⟩ : ∃ a, y = 2^a := by
    have h_prime_factors_y : y.primeFactors = {2} := by
      exact hy.2.1 ▸ by native_decide;
    rw [ ← Nat.factorization_prod_pow_eq_self ( show y ≠ 0 by rintro rfl; simp_all +decide [ is_erdos_850_solution ] ) ] ; rw [ Finsupp.prod ] ; aesop;
  -- Since $y+1$ is a power of $3$, we can write $y+1 = 3^b$ for some $b$.
  obtain ⟨b, hb⟩ : ∃ b, y + 1 = 3^b := by
    have hb : (y + 1).primeFactors = {3} := by
      have := hy.2.2.1;
      exact this ▸ by native_decide;
    rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( y + 1 ) ≠ 0 ) ] ; rw [ Finsupp.prod ] ; aesop;
  -- From the equation $2^a + 1 = 3^b$, we can see that $a$ must be 3 and $b$ must be 2.
  have h_ab : a = 3 ∧ b = 2 := by
    rcases a with ( _ | _ | _ | _ | a ) <;> rcases b with ( _ | _ | _ | _ | b ) <;> norm_num [ Nat.pow_succ' ] at * <;> first | omega | simp_all +arith +decide;
    · cases hy ; simp_all +decide [ Nat.primeFactors_mul ];
      exact absurd ‹Nat.primeFactors 8 = { 2 } ∧ Nat.primeFactors 9 = { 3 } ∧ Nat.primeFactors 10 = Nat.primeFactors 4›.2.2 ( by native_decide );
    · have := congr_arg ( · % 16 ) hb; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rw [ ← Nat.mod_add_div b 4 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt b four_pos; interval_cases b % 4 <;> norm_num at *;
      have := congr_arg ( · % 5 ) hb; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rw [ ← Nat.mod_add_div a 4 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt a four_pos; interval_cases a % 4 <;> contradiction;
  cases hy ; aesop

/-
The only solution to 11^c - 3^a = 2 in positive integers is c=1, a=2.
-/
lemma pow_eleven_sub_pow_three_eq_two (c a : ℕ) (hc : c > 0) (ha : a > 0) (h : 11^c - 3^a = 2) : c = 1 ∧ a = 2 := by
  rw [ Nat.sub_eq_iff_eq_add <| Nat.le_of_lt <| Nat.lt_of_sub_eq_succ h ] at h;
  -- Let's consider the equation modulo 8.
  have h_mod8 : (11 ^ c) % 8 = (2 + 3 ^ a) % 8 := by
    rw [h];
  rcases Nat.even_or_odd' c with ⟨ k, rfl | rfl ⟩ <;> rcases Nat.even_or_odd' a with ⟨ l, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at *;
  rcases k with ( _ | _ | k ) <;> rcases l with ( _ | _ | l ) <;> norm_num [ Nat.pow_succ', mul_assoc ] at *;
  · linarith [ Nat.one_le_pow l 9 ( by decide ) ];
  · omega;
  · grind;
  · have := congr_arg ( · % 121 ) h ; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
    rw [ ← Nat.mod_add_div l 110 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt l ( by decide : 0 < 110 ) ; interval_cases l % 110 <;> contradiction;

/-
There are no solutions to the Erdos 850 problem with x = 9. We use the fact that y is a power of 3 and y+2 is a power of 11. We show that the only solution to 11^c - 3^a = 2 is c=1, a=2, which implies y=9, contradicting x!=y.
-/
theorem no_solution_x_9 : ∀ y, ¬ is_erdos_850_solution 9 y := by
  intro y hy; obtain ⟨ hy1, hy2, hy3, hy4 ⟩ := hy; simp_all +decide [ Nat.primeFactors_mul ] ;
  -- Since $y$ is a power of $3$, we can write $y = 3^a$ for some integer $a$.
  obtain ⟨a, ha⟩ : ∃ a : ℕ, y = 3 ^ a := by
    have hy_pow : y.primeFactors = {3} := by
      exact hy2 ▸ by native_decide;
    rw [ ← Nat.factorization_prod_pow_eq_self ( show y ≠ 0 by rintro rfl; norm_num at * ) ] ; rw [ Finsupp.prod ] ; aesop;
  -- Since $y+2$ is a power of $11$, we can write $y+2 = 11^c$ for some integer $c$.
  obtain ⟨c, hc⟩ : ∃ c : ℕ, y + 2 = 11 ^ c := by
    rw [ ← Nat.prod_primeFactorsList ( by positivity : y + 2 ≠ 0 ) ] ; rw [ List.prod_eq_pow_single 11 ] ; aesop;
    intro p hp h; replace hy4 := Finset.ext_iff.mp hy4 p; aesop;
  -- The only solution to $11^c - 3^a = 2$ in positive integers is $c=1$ and $a=2$.
  have h_sol : c = 1 ∧ a = 2 := by
    apply pow_eleven_sub_pow_three_eq_two c a (by
    exact Nat.pos_of_ne_zero ( by rintro rfl; linarith [ pow_pos ( by decide : 0 < 3 ) a ] )) (by
    contrapose! hy1; aesop) (by
    rw [ ← hc, ha, Nat.add_sub_cancel_left ]);
  aesop

