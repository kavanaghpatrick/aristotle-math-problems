        cases le_total y x <;> simp_all +decide [ is_erdos_850_solution ];
        · have h_subset : y.primeFactors ⊆ (x - y).primeFactors ∧ (y + 1).primeFactors ⊆ (x - y).primeFactors ∧ (y + 2).primeFactors ⊆ (x - y).primeFactors := by
            have h_subset : y.primeFactors ⊆ (x - y).primeFactors ∧ (y + 1).primeFactors ⊆ (x - y).primeFactors ∧ (y + 2).primeFactors ⊆ (x - y).primeFactors := by
              have h1 : y.primeFactors ⊆ (x - y).primeFactors := by
                convert prime_factors_subset_diff _ _ using 1;
                · aesop;
                · exact lt_of_le_of_ne ‹_› ( Ne.symm h.1 )
              have h2 : (y + 1).primeFactors ⊆ (x - y).primeFactors := by
                intro p hp; have := Nat.dvd_sub ( show p ∣ x + 1 from Nat.dvd_of_mem_primeFactors <| h.2.2.1.symm ▸ hp ) ( show p ∣ y + 1 from Nat.dvd_of_mem_primeFactors hp ) ; aesop;
              have h3 : (y + 2).primeFactors ⊆ (x - y).primeFactors := by
                intro p hp; have := Nat.dvd_sub ( show p ∣ x + 2 from Nat.dvd_of_mem_primeFactors <| h.2.2.2.symm ▸ hp ) ( show p ∣ y + 2 from Nat.dvd_of_mem_primeFactors hp ) ; aesop;
              exact ⟨h1, h2, h3⟩;
            exact h_subset;
          have h_le : x ≤ 2 := by
            apply consecutive_smooth_limit;
            · simp_all +decide [ Set.subset_def ];
              refine' Finset.Subset.trans h_subset.1 _;
              convert h_smooth using 1;
              norm_cast;
            · simp_all +decide [ Finset.subset_iff ];
              intro p pp dp; specialize h_smooth pp; simp_all +decide [ ← Int.natCast_dvd_natCast, abs_of_nonneg ] ;
