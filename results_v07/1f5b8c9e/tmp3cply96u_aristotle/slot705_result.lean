            · simp_all +decide [ abs_of_nonneg, Int.natAbs_eq_iff ];
              grind;
          interval_cases x <;> interval_cases y <;> simp_all +decide;
        · have h_subset : x.primeFactors ⊆ (y - x).primeFactors ∧ (x + 1).primeFactors ⊆ (y - x).primeFactors ∧ (x + 2).primeFactors ⊆ (y - x).primeFactors := by
            have h1 : x.primeFactors ⊆ (y - x).primeFactors := by
              apply prime_factors_subset_diff; exact h.right.left; exact lt_of_le_of_ne ‹_› h.left;
            have h2 : (x + 1).primeFactors ⊆ (y - x).primeFactors := by
              have h2 : (x + 1).primeFactors ⊆ ((y + 1) - (x + 1)).primeFactors := by
