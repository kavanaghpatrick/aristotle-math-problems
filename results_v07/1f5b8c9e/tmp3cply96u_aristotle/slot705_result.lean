/-
If (x, y) is a solution to the Erdos 850 problem, then x and y have the same parity.
-/
theorem erdos_850_parity {x y : ℕ} (h : is_erdos_850_solution x y) : x % 2 = y % 2 := by
  obtain ⟨ hx_ne_y, hx_prime_factors, hy_prime_factors, hxy_prime_factors ⟩ := h;
  cases Nat.mod_two_eq_zero_or_one x <;> cases Nat.mod_two_eq_zero_or_one y <;> simp_all +decide [ Nat.add_mod ];
  · replace hx_prime_factors := Finset.ext_iff.mp hx_prime_factors 2; replace hy_prime_factors := Finset.ext_iff.mp hy_prime_factors 2; replace hxy_prime_factors := Finset.ext_iff.mp hxy_prime_factors 2; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;
  · replace hx_prime_factors := Finset.ext_iff.mp hx_prime_factors 2; replace hy_prime_factors := Finset.ext_iff.mp hy_prime_factors 2; replace hxy_prime_factors := Finset.ext_iff.mp hxy_prime_factors 2; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;

/-
If (x, y) is a solution to the Erdos 850 problem, then x and y are congruent modulo 3.
-/
theorem erdos_850_mod_3 {x y : ℕ} (h : is_erdos_850_solution x y) : x % 3 = y % 3 := by
  obtain ⟨ hx_ne_y, hx_prime_factors, hy_prime_factors, hxy_prime_factors ⟩ := h;
  replace hx_prime_factors := Finset.ext_iff.mp hx_prime_factors 3; replace hy_prime_factors := Finset.ext_iff.mp hy_prime_factors 3; replace hxy_prime_factors := Finset.ext_iff.mp hxy_prime_factors 3; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;
  grind

/-
If (x, y) is a solution to the Erdos 850 problem, then x and y are congruent modulo 6.
-/
theorem erdos_850_mod_6 {x y : ℕ} (h : is_erdos_850_solution x y) : x % 6 = y % 6 := by
  -- By the Chinese Remainder Theorem, since $x \equiv y \pmod{2}$ and $x \equiv y \pmod{3}$, we have $x \equiv y \pmod{6}$.
  have h_crt : x % 2 = y % 2 ∧ x % 3 = y % 3 → x % 6 = y % 6 := by
    omega;
  exact h_crt ⟨ erdos_850_parity h, erdos_850_mod_3 h ⟩

/-
If x and y have the same prime factors and x < y, then the prime factors of x are a subset of the prime factors of y - x.
-/
lemma prime_factors_subset_diff {x y : ℕ} (h : x.primeFactors = y.primeFactors) (hxy : x < y) :
    x.primeFactors ⊆ (y - x).primeFactors := by
      exact fun p hp => Nat.mem_primeFactors.mpr ⟨ Nat.prime_of_mem_primeFactors hp, Nat.dvd_sub ( Nat.dvd_of_mem_primeFactors ( h ▸ hp ) ) ( Nat.dvd_of_mem_primeFactors hp ), by linarith [ Nat.sub_pos_of_lt hxy ] ⟩

/-
If x, x+1, and x+2 are all 3-smooth (prime factors in {2, 3}), then x ≤ 2.
-/
lemma consecutive_smooth_limit (x : ℕ)
    (h1 : x.primeFactors ⊆ {2, 3})
    (h2 : (x + 1).primeFactors ⊆ {2, 3})
    (h3 : (x + 2).primeFactors ⊆ {2, 3}) :
    x ≤ 2 := by
      -- By contradiction, assume $x \geq 3$.
      by_contra h_contra;
      -- Since $x$, $x+1$, and $x+2$ are all 3-smooth, they must be of the form $2^a \cdot 3^b$ for some non-negative integers $a$ and $b$.
      obtain ⟨a, b, ha⟩ : ∃ a b : ℕ, x = 2^a * 3^b := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by linarith : x ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h1 ] <;> aesop
      obtain ⟨c, d, hc⟩ : ∃ c d : ℕ, x + 1 = 2^c * 3^d := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( x + 1 ) ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h2 ] <;> aesop
      obtain ⟨e, f, he⟩ : ∃ e f : ℕ, x + 2 = 2^e * 3^f := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( x + 2 ) ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h3 ] <;> aesop;
      rcases a with ( _ | a ) <;> rcases c with ( _ | c ) <;> rcases e with ( _ | e ) <;> simp_all +decide [ Nat.pow_succ', mul_assoc ];
      all_goals have := congr_arg Even hc; norm_num [ parity_simps ] at this;
      · rcases b with ( _ | _ | b ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
      · have := congr_arg ( · % 2 ) he; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      · have := congr_arg ( · % 2 ) he; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      · rcases a with ( _ | a ) <;> rcases e with ( _ | e ) <;> norm_num [ Nat.pow_succ', mul_assoc ] at *;
        · rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
        · rcases d with ( _ | _ | d ) <;> rcases b with ( _ | _ | b ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
        · rcases f with ( _ | _ | f ) <;> rcases d with ( _ | _ | d ) <;> norm_num [ Nat.pow_succ' ] at *;
          · linarith;
          · omega;
          · grind;
          · grind;
        · omega

/-
If (x, y) is a solution and the prime factors of |x - y| are a subset of {2, 3}, then x ≤ 2.
-/
lemma smooth_diff_implies_small {x y : ℕ} (h : is_erdos_850_solution x y)
    (h_smooth : (Nat.primeFactors |(x : ℤ) - y|.natAbs) ⊆ {2, 3}) :
