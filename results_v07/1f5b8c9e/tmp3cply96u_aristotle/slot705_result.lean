/-
Definition of a solution to the Erdos 850 problem: two distinct numbers x and y such that x, x+1, x+2 have the same prime factors as y, y+1, y+2 respectively.
-/
def is_erdos_850_solution (x y : ℕ) : Prop :=
  x ≠ y ∧
  x.primeFactors = y.primeFactors ∧
  (x + 1).primeFactors = (y + 1).primeFactors ∧
  (x + 2).primeFactors = (y + 2).primeFactors

/-
The Erdos 850 conjecture states that there exist distinct x, y such that rad(x)=rad(y), rad(x+1)=rad(y+1), and rad(x+2)=rad(y+2). This is equivalent to the condition on prime factors.
-/
def erdos_850_conjecture : Prop := ∃ x y, is_erdos_850_solution x y

theorem erdos_850 : erdos_850_conjecture ↔ ∃ x y : ℕ, x ≠ y
    ∧ x.primeFactors = y.primeFactors
    ∧ (x+1).primeFactors = (y+1).primeFactors
    ∧ (x+2).primeFactors = (y+2).primeFactors := by
  unfold erdos_850_conjecture is_erdos_850_solution
  rfl

