      -- By Lemma 2, $x \leq 2$.
      have h_x_le_2 : x.primeFactors ⊆ {2, 3} ∧ (x + 1).primeFactors ⊆ {2, 3} ∧ (x + 2).primeFactors ⊆ {2, 3} := by
        cases le_total x y <;> simp_all +decide [ is_erdos_850_solution ];
