/-
The prime factors of 6, 12, 18, and 24 are subsets of {2, 3}.
-/
lemma smooth_diffs (d : ℕ) (h : d ∈ ({6, 12, 18, 24} : Set ℕ)) : d.primeFactors ⊆ {2, 3} := by
  rcases h with ( rfl | rfl | rfl | rfl ) <;> native_decide

/-
If (x, y) is a solution, then |x - y| >= 30.
-/
theorem erdos_850_diff_ge_30 {x y : ℕ} (h : is_erdos_850_solution x y) : |(x : ℤ) - y| ≥ 30 := by
  -- Assume for contradiction that |(x : ℤ) - y| < 30.
  by_contra h_contra
  have h_abs : |(x : ℤ) - y| < 30 := by
    exact lt_of_not_ge h_contra;
  -- Since $x \equiv y \pmod{6}$, we have $|(x : ℤ) - y| \in \{6, 12, 18, 24\}$.
  have h_diff : ∃ d ∈ ({6, 12, 18, 24} : Set ℕ), |(x : ℤ) - y| = d := by
    have h_mod : x % 6 = y % 6 := by
      exact?;
    have h_diff : |(x : ℤ) - y| % 6 = 0 := by
      cases abs_cases ( x - y : ℤ ) <;> omega;
    have : |( x : ℤ ) - y| ≥ 0 := abs_nonneg _; interval_cases _ : |( x : ℤ ) - y| <;> simp_all +decide ;
    simp_all +decide [ sub_eq_iff_eq_add, is_erdos_850_solution ];
  -- By `smooth_diff_implies_small`, x ≤ 2.
  have h_small : x ≤ 2 := by
    apply smooth_diff_implies_small h;
    rcases h_diff with ⟨ d, hd₁, hd₂ ⟩ ; simp_all +decide [ Set.subset_def ] ;
    rcases hd₁ with ( rfl | rfl | rfl | rfl ) <;> native_decide;
  exact no_small_solutions x y ( by interval_cases x <;> trivial ) h

/-
Definition of the k=2 case and proof that a solution exists (x=2, y=8).
-/
def is_erdos_k2_solution (x y : ℕ) : Prop :=
  x ≠ y ∧
  x.primeFactors = y.primeFactors ∧
  (x + 1).primeFactors = (y + 1).primeFactors

theorem exists_erdos_k2_solution : ∃ x y, is_erdos_k2_solution x y := by
  use 2, 8; norm_num [ is_erdos_k2_solution ] ;
  native_decide +revert

/-
The Erdos 850 conjecture is equivalent to the existence of a solution.
-/
def answer (p : Prop) : Prop := p

theorem erdos_850 : answer erdos_850_conjecture ↔ ∃ x y : ℕ, x ≠ y
    ∧ x.primeFactors = y.primeFactors
    ∧ (x+1).primeFactors = (y+1).primeFactors
    ∧ (x+2).primeFactors = (y+2).primeFactors := by
      bound

/-
If (x, y) is a solution, then |x - y| >= 30.
-/
theorem erdos_850_diff_ge_30_proven {x y : ℕ} (h : is_erdos_850_solution x y) : |(x : ℤ) - y| ≥ 30 := by
  -- Apply the theorem that states |x - y| ≥ 30 for any solution (x, y) by assuming |x - y| < 30 and deriving a contradiction.
  apply erdos_850_diff_ge_30 h