              exact h_sub;
            aesop;
          simp_all +decide [ Finset.subset_iff ];
          refine' ⟨ fun p pp dp hy => h_smooth pp _ _, fun p pp dp => h_smooth pp _ _, fun p pp dp => h_smooth pp _ _ ⟩;
          all_goals norm_cast; simp_all +decide [ sub_eq_iff_eq_add ];
          · exact h_prime_factors_subset.1 pp dp |>.2;
          · exact h_prime_factors_subset.2.1 pp dp |>.2;
          · exact h_prime_factors_subset.2.2 pp dp |>.2;
