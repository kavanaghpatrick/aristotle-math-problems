/-
If x, x+1, and x+2 are all 3-smooth (prime factors in {2, 3}), then x ≤ 2.
-/
lemma consecutive_smooth_limit (x : ℕ)
    (h1 : x.primeFactors ⊆ {2, 3})
    (h2 : (x + 1).primeFactors ⊆ {2, 3})
    (h3 : (x + 2).primeFactors ⊆ {2, 3}) :
    x ≤ 2 := by
      -- By contradiction, assume $x \geq 3$.
      by_contra h_contra;
      -- Since $x$, $x+1$, and $x+2$ are all 3-smooth, they can be written as $2^a \cdot 3^b$, $2^c \cdot 3^d$, and $2^e \cdot 3^f$ respectively.
      obtain ⟨a, b, ha⟩ : ∃ a b : ℕ, x = 2^a * 3^b := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by linarith : x ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h1 ] <;> aesop
      obtain ⟨c, d, hb⟩ : ∃ c d : ℕ, x + 1 = 2^c * 3^d := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : x + 1 ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h2 ] <;> aesop
      obtain ⟨e, f, hc⟩ : ∃ e f : ℕ, x + 2 = 2^e * 3^f := by
        rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( x + 2 ) ≠ 0 ) ];
        rw [ Finsupp.prod_of_support_subset _ h3 ] <;> aesop;
      rcases a with ( _ | _ | a ) <;> rcases c with ( _ | _ | c ) <;> rcases e with ( _ | _ | e ) <;> simp_all +decide [ Nat.pow_succ', Nat.mul_assoc ];
      any_goals omega;
      all_goals have := congr_arg Even hb; have := congr_arg Even hc; norm_num [ parity_simps ] at *;
      · rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
      · have := congr_arg ( · % 3 ) hc; norm_num [ Nat.add_mod, Nat.pow_mod ] at this; rcases b with ( _ | _ | b ) <;> rcases f with ( _ | _ | f ) <;> norm_num at *;
      · rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
      · have := congr_arg ( · % 3 ) hb; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this; rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> norm_num at *;
