/-
Definition of the Erdos 850 solution predicate and the conjecture.
-/
def is_erdos_850_solution (x y : ℕ) : Prop :=
  x ≠ y ∧
  x.primeFactors = y.primeFactors ∧
  (x + 1).primeFactors = (y + 1).primeFactors ∧
  (x + 2).primeFactors = (y + 2).primeFactors

def erdos_850_conjecture : Prop := ∃ x y, is_erdos_850_solution x y

/-
If (x, y) is a solution, then x and y have the same parity.
-/
theorem erdos_850_parity {x y : ℕ} (h : is_erdos_850_solution x y) : x % 2 = y % 2 := by
  cases Nat.mod_two_eq_zero_or_one x <;> cases Nat.mod_two_eq_zero_or_one y <;> have := h.2.1 <;> have := h.2.2.1 <;> simp_all +decide [ Nat.dvd_iff_mod_eq_zero ];
  · replace this := Finset.ext_iff.mp this 2; simp_all +decide [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] ;
  · replace := h.1; replace := congr_arg ( fun s => 2 ∈ s ) ‹x.primeFactors = y.primeFactors›; norm_num [ Nat.dvd_iff_mod_eq_zero, ‹x % 2 = _›, ‹y % 2 = _› ] at this;
    cases h ; aesop

/-
If (x, y) is a solution, then x and y are congruent modulo 3.
