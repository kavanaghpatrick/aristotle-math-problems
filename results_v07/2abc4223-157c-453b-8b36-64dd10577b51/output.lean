          · intro p pp dp hp; specialize h_smooth pp; simp_all +decide [ ← Int.natCast_dvd_natCast, abs_of_nonpos ] ;
            exact h_smooth ( by omega );
          · intro p pp dp dp'; specialize h_smooth pp; simp_all +decide [ ← Int.natCast_dvd_natCast, abs_of_nonpos ] ;
            exact h_smooth ( by omega );
          · intro p pp dp hp; specialize h_smooth pp; simp_all +decide [ ← Int.natCast_dvd_natCast, abs_of_nonpos, sub_nonpos ] ;
            grind;
        · have h_prime_factors_subset : x.primeFactors ⊆ (x - y).primeFactors ∧ (x + 1).primeFactors ⊆ (x - y).primeFactors ∧ (x + 2).primeFactors ⊆ (x - y).primeFactors := by
            have h_prime_factors_subset : y.primeFactors ⊆ (x - y).primeFactors ∧ (y + 1).primeFactors ⊆ (x - y).primeFactors ∧ (y + 2).primeFactors ⊆ (x - y).primeFactors := by
              have h_sub : y.primeFactors ⊆ (x - y).primeFactors ∧ (y + 1).primeFactors ⊆ (x - y).primeFactors ∧ (y + 2).primeFactors ⊆ (x - y).primeFactors := by
                have h1 : y.primeFactors ⊆ (x - y).primeFactors := by
                  exact prime_factors_subset_diff ( by aesop ) ( lt_of_le_of_ne ‹_› ( Ne.symm h.1 ) )
                have h2 : (y + 1).primeFactors ⊆ (x - y).primeFactors := by
                  have h2 : (y + 1).primeFactors ⊆ (x + 1 - (y + 1)).primeFactors := by
                    apply prime_factors_subset_diff;
                    · aesop;
                    · grind;
                  aesop
                have h3 : (y + 2).primeFactors ⊆ (x - y).primeFactors := by
                  have h3 : (y + 2).primeFactors ⊆ (x + 2).primeFactors := by
                    aesop;
                  refine' fun p hp => _;
                  have h4 : p ∣ (x + 2) - (y + 2) := by
                    exact Nat.dvd_sub' ( Nat.dvd_of_mem_primeFactors ( h3 hp ) ) ( Nat.dvd_of_mem_primeFactors hp );
                  aesop
