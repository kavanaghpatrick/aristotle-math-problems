  all_goals replace hx := Finset.ext_iff.mp hx 3; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;
  · rw [ eq_comm ] at hy ; aesop;
  · rw [ eq_comm ] at hy ; aesop;
  · replace hy := Finset.ext_iff.mp hy.2 3; simp_all +decide [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] ;
  · replace hy := Finset.ext_iff.mp hy.1 3; simp_all +decide [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] ;

/-
If (x, y) is a solution, then x and y are congruent modulo 6.
-/
theorem erdos_850_mod_6 {x y : ℕ} (h : is_erdos_850_solution x y) : x % 6 = y % 6 := by
  exact Nat.ModEq.symm ( Nat.modEq_of_dvd <| by simpa using lcm_dvd ( Nat.modEq_iff_dvd.mp ( erdos_850_parity h|>.symm ) ) ( Nat.modEq_iff_dvd.mp ( erdos_850_mod_3 h|>.symm ) ) )

