            exact h.2.1 ▸ prime_factors_subset_diff ( by tauto ) ( lt_of_le_of_ne ‹_› h.1 )
          have h_prime_factors_subset_1 : (y + 1).primeFactors ⊆ (y - x).primeFactors := by
            have h_prime_factors_subset_1 : (x + 1).primeFactors ⊆ (y + 1 - (x + 1)).primeFactors := by
              apply prime_factors_subset_diff; aesop; exact Nat.succ_lt_succ ( lt_of_le_of_ne ‹_› ( by aesop ) ) ;
            aesop
          have h_prime_factors_subset_2 : (y + 2).primeFactors ⊆ (y - x).primeFactors := by
            have h_prime_factors_subset_2 : (x + 2).primeFactors ⊆ (y + 2 - (x + 2)).primeFactors := by
              apply prime_factors_subset_diff; aesop; exact by omega;
            aesop;
