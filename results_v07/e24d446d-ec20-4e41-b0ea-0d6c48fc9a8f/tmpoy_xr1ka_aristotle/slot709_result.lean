/-!
## Definition
-/

/-- The Erdős-Straus property: there exist positive integers x, y, z with
    4/n = 1/x + 1/y + 1/z, equivalently 4·x·y·z = n·(y·z + x·z + x·y). -/
def is_erdos_straus (n : Nat) :=
  ∃ x y z : Nat, 0 < x ∧ 0 < y ∧ 0 < z ∧
    4 * x * y * z = n * (y * z + x * z + x * y)

/-!
## Basic lemmas
