lemma is_erdos_straus_even (n : Nat) (h : n % 2 = 0) (hn : n ≥ 2) : is_erdos_straus n := by
  obtain ⟨k, rfl⟩ := Nat.dvd_of_mod_eq_zero h
  exact ⟨k, 2 * k, 2 * k, by omega, by omega, by omega, by nlinarith⟩

/-- Erdős-Straus holds for n ≡ 3 mod 4. -/
