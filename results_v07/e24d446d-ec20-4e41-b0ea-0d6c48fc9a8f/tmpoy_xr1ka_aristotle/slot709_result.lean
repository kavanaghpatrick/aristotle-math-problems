/-- If n satisfies Erdős-Straus, then n·k (k > 0) does too. -/
lemma is_erdos_straus_mul_right (n k : Nat) (hk : k > 0) :
    is_erdos_straus n → is_erdos_straus (n * k) := by
  rintro ⟨x, y, z, hx, hy, hz, h⟩
  exact ⟨x * k, y * k, z * k, mul_pos hx hk, mul_pos hy hk, mul_pos hz hk, by nlinarith [pow_pos hk 3]⟩

/-- Reduction to primes: if Erdős-Straus holds for all primes, it holds for all n ≥ 2. -/
lemma erdos_straus_of_primes :
    (∀ p, Nat.Prime p → is_erdos_straus p) → (∀ n, 2 ≤ n → is_erdos_straus n) := by
  intro h n hn
  obtain ⟨p, hp, hpn⟩ := Nat.exists_prime_and_dvd (by omega : n ≠ 1)
  obtain ⟨k, rfl⟩ := hpn
  exact is_erdos_straus_mul_right p k (Nat.pos_of_ne_zero (by intro hk; simp [hk] at hn)) (h p hp)

