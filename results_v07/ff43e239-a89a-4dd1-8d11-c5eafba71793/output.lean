/-
Formalized Lehmer's Totient Problem and Conjecture. Proved that any counterexample must be odd and squarefree. Established the equivalence between the existence of a counterexample and the negation of the conjecture.
-/

import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

