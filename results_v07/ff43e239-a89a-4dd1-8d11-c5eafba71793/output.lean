/-
A Lehmer counterexample is a composite number n > 1 such that φ(n) divides n - 1.
-/
def LehmerCounterexample (n : ℕ) : Prop :=
  n > 1 ∧ ¬Nat.Prime n ∧ Nat.totient n ∣ n - 1

/-
Any Lehmer counterexample must be odd.
-/
theorem lehmer_odd (n : ℕ) (h : LehmerCounterexample n) : Odd n := by
  obtain ⟨ hn₁, hn₂ ⟩ := h;
  -- If $n$ is even, then $\phi(n)$ is even.
  have h_phi_even : Even (Nat.totient n) := by
    exact Nat.totient_even <| Nat.le_of_not_lt fun h => by interval_cases n ; contradiction;
  obtain ⟨ k, hk ⟩ := hn₂.2; replace hk := congr_arg Even hk; rcases n with ( _ | _ | n ) <;> simp_all +arith +decide [ parity_simps ] ;

/-
Any Lehmer counterexample must be squarefree.
-/
theorem lehmer_squarefree (n : ℕ) (h : LehmerCounterexample n) : Squarefree n := by
  -- Suppose for contradiction that n is not squarefree.
  by_contra h_not_squarefree
  obtain ⟨p, hp⟩ : ∃ p, Nat.Prime p ∧ p ^ 2 ∣ n := by
    simpa only [ pow_two ] using by rw [ Nat.squarefree_iff_prime_squarefree ] at h_not_squarefree; aesop;
  -- Then $p \mid \varphi(n)$.
  have h_div_phi : p ∣ Nat.totient n := by
    refine' Nat.dvd_trans _ ( Nat.totient_dvd_of_dvd hp.2 );
    norm_num [ Nat.totient_prime_pow hp.1 ];
  have := Nat.dvd_trans h_div_phi h.2.2; simp_all +decide [ Nat.dvd_add_right, sq ] ;
  have := Nat.dvd_sub' ( dvd_of_mul_left_dvd hp.2 ) this; rcases n with ( _ | _ | n ) <;> simp_all +decide ;
  cases h.1

/-
Lehmer's Totient Conjecture states that there are no Lehmer counterexamples.
-/
def LehmerTotientConjecture : Prop :=
  ¬ ∃ n, LehmerCounterexample n

/-
The existence of a number satisfying the conditions of Lehmer's Totient Problem is equivalent to the negation of Lehmer's Totient Conjecture.
-/
theorem lehmer_totient :
    ¬ LehmerTotientConjecture ↔ ∃ n > 1, ¬Nat.Prime n ∧ Nat.totient n ∣ n - 1 := by
  unfold LehmerTotientConjecture; aesop;