/-
The divisibility condition in Erdos 389 is equivalent to a condition on factorials.
-/
theorem erdos_389_equivalent (n k : ℕ) (hn : 1 ≤ n) :
  ((Finset.range k).prod (fun i => n + i) ∣ (Finset.range k).prod (fun i => n + k + i)) ↔
  ((n + k - 1).factorial ^ 2 ∣ (n + 2 * k - 1).factorial * (n - 1).factorial) := by
    -- The product of n(n+1)...(n+k-1) is n.ascFactorial k, which is (n+k-1)!/(n-1)!.
    have h_prod1 : (∏ i ∈ Finset.range k, (n + i)) = Nat.factorial (n + k - 1) / Nat.factorial (n - 1) := by
      rw [ Nat.div_eq_of_eq_mul_left ];
      · positivity;
      · induction' k with k ih <;> simp_all +decide [ Nat.factorial, Finset.prod_range_succ ];
        cases n <;> simp_all +decide [ Nat.factorial_succ, mul_comm, mul_assoc, mul_left_comm, Finset.prod_range_succ ];
        rw [ Nat.add_right_comm, Nat.factorial_succ, ih ] ; ring

    -- The product of (n+k)...(n+2k-1) is (n+k).ascFactorial k, which is (n+2k-1)!/(n+k-1)!.
    have h_prod2 : (∏ i ∈ Finset.range k, (n + k + i)) = Nat.factorial (n + 2 * k - 1) / Nat.factorial (n + k - 1) := by
      rw [ Nat.div_eq_of_eq_mul_left ] <;> try positivity;
      -- By definition of factorial, we can rewrite the right-hand side as a product of consecutive integers.
      have h_factorial : ∀ (m k : ℕ), Nat.factorial (m + k) = Nat.factorial m * (∏ i ∈ Finset.range k, (m + i + 1)) := by
        exact fun m k => Nat.recOn k ( by norm_num ) fun n ih => by rw [ Nat.add_succ, Nat.factorial_succ, ih, Finset.prod_range_succ ] ; ring;
      convert h_factorial ( n + k - 1 ) k using 1 <;> cases n <;> cases k <;> norm_num [ Nat.mul_succ, Finset.prod_range_succ' ] at * ; ring;
      grind +ring

    -- Substitute these into the divisibility statement.
    have h_div : (∏ i ∈ Finset.range k, (n + i)) ∣ (∏ i ∈ Finset.range k, (n + k + i)) ↔
      (Nat.factorial (n + k - 1) / Nat.factorial (n - 1)) ∣ (Nat.factorial (n + 2 * k - 1) / Nat.factorial (n + k - 1)) := by
        rw [h_prod1, h_prod2];
    rw [ h_div, Nat.dvd_div_iff_mul_dvd ];
    · rw [ ← Nat.mul_div_assoc ];
      · rw [ sq, Nat.div_dvd_iff_dvd_mul ];
        · rw [ mul_comm ( n - 1 |> Nat.factorial ) ];
        · exact dvd_mul_of_dvd_left ( Nat.factorial_dvd_factorial ( by omega ) ) _;
        · positivity;
      · exact Nat.factorial_dvd_factorial ( by omega );
    · exact Nat.factorial_dvd_factorial ( by omega )

/-
The term in the Legendre sum for the valuation of the ratio.
-/
def legendre_term (n k p j : ℕ) : ℤ :=
  ((n + 2 * k - 1) / p ^ j : ℤ) + ((n - 1) / p ^ j : ℤ) - 2 * ((n + k - 1) / p ^ j : ℤ)

/-
The sum of Legendre terms equals the linear combination of p-adic valuations of the factorials.
-/
theorem legendre_sum_eq_valuation_diff (n k p : ℕ) (hp : p.Prime) (hn : 1 ≤ n) :
  let b := Nat.log p (n + 2 * k) + 1
  (∑ j ∈ Finset.range b, legendre_term n k p j) =
  ((padicValNat p (n + 2 * k - 1).factorial : ℤ) + padicValNat p (n - 1).factorial - 2 * padicValNat p (n + k - 1).factorial) := by
    haveI := Fact.mk hp ; erw [ padicValNat_factorial, padicValNat_factorial, padicValNat_factorial ] ; norm_num [ mul_comm ] ;
    any_goals exact Nat.log p ( n + k * 2 ) + 1;
    · simp +decide [ Finset.sum_Ico_eq_sub _ _, legendre_term ];
      simp +decide [ Finset.sum_add_distrib, mul_sub, Nat.cast_sub ( show 1 ≤ n + k * 2 from by linarith ), Nat.cast_sub ( show 1 ≤ n from by linarith ), Nat.cast_sub ( show 1 ≤ n + k from by linarith ) ] ; ring;
      rw [ Finset.sum_mul _ _ _ ];
    · exact Nat.lt_succ_of_le ( Nat.log_mono_right <| by omega );
    · exact Nat.lt_succ_of_le ( Nat.log_mono_right <| by omega );
    · exact Nat.lt_succ_of_le ( Nat.log_mono_right <| by omega )

/-
The divisibility condition is equivalent to the non-negativity of the sum of Legendre terms for all primes.
-/
theorem legendre_condition (n k : ℕ) (hn : 1 ≤ n) :
  ((Finset.range k).prod (fun i => n + i) ∣ (Finset.range k).prod (fun i => n + k + i)) ↔
  ∀ p : ℕ, p.Prime → (∑ j ∈ Finset.range (Nat.log p (n + 2 * k) + 1), legendre_term n k p j) ≥ 0 := by
    constructor <;> intro h;
    · -- Applying the equivalent condition from erdos_389_equivalent.
      have h_equiv : (Nat.factorial (n + k - 1) ^ 2 ∣ Nat.factorial (n + 2 * k - 1) * Nat.factorial (n - 1)) := by
        convert erdos_389_equivalent n k hn |>.1 _ using 1;
        assumption;
      intro p pp; have := Nat.factorization_le_iff_dvd ( by positivity ) ( by positivity ) |>.2 h_equiv; simp_all +decide [ Nat.factorization_eq_zero_iff ] ;
      -- By definition of $legendre\_term$, we know that
      have h_legendre_term : ∀ (n k p : ℕ) (hp : p.Prime) (hn : 1 ≤ n), (∑ j ∈ Finset.range (Nat.log p (n + 2 * k) + 1), legendre_term n k p j) = ((padicValNat p (n + 2 * k - 1).factorial : ℤ) + (padicValNat p (n - 1).factorial : ℤ) - 2 * (padicValNat p (n + k - 1).factorial : ℤ)) := by
        exact?;
      replace := this p; simp_all +decide [ Nat.factorization_mul, Nat.factorial_ne_zero ] ;
      simp_all +decide [ Nat.factorization ];
      norm_cast;
    · -- By definition of Legendre sum, this implies that for all primes $p$, the $p$-adic valuation of $(n+2k-1)!$ is greater than or equal to twice the $p$-adic valuation of $(n+k-1)!$.
      have h_legendre : ∀ p : ℕ, Nat.Prime p → padicValNat p ((n + 2 * k - 1).factorial) + padicValNat p ((n - 1).factorial) ≥ 2 * padicValNat p ((n + k - 1).factorial) := by
        intro p hp
        specialize h p hp;
        have := @legendre_sum_eq_valuation_diff n k p hp hn; simp_all +decide [ two_mul ] ;
        exact_mod_cast h;
      -- This implies that $(n + k - 1)!^2$ divides $(n + 2k - 1)! (n - 1)!$.
      have h_div : (n + k - 1).factorial ^ 2 ∣ (n + 2 * k - 1).factorial * (n - 1).factorial := by
        rw [ ← Nat.factorization_le_iff_dvd ] <;> try positivity;
        intro p; by_cases hp : Nat.Prime p <;> simp_all +decide [ Nat.factorization ] ;
        haveI := Fact.mk hp; rw [ padicValNat.pow, padicValNat.mul ] <;> first | positivity | aesop;
      convert erdos_389_equivalent n k hn |>.2 h_div using 1

/-
If p^j divides k, the Legendre term is 0.
-/
theorem legendre_term_zero_of_dvd (n k p j : ℕ) (h : p ^ j ∣ k) : legendre_term n k p j = 0 := by
  obtain ⟨ m, rfl ⟩ := h;
  unfold legendre_term; ring;
  by_cases h : p = 0 <;> simp_all +decide [ mul_assoc, Int.add_mul_ediv_left ];
  · cases j <;> norm_num;
    ring;
  · ring

/-
Integer division (A*M + r) / (L*M) equals A/L when r < M.
-/
theorem div_mul_add_div_eq_div {A M L r : ℕ} (hM : 0 < M) (hr : r < M) :
  (A * M + r) / (L * M) = A / L := by
    rw [ ← Nat.mul_div_mul_right _ _ hM ];
    -- Since $M$ is positive, we can divide both the numerator and the denominator by $M^2$.
    have h_div : (A * M^2 + r * M) / (L * M^2) = (A + r / M) / L := by
      rw [ Nat.div_eq_of_lt hr ] ; ring;
      rw [ show A * M ^ 2 + M * r = M * ( A * M + r ) by ring, mul_comm ];
      rw [ sq, mul_comm ];
      rw [ Nat.mul_assoc, Nat.mul_div_mul_left _ _ hM ];
      rw [ ← Nat.div_div_eq_div_mul ];
      rw [ Nat.add_div ] <;> norm_num [ hM ];
      rw [ Nat.div_eq_of_lt hr, if_neg ( by linarith [ Nat.mod_lt r hM ] ) ] ; norm_num;
    convert h_div using 1 <;> ring;
    norm_num [ Nat.div_eq_of_lt hr ]

/-
(2A)/D is at least 2*(A/D).
-/
theorem two_mul_div_sub_two_mul_div_nonneg (A D : ℕ) (hD : 0 < D) :
  (2 * A) / D - 2 * (A / D) ≥ 0 := by
    exact Nat.zero_le _

/-
If K is a multiple of p^M and n is small, then (n+K-1)/p^j is the same as K/p^j for j > M.
-/
theorem div_eq_div_of_dvd_add_small (n K p j M : ℕ)
    (hM : 0 < M) (h_dvd : p ^ M ∣ K) (h_large : n < p ^ M) (h_j : M < j) (hn : 1 ≤ n) :
    (n + K - 1) / p ^ j = K / p ^ j := by
      -- Substitute $K = q * p^M$ into the expression $(n + K - 1) / p^j$.
      obtain ⟨q, hq⟩ : ∃ q, K = q * p ^ M := by
        exact exists_eq_mul_left_of_dvd h_dvd;
      -- By div_mul_add_div_eq_div (with A=q, M=p^M, L=p^l, r=n-1), LHS = q / p^l.
      have h_left : (n + q * p ^ M - 1) / (p ^ M * p ^ (j - M)) = (q * p ^ M) / (p ^ M * p ^ (j - M)) := by
        have h_left : ∀ (A M L r : ℕ), 0 < M → r < M → (A * M + r) / (L * M) = A / L := by
          exact?;
        convert h_left q ( p ^ M ) ( p ^ ( j - M ) ) ( n - 1 ) ( pow_pos ( Nat.pos_of_ne_zero ( by aesop_cat ) ) _ ) ( by omega ) using 1 ; ring;
        · rw [ add_comm, Nat.add_sub_assoc hn ];
        · rw [ mul_comm, Nat.mul_div_mul_left _ _ ( pow_pos ( Nat.pos_of_ne_zero ( by aesop_cat ) ) _ ) ];
      simp_all +decide [ mul_comm, ← pow_add, add_tsub_cancel_of_le h_j.le ]

/-
The first term (n + 2k - 1) / p^j simplifies to (2k) / p^j.
-/
theorem legendre_term_simplification_1 (n k p j M : ℕ)
    (hM : 0 < M) (h_dvd : p ^ M ∣ k) (h_large : n < p ^ M) (h_j : M < j) (hn : 1 ≤ n) :
    (n + 2 * k - 1) / p ^ j = (2 * k) / p ^ j := by
      convert div_eq_div_of_dvd_add_small n ( 2 * k ) p j M hM ( dvd_mul_of_dvd_right h_dvd _ ) ( by linarith ) h_j ( by linarith ) using 1

/-
The second term (n + k - 1) / p^j simplifies to k / p^j.
-/
theorem legendre_term_simplification_2 (n k p j M : ℕ)
    (hM : 0 < M) (h_dvd : p ^ M ∣ k) (h_large : n < p ^ M) (h_j : M < j) (hn : 1 ≤ n) :
    (n + k - 1) / p ^ j = k / p ^ j := by
      convert div_eq_div_of_dvd_add_small n k p j M hM h_dvd h_large h_j hn using 1

/-
If k is divisible by a large enough power of p, then the Legendre term is non-negative.
-/
theorem legendre_term_nonneg_of_large_prime_power (n k p j M : ℕ)
    (hn : 1 ≤ n) (h_dvd : p ^ M ∣ k) (h_large : n < p ^ M) (h_j : M < j) :
    legendre_term n k p j ≥ 0 := by
      -- Let's simplify the expression for the Legendre term.
      have h_legendre_simplified : legendre_term n k p j = (2 * k / p ^ j : ℤ) - 2 * (k / p ^ j : ℤ) := by
        -- By simplifying the terms in the Legendre term, we can see that they reduce to the given expression.
        have h_simplify : ((n + 2 * k - 1) / p ^ j : ℤ) = (2 * k / p ^ j : ℤ) ∧ ((n + k - 1) / p ^ j : ℤ) = (k / p ^ j : ℤ) ∧ ((n - 1) / p ^ j : ℤ) = 0 := by
          refine' ⟨ _, _, _ ⟩ <;> norm_cast;
          · rw [ Int.subNatNat_of_le ( by linarith ) ] ; norm_cast;
            -- Since $p^j > n$, we have $(n + 2k - 1) / p^j = (2k) / p^j$.
            apply legendre_term_simplification_1 n k p j M (Nat.pos_of_ne_zero (by
            aesop)) h_dvd h_large h_j hn;
          · rw [ Int.subNatNat_of_le ( by linarith ) ] ; norm_cast;
            convert legendre_term_simplification_2 n k p j M ( Nat.pos_of_ne_zero ( by aesop_cat ) ) h_dvd h_large h_j hn using 1;
          · exact Nat.div_eq_of_lt ( by rw [ tsub_lt_iff_left ] <;> linarith [ pow_le_pow_right₀ ( show 1 ≤ p by contrapose! h_large; interval_cases p ; cases M <;> cases j <;> aesop ) h_j.le ] );
        unfold legendre_term; aesop;
      norm_num [ h_legendre_simplified ];
      rw [ Int.le_ediv_iff_mul_le ];
      · nlinarith [ Nat.div_mul_le_self k ( p ^ j ) ];
      · exact pow_pos ( Nat.cast_pos.mpr ( Nat.pos_of_ne_zero ( by rintro rfl; cases M <;> simp_all +decide ) ) ) _

/-
For any bound P, there exists a k such that the Legendre condition holds for all primes p <= P.
-/
theorem exists_k_for_small_primes (n P : ℕ) (hn : 1 ≤ n) :
  ∃ k : ℕ, 0 < k ∧ ∀ p : ℕ, p.Prime → p ≤ P →
    (∑ j ∈ Finset.range (Nat.log p (n + 2 * k) + 1), legendre_term n k p j) ≥ 0 := by
      by_contra h_contra;
      obtain ⟨k, hk⟩ : ∃ k : ℕ, 0 < k ∧ ∀ p : ℕ, Nat.Prime p → p ≤ P → p ^ (Nat.log p n + 1) ∣ k := by
        exact ⟨ ∏ p ∈ Finset.filter Nat.Prime ( Finset.Icc 2 P ), p ^ ( Nat.log p n + 1 ), Finset.prod_pos fun p hp => pow_pos ( Nat.Prime.pos ( Finset.mem_filter.mp hp |>.2 ) ) _, fun p hp hp' => Finset.dvd_prod_of_mem _ ( Finset.mem_filter.mpr ⟨ Finset.mem_Icc.mpr ⟨ Nat.Prime.two_le hp, hp' ⟩, hp ⟩ ) ⟩;
      refine' h_contra ⟨ k, hk.1, fun p hp hp' => Finset.sum_nonneg fun j hj => _ ⟩;
      by_cases hj' : j ≤ Nat.log p n + 1;
      · -- Since $p^j \mid k$, we have $legendre_term n k p j = 0$ by definition.
        have h_div : p ^ j ∣ k := by
          exact dvd_trans ( pow_dvd_pow _ hj' ) ( hk.2 p hp hp' );
        exact legendre_term_zero_of_dvd n k p j h_div ▸ by norm_num;
      · apply legendre_term_nonneg_of_large_prime_power n k p j ( Nat.log p n + 1 ) hn ( hk.2 p hp hp' ) ( Nat.lt_pow_succ_log_self hp.one_lt _ ) ( by linarith )

/-
Erdos 389 holds for n=1.
-/
theorem erdos_389_n_1 : ∃ k : ℕ, 0 < k ∧ (Finset.range k).prod (fun i => 1 + i) ∣ (Finset.range k).prod (fun i => 1 + k + i) := by
  use 1;
  simp;

/-
Definition of k_witness as the product of prime powers.
-/
def k_witness (n P : ℕ) : ℕ :=
  ∏ p ∈ Finset.filter Nat.Prime (Finset.range (P + 1)), p ^ (Nat.log p n + 1)

/-
k_witness is positive.
-/
theorem k_witness_pos (n P : ℕ) (hn : 1 ≤ n) : 0 < k_witness n P := by
  exact Finset.prod_pos fun p hp => pow_pos ( Nat.Prime.pos ( Finset.mem_filter.mp hp |>.2 ) ) _

/-
For sufficiently large primes, the Legendre sum is zero.
-/
theorem legendre_condition_large_primes (n k p : ℕ) (hp : p.Prime) (h_large : n + 2 * k < p) :
  (∑ j ∈ Finset.range (Nat.log p (n + 2 * k) + 1), legendre_term n k p j) = 0 := by
    rw [ Nat.log_of_lt ] <;> norm_num;
    · unfold legendre_term; norm_num;
      ring;
    · linarith

/-
If the modular condition holds for all powers of p, then the Legendre sum is non-negative.
-/
theorem modular_condition_sufficient (n k p : ℕ) (hp : p.Prime) (hn : 1 ≤ n) (h_large : p > n)
    (h_mod : ∀ j ≥ 1, 2 * ((n + k - 1) % p ^ j) ≥ n - 1) :
    (∑ j ∈ Finset.range (Nat.log p (n + 2 * k) + 1), legendre_term n k p j) ≥ 0 := by
      simp_all +decide [ legendre_term ];
      -- Since $p > n$, we have $((n + k - 1) \% p^j) < p^j$. Therefore, $2 * ((n + k - 1) \% p^j) \geq n - 1$ implies that $((n + 2 * k - 1) / p^j) \geq 2 * ((n + k - 1) / p^j)$.
      have h_term_nonneg : ∀ j ≥ 1, ((n + 2 * k - 1) / p ^ j : ℤ) ≥ 2 * ((n + k - 1) / p ^ j : ℤ) := by
        intro j hj; specialize h_mod j hj; norm_cast; simp_all +decide [ Nat.mod_add_div ] ;
        rw [ Int.subNatNat_of_le ( by linarith ), Int.subNatNat_of_le ( by linarith ) ] ; norm_cast;
        rw [ Nat.le_div_iff_mul_le ( pow_pos hp.pos _ ) ];
        linarith [ Nat.mod_add_div ( n + k - 1 ) ( p ^ j ), Nat.sub_add_cancel ( by linarith : 1 ≤ n + k ), Nat.sub_add_cancel ( by linarith : 1 ≤ n + 2 * k ) ];
      refine Finset.sum_le_sum fun i hi => ?_ ; rcases i with ( _ | i ) <;> norm_num at *;
      · linarith;
      · exact le_add_of_le_of_nonneg ( h_term_nonneg _ ( Nat.succ_pos _ ) ) ( Int.ediv_nonneg ( by linarith ) ( by positivity ) )

/-
Reduction: the divisibility of consecutive products is equivalent to
divisibility of binomial coefficients.
-/
theorem consecutive_prod_eq_choose (n k : ℕ) :
    (∏ i ∈ Finset.range k, (n + 1 + i)) = k.factorial * (n + k).choose k := by
  rw [← Nat.ascFactorial_eq_prod_range, Nat.ascFactorial_eq_factorial_mul_choose]

theorem erdos_389_reduce_to_choose (n k : ℕ) :
    ((∏ i ∈ Finset.range k, (n + 1 + i)) ∣
     (∏ i ∈ Finset.range k, (n + k + 1 + i))) ↔
    ((n + k).choose k ∣ (n + 2 * k).choose k) := by
  rw [consecutive_prod_eq_choose n k]
  have hk1 : (∏ i ∈ Finset.range k, (n + k + 1 + i)) = k.factorial * (n + 2 * k).choose k := by
    have h : ∏ i ∈ Finset.range k, (n + k + 1 + i) =
      (n + k + 1).ascFactorial k := by
      rw [Nat.ascFactorial_eq_prod_range]
    rw [h, Nat.ascFactorial_eq_factorial_mul_choose]
    congr 1; ring
  rw [hk1, Nat.mul_dvd_mul_iff_left (Nat.factorial_pos k)]

/-
Erdős 389: For every positive integer n, there exists k > 0 such that
the product of k consecutive integers starting from n+1 divides
the product of the next k consecutive integers.

Equivalently (by `erdos_389_reduce_to_choose`): for every n ≥ 1, there exists k > 0
such that C(n+k, k) | C(n+2k, k), i.e., Nat.choose (n+k) k ∣ Nat.choose (n+2*k) k.

Computationally verified for small n:
  n=1: k=5 works (ratio = 77)
  n=2: k=4 works (ratio = 14)
  n=3: k=207 works
  n=4: k=206 works
  n=5: k=2475 works

Approach via Legendre sums:
  By `legendre_condition` (with m = n+1), the divisibility holds iff for all primes p,
  the sum of `legendre_term (n+1) k p j` over j is non-negative.
  - `exists_k_for_small_primes` constructs k handling primes ≤ any given bound P.
  - `legendre_condition_large_primes` shows primes > n+1+2k contribute 0.
  - `legendre_term_zero_of_dvd` shows terms vanish when p^j | k.
  - `legendre_term_nonneg_of_large_prime_power` shows terms are non-negative for large j.

  The remaining gap: for primes p in (P, n+1+2k], the Legendre sum may include
  negative terms at j=1. This requires (n+k) mod p ≥ ⌈n/2⌉ for each such prime p
  (see `modular_condition_sufficient`). Finding k satisfying this for ALL primes
  simultaneously, while also satisfying divisibility conditions for primes ≤ P,
  appears to require arguments from analytic number theory (sieve methods or
  probabilistic existence proofs) that are not currently available in Mathlib.

  STATUS: OPEN. The infrastructure above reduces the problem to a number-theoretic
  gap about simultaneous modular conditions on k.
-/
theorem erdos_389 : ∀ n : ℕ, n ≥ 1 →
    ∃ k : ℕ, k > 0 ∧
    (∏ i ∈ Finset.range k, (n + 1 + i)) ∣
    (∏ i ∈ Finset.range k, (n + k + 1 + i)) := by
  sorry