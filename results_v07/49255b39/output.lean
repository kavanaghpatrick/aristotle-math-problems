  · have := congr_arg ( · % 121 ) hk; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
  · have := congr_arg ( · % 121 ) hk; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;

/-
