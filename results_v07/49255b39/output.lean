  · have := congr_arg ( · % 8 ) hc; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_add, Nat.pow_mul, Nat.pow_mod ] at this; rcases k with ( _ | k ) <;> rcases l with ( _ | l ) <;> norm_num [ Nat.pow_succ', ← mul_assoc, Nat.mul_mod, Nat.pow_mod ] at *;
