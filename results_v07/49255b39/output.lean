    obtain ⟨m, hm⟩ : ∃ m, 5 ^ (k + 2) + 2 = 7 ^ m := by
      rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( 5 ^ ( k + 2 ) + 2 ) ≠ 0 ) ] ; rw [ Finsupp.prod ] ; aesop;
    have := congr_arg ( · % 25 ) hm; norm_num [ Nat.add_mod, Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this;
    rw [ ← Nat.mod_add_div m 20 ] at this; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this; have := Nat.mod_lt m ( by decide : 0 < 20 ) ; interval_cases m % 20 <;> contradiction;

/-
Prove that x=6 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_6 : ∀ y, ¬ is_erdos_850_solution 6 y := by
  intro y hy; have := hy.2; simp_all +decide [ Nat.primeFactors_mul ] ;
  -- From the equality of prime factors, we know that $y + 2 = 2^k$ for some $k$.
  obtain ⟨k, hk⟩ : ∃ k, y + 2 = 2 ^ k := by
    have h_y_plus_2_power_of_two : (y + 2).primeFactors = {2} := by
      exact this.2.2.symm.trans ( by native_decide );
    rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( y + 2 ) ≠ 0 ) ] ; rw [ Finsupp.prod ] ; aesop;
  rcases k with ( _ | _ | _ | _ | k ) <;> simp_all +decide [ Nat.primeFactors_pow ];
  · cases hy.1 rfl;
  · -- From the equality of prime factors, we know that $y + 1 = 7^m$ for some $m$.
    obtain ⟨m, hm⟩ : ∃ m, y + 1 = 7 ^ m := by
      rw [ ← Nat.prod_primeFactorsList ( by linarith : y + 1 ≠ 0 ) ] ; rw [ List.prod_eq_pow_single 7 ] ; aesop;
      intro a' ha' ha''; replace this := Finset.ext_iff.mp this.2.1 a'; aesop;
    have := congr_arg ( · % 16 ) hk; have := congr_arg ( · % 16 ) hm; ring_nf at *; norm_num [ Nat.add_mod, Nat.mul_mod ] at *;
    rw [ ← Nat.mod_add_div m 4 ] at *; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *; have := Nat.mod_lt m four_pos; interval_cases m % 4 <;> norm_num at * <;> omega;

/-
Prove that x=7 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_7 : ∀ y, ¬ is_erdos_850_solution 7 y := by
  intro y hy; have := hy.2.1; simp_all +decide [ Nat.primeFactors_mul ] ;
  -- Since $y$ has only one prime factor, $7$, we can write $y = 7^k$ for some integer $k$.
  obtain ⟨k, rfl⟩ : ∃ k, y = 7 ^ k := by
    rw [ eq_comm ] at this;
    rw [ ← Nat.factorization_prod_pow_eq_self ( show y ≠ 0 by rintro rfl; simp_all +decide [ is_erdos_850_solution ] ) ] ; rw [ Finsupp.prod ] ; aesop;
  rcases k with ( _ | _ | k ) <;> norm_num [ Nat.primeFactors_pow ] at *;
  · cases hy.1 rfl;
  · have := hy.2.2.1; norm_num [ Nat.primeFactors_pow ] at this;
    rw [ eq_comm ] at this;
    -- Since $7^{k+2} + 1$ is divisible by $2$ and $8$ is $2^3$, $7^{k+2} + 1$ must be a power of $2$.
    have h_pow_two : ∃ m, 7 ^ (k + 2) + 1 = 2 ^ m := by
      rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( 7 ^ ( k + 2 ) + 1 ) ≠ 0 ) ];
      rw [ Finsupp.prod_of_support_subset ] <;> norm_num [ this ];
      rotate_left;
      exact { 2 };
      · native_decide;
      · aesop;
    rcases h_pow_two with ⟨ m, hm ⟩ ; rcases m with ( _ | _ | _ | _ | m ) <;> norm_num [ Nat.pow_succ', ← mul_assoc, Nat.mul_mod ] at hm;
    · linarith [ pow_pos ( by decide : 0 < 7 ) k ];
    · linarith [ pow_pos ( by decide : 0 < 7 ) k ];
    · linarith [ Nat.one_le_pow k 7 ( by decide ) ];
    · have := congr_arg ( · % 16 ) hm; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rw [ ← Nat.mod_add_div k 4 ] at this; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this; have := Nat.mod_lt k four_pos; interval_cases k % 4 <;> contradiction;

/-
Prove that x=8 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_8 : ∀ y, ¬ is_erdos_850_solution 8 y := by
  intro y hy;
  rcases hy with ⟨ hy₁, hy₂, hy₃ ⟩;
  -- Since $y$ must be of the form $2^k$ for some $k \geq 3$, let's write $y = 2^k$.
  obtain ⟨k, rfl⟩ : ∃ k, y = 2 ^ k := by
    have hy_prime_factors : y.primeFactors = {2} := by
      exact hy₂ ▸ by native_decide;
    rw [ ← Nat.factorization_prod_pow_eq_self ( show y ≠ 0 by rintro rfl; simp +decide at hy_prime_factors ) ] ; rw [ Finsupp.prod ] ; aesop;
  -- Since $2^k + 2 = 2(2^{k-1} + 1)$, we have $2^{k-1} + 1 = 5^m$ for some $m$.
  obtain ⟨m, hm⟩ : ∃ m, 2 ^ (k - 1) + 1 = 5 ^ m := by
    have h_form : (2 ^ (k - 1) + 1).primeFactors ⊆ {5} := by
      have h_form : (2 ^ k + 2).primeFactors ⊆ {2, 5} := by
        exact hy₃.2 ▸ by native_decide;
      rcases k with ( _ | _ | k ) <;> simp_all +decide [ Nat.pow_succ' ];
      · exact absurd hy₃.2 ( by native_decide );
      · rw [ show 2 * ( 2 * 2 ^ k ) + 2 = 2 * ( 2 * 2 ^ k + 1 ) by ring, Nat.primeFactors_mul ] at h_form <;> simp_all +decide;
    rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( 2 ^ ( k - 1 ) + 1 ) ≠ 0 ) ];
    rw [ Finsupp.prod_of_support_subset _ h_form ] <;> aesop;
  rcases k with ( _ | _ | _ | _ | k ) <;> norm_num [ Nat.pow_succ', ← mul_assoc, Nat.primeFactors_mul ] at *;
  · linarith [ Nat.pow_le_pow_right ( show 1 ≤ 5 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ];
  · linarith [ Nat.pow_le_pow_right ( show 1 ≤ 5 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ];
  · have := congr_arg ( · % 8 ) hm; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
    rcases Nat.even_or_odd' m with ⟨ c, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this;
    have := congr_arg ( · % 3 ) hm; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mul, Nat.pow_mod ] at this;
    rcases Nat.even_or_odd' k with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this

/-
Prove that x=9 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_9 : ∀ y, ¬ is_erdos_850_solution 9 y := by
  intros y h_solution; obtain ⟨ hxy, h1, h2, h3 ⟩ := h_solution; ( have := Nat.divisors_prime_pow ( by decide : Nat.Prime 3 ) 2; simp_all +decide [ Nat.primeFactors_mul ] ; );
