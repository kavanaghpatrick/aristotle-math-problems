/-
Prove that any solution to Erdos 850 must satisfy x > 10.
-/
theorem solutions_must_be_large : ∀ x y, is_erdos_850_solution x y → x > 10 := by
  intro x y h
  by_contra h_le
  replace h_le : x ≤ 10 := Nat.le_of_not_gt h_le
  rcases Nat.lt_or_eq_of_le h_le with h_lt | rfl
  · exact no_small_solutions x h_lt y h
  · exact no_solution_x_10 y h

/-
Prove that for any solution x, y to Erdos 850, the absolute difference |y - x| must be greater than 2.
-/
theorem diff_gt_2 : ∀ x y, is_erdos_850_solution x y → |(y : ℤ) - x| > 2 := by
  intro x y hxy; rcases lt_trichotomy x y with h | rfl | h <;> simp_all +decide [ is_erdos_850_solution ] ;
  · by_contra h_contra; push_neg at h_contra; (
    -- Since $|y - x| \leq 2$, we have $y = x + 1$ or $y = x + 2$.
    have h_cases : y = x + 1 ∨ y = x + 2 := by
      cases abs_cases ( y - x : ℤ ) <;> omega;
    rcases h_cases with ( rfl | rfl ) <;> simp_all +decide [ Nat.primeFactors_mul ];
    · -- Since $x$ and $x+1$ are coprime, their prime factors must be disjoint.
      have h_coprime : Nat.gcd x (x + 1) = 1 := by
        norm_num;
      have h_disjoint : Disjoint (x.primeFactors) ((x + 1).primeFactors) := by
        exact Nat.Coprime.disjoint_primeFactors h_coprime;
      simp_all +decide [ Finset.disjoint_left ];
    · norm_num [ Finset.ext_iff ] at *;
      have := hxy.1 2 Nat.prime_two; have := hxy.2.1 2 Nat.prime_two; have := hxy.2.2 2 Nat.prime_two; norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] at *;
      have := hxy.1 3 Nat.prime_three; have := hxy.2.1 3 Nat.prime_three; have := hxy.2.2 3 Nat.prime_three; norm_num [ Nat.add_mod, Nat.mul_mod ] at *; have := Nat.mod_lt x zero_lt_three; interval_cases x % 3 <;> simp_all +decide ;);
  · -- Since $y < x$, we have $|y - x| = x - y$.
    have h_abs : |(y : ℤ) - x| = x - y := by
      rw [ abs_sub_comm, abs_of_nonneg ( sub_nonneg_of_le ( mod_cast h.le ) ) ];
    -- By the properties of the radical function and the definition of Erdos 850 solutions, we know that $rad(x(x+1)(x+2)) \leq x - y$.
    have h_rad_le : rad (y * (y + 1) * (y + 2)) ≤ x - y := by
      convert erdos_850_diff_bound h _ _ _ using 1 <;> aesop ( simp_config := { singlePass := true } ) ;
    -- Since $y < x$, we have $rad(y(y+1)(y+2)) \geq 3$.
    have h_rad_ge_3 : 3 ≤ rad (y * (y + 1) * (y + 2)) := by
      -- Since $y < x$, we have $rad(y(y+1)(y+2)) \geq 3$ because $y(y+1)(y+2)$ is divisible by 3.
      have h_rad_ge_3 : 3 ∣ y * (y + 1) * (y + 2) := by
        exact Nat.dvd_of_mod_eq_zero ( by norm_num [ Nat.add_mod, Nat.mul_mod ] ; have := Nat.mod_lt y zero_lt_three; interval_cases y % 3 <;> trivial );
      exact Nat.le_of_dvd ( rad_pos _ ) ( Finset.dvd_prod_of_mem _ ( Nat.mem_primeFactors.mpr ⟨ by norm_num, h_rad_ge_3, by aesop ⟩ ) );
    omega

/-
Define k-smooth numbers and prove that if x, y is a solution to Erdos 850 with x < y, then x(x+1)(x+2) is (y-x)-smooth.
-/
def is_smooth (k n : ℕ) : Prop := ∀ p, p ∈ n.primeFactors → p ≤ k

theorem erdos_850_smoothness {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) :
    is_smooth (y - x) (x * (x + 1) * (x + 2)) := by
      -- By definition of $is_smooth$, we need to show that every prime factor of $x * (x + 1) * (x + 2)$ is less than or equal to $y - x$.
      unfold is_smooth
      intro p hp;
      -- By the properties of the radical, we know that $p \leq \text{rad}(x(x+1)(x+2))$.
      have hp_rad : p ≤ rad (x * (x + 1) * (x + 2)) := by
        exact Nat.le_of_dvd ( Finset.prod_pos fun q hq => Nat.pos_of_mem_primeFactors hq ) ( Finset.dvd_prod_of_mem _ hp );
      exact le_trans hp_rad ( erdos_850_diff_bound hxy h.2.1 h.2.2.1 h.2.2.2 )

/-
Prove that if x and y are a solution to Erdos 850, they have the same parity.
-/
theorem same_parity {x y : ℕ} (h : is_erdos_850_solution x y) : x % 2 = y % 2 := by
  obtain ⟨ hxy, h1, h2, h3 ⟩ := h;
  cases Nat.mod_two_eq_zero_or_one x <;> cases Nat.mod_two_eq_zero_or_one y <;> simp_all +decide [ Nat.add_mod ];
  · replace h1 := Finset.ext_iff.mp h1 2; replace h2 := Finset.ext_iff.mp h2 2; replace h3 := Finset.ext_iff.mp h3 2; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;
  · replace h1 := Finset.ext_iff.mp h1 2; replace h2 := Finset.ext_iff.mp h2 2; replace h3 := Finset.ext_iff.mp h3 2; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;

/-
Prove that for any solution x, y to Erdos 850, the absolute difference |y - x| cannot be 3.
-/
theorem diff_ne_3 : ∀ x y, is_erdos_850_solution x y → |(y : ℤ) - x| ≠ 3 := by
  intro x y hxy h;
  cases abs_cases ( y - x : ℤ ) <;> simp_all +decide [ sub_eq_iff_eq_add' ];
  · have := hxy.2.2.1 ; have := hxy.2.2.2 ; norm_cast at * ; simp_all +decide [ Nat.primeFactors_mul ] ;
    replace := Finset.ext_iff.mp this 2 ; simp_all +decide [ Nat.dvd_add_right ];
    grind;
  · norm_cast at h; have := hxy.2.2.1; simp_all +decide [ Nat.primeFactors_mul ] ;
    replace this := Finset.ext_iff.mp this 2 ; simp_all +arith +decide [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ];
    cases Nat.mod_two_eq_zero_or_one y <;> simp_all +decide only

/-
Prove that for any solution x, y to Erdos 850, the absolute difference |y - x| cannot be 4.
-/
theorem diff_ne_4 : ∀ x y, is_erdos_850_solution x y → |(y : ℤ) - x| ≠ 4 := by
  intro x y hxy h;
  cases' eq_or_ne x y with h h <;> simp_all +decide [ is_erdos_850_solution ];
  cases abs_cases ( y - x : ℤ ) <;> simp_all +decide [ sub_eq_iff_eq_add ];
  · norm_cast at *; simp_all +decide [ Finset.ext_iff ] ;
    have := hxy.1 2 Nat.prime_two; have := hxy.2.1 2 Nat.prime_two; have := hxy.2.2 2 Nat.prime_two; norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] at *;
    have := hxy.2.1 3 Nat.prime_three; have := hxy.2.2 3 Nat.prime_three; norm_num [ Nat.add_mod, Nat.mul_mod ] at *; have := Nat.mod_lt x zero_lt_three; interval_cases _ : x % 3 <;> simp_all +decide ;
  · norm_cast at *;
    simp_all +arith +decide [ Finset.ext_iff ];
    have := hxy.1 2 Nat.prime_two; have := hxy.2.1 2 Nat.prime_two; have := hxy.2.2 2 Nat.prime_two; norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod ] at *;
    have := hxy.1 3 Nat.prime_three; have := hxy.2.1 3 Nat.prime_three; have := hxy.2.2 3 Nat.prime_three; norm_num [ Nat.add_mod, Nat.mul_mod ] at *; have := Nat.mod_lt y zero_lt_three; interval_cases y % 3 <;> simp_all +decide ;

/-
Prove that the radical of the product of three consecutive positive integers is at least 6.
-/
theorem rad_prod_consecutive_ge_6 (x : ℕ) (hx : x > 0) : rad (x * (x + 1) * (x + 2)) ≥ 6 := by
  -- Since $x$, $x+1$, and $x+2$ are three consecutive integers, they are pairwise coprime, and thus their product's prime factors are at least $2$, $3$, and $5$.
  have h_prime_factors : (Nat.primeFactors (x * (x + 1) * (x + 2))) ⊇ {2, 3} := by
    norm_num [ Finset.insert_subset_iff, Nat.primeFactors_mul, hx.ne' ];
    grind;
  exact le_trans ( by decide ) ( Finset.prod_le_prod_of_subset_of_one_le' h_prime_factors fun _ _ _ => Nat.pos_of_mem_primeFactors ‹_› )

/-
Prove that 6 divides the radical of the product of three consecutive positive integers.
-/
theorem six_dvd_rad_prod_consecutive (x : ℕ) (hx : x > 0) : 6 ∣ rad (x * (x + 1) * (x + 2)) := by
  -- Since $x(x+1)(x+2)$ is divisible by both 2 and 3, its prime factors must include 2 and 3.
  have h_prime_factors : 2 ∈ (x * (x + 1) * (x + 2)).primeFactors ∧ 3 ∈ (x * (x + 1) * (x + 2)).primeFactors := by
    norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.add_mod, Nat.mod_two_of_bodd ];
    exact ⟨ hx.ne', by norm_num [ Nat.add_mod, Nat.mul_mod ] ; have := Nat.mod_lt x zero_lt_three; interval_cases x % 3 <;> trivial, hx.ne' ⟩;
  -- Since 2 and 3 are prime factors of $x(x+1)(x+2)$, their product 6 must divide the radical of $x(x+1)(x+2)$.
  have h_div : 2 ∣ (x * (x + 1) * (x + 2)).primeFactors.prod (fun p => p) ∧ 3 ∣ (x * (x + 1) * (x + 2)).primeFactors.prod (fun p => p) := by
    exact ⟨ Finset.dvd_prod_of_mem _ h_prime_factors.1, Finset.dvd_prod_of_mem _ h_prime_factors.2 ⟩;
  exact Nat.lcm_dvd h_div.left h_div.right

/-
Prove that if the radical of x(x+1)(x+2) is 6, then x <= 2.
-/
theorem rad_eq_six_implies_small_x {x : ℕ} (hx : x > 0) (h : rad (x * (x + 1) * (x + 2)) = 6) : x ≤ 2 := by
  -- Since $x \geq 3$, we know that $x$, $x+1$, and $x+2$ are all greater than 1 and have no common prime factors other than 2 and 3.
  have h_prime_factors : ∀ p, Nat.Prime p → p ∣ x * (x + 1) * (x + 2) → p = 2 ∨ p = 3 := by
    intro p pp dp; have := Nat.dvd_trans ( Nat.dvd_refl p ) dp; simp_all +decide [ rad ];
    have := h ▸ Finset.dvd_prod_of_mem _ ( Nat.mem_primeFactors.mpr ⟨ pp, this, by positivity ⟩ ) ; ( have := Nat.le_of_dvd ( by positivity ) this; interval_cases p <;> trivial; );
  -- Since $x \geq 3$, we know that $x$, $x+1$, and $x+2$ are all greater than 1 and have no common prime factors other than 2 and 3. Therefore, $x$, $x+1$, and $x+2$ must be of the form $2^a$, $3^b$, or $2^a \cdot 3^b$.
  have h_form : ∀ n ∈ [x, x + 1, x + 2], ∃ a b : ℕ, n = 2^a * 3^b := by
    intro n hn
    have h_prime_factors_n : ∀ p, Nat.Prime p → p ∣ n → p = 2 ∨ p = 3 := by
      exact fun p pp dp => h_prime_factors p pp ( dvd_trans dp ( by fin_cases hn <;> simp +decide [ dvd_mul_of_dvd_left ] ) );
    rw [ ← Nat.factorization_prod_pow_eq_self ( show n ≠ 0 by aesop ) ];
    rw [ Finsupp.prod_of_support_subset ];
    rotate_left;
    exact { 2, 3 };
    · intro p hp; specialize h_prime_factors_n p; aesop;
    · norm_num;
    · aesop;
  obtain ⟨ a, b, ha ⟩ := h_form x ( by norm_num ) ; obtain ⟨ c, d, hb ⟩ := h_form ( x + 1 ) ( by norm_num ) ; obtain ⟨ e, f, hc ⟩ := h_form ( x + 2 ) ( by norm_num ) ; simp_all +decide [ Nat.pow_succ', Nat.mul_assoc ] ;
  rcases a with ( _ | a ) <;> rcases c with ( _ | c ) <;> rcases e with ( _ | e ) <;> norm_num [ Nat.pow_succ', mul_assoc ] at *;
  all_goals have := congr_arg Even hb; norm_num [ parity_simps ] at this;
  · have := congr_arg ( · % 3 ) hc; rcases b with ( _ | _ | b ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ', Nat.pow_mul, Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at *;
  · have := congr_arg ( · % 2 ) hc; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
  · have := congr_arg ( · % 2 ) hc; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
  · rcases a with ( _ | a ) <;> rcases e with ( _ | e ) <;> norm_num [ Nat.pow_succ', mul_assoc ] at *;
    · rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
    · have := congr_arg ( · % 3 ) hb; rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at *;
    · rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
    · grind

/-
Prove that the radical of n is squarefree.
-/
theorem rad_squarefree (n : ℕ) : Squarefree (rad n) := by
  -- The product of distinct primes is squarefree.
  have h_squarefree : ∀ {S : Finset ℕ}, (∀ p ∈ S, Nat.Prime p) → Squarefree (S.prod (fun p => p)) := by
    intros S hS; induction S using Finset.induction <;> simp_all +decide [ Nat.squarefree_mul_iff ] ;
    exact ⟨ Nat.Coprime.prod_right fun p hp => hS.1.coprime_iff_not_dvd.mpr fun h => by have := Nat.prime_dvd_prime_iff_eq hS.1 ( hS.2 p hp ) ; aesop, hS.1.squarefree ⟩;
  exact h_squarefree fun p hp => Nat.prime_of_mem_primeFactors hp

/-
Prove that rad_lcm x is squarefree.
-/
theorem rad_lcm_squarefree (x : ℕ) : Squarefree (rad_lcm x) := by
  by_contra h_not_squarefree;
  -- By definition of $rad_lcm$, we know that $rad_lcm x = rad (x * (x + 1) * (x + 2))$ for $x \neq 0$.
  by_cases hx : x = 0;
  · exact h_not_squarefree <| by subst hx; native_decide;
  · exact h_not_squarefree <| by simpa only [ rad_lcm_eq_rad_prod_succ x hx ] using rad_squarefree _;

/-
Prove that if x, y is a solution to Erdos 850 with x < y, then rad_lcm(x) divides y - x.
-/
theorem diff_divisible_by_rad_lcm {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) :
    rad_lcm x ∣ y - x := by
      have h_rad_lcm_div : x ≡ y [MOD rad_lcm x] := by
        convert erdos_850_congruence _ _ _ _ using 1;
        · grind;
        · exact h.2.1;
        · exact h.2.2.1;
        · exact h.2.2.2;
      rw [ ← Nat.modEq_zero_iff_dvd ];
      cases le_total y x <;> simp_all +decide [ ← ZMod.natCast_eq_natCast_iff ]

/-
Prove that if x, y is a solution to Erdos 850 with x < y, then y - x is divisible by 6.
-/
theorem diff_divisible_by_six {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) :
    6 ∣ y - x := by
      have h_div_6 : 6 ∣ rad (x * (x + 1) * (x + 2)) ∧ rad (x * (x + 1) * (x + 2)) ∣ y - x := by
        refine' ⟨ _, _ ⟩;
        · apply six_dvd_rad_prod_consecutive;
          exact Nat.pos_of_ne_zero fun hx => by have := no_solution_x_0 y; aesop;
        · have h_div : rad_lcm x ∣ y - x := by
            exact?;
          convert h_div using 1;
          rw [ rad_lcm_eq_rad_prod_succ ];
          rintro rfl; exact no_solution_x_0 y h;
      exact dvd_trans h_div_6.1 h_div_6.2

/-
Prove that rad_lcm x >= 6 for x > 0.
-/
theorem rad_lcm_ge_6 (x : ℕ) (hx : x > 0) : rad_lcm x ≥ 6 := by
  -- By definition of rad_lcm, we know that rad_lcm x = rad (x * (x + 1) * (x + 2)).
  have h_rad_lcm_def : rad_lcm x = rad (x * (x + 1) * (x + 2)) := by
    exact rad_lcm_eq_rad_prod_succ x hx.ne';
  exact h_rad_lcm_def.symm ▸ rad_prod_consecutive_ge_6 x hx

/-
Prove that for any solution x, y to Erdos 850 with x < y, the difference y - x is at least 6.
-/
theorem diff_ge_6 {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) : y - x ≥ 6 := by
  -- Since $6 \mid y - x$, it follows that $y - x \geq 6$.
  have h_div : 6 ∣ y - x := by
    exact?
  exact Nat.le_of_dvd (Nat.sub_pos_of_lt hxy) h_div

/-
Prove that 6 divides rad_lcm x for x > 0.
-/
theorem six_dvd_rad_lcm (x : ℕ) (hx : x > 0) : 6 ∣ rad_lcm x := by
  -- Since $x$, $x+1$, and $x+2$ are consecutive integers, one of them must be divisible by 2 and another by 3. Therefore, $rad(x(x+1)(x+2))$ must be divisible by $2 \times 3 = 6$.
  have h_div_6 : 6 ∣ rad (x * (x + 1) * (x + 2)) := by
    exact?;
  rw [ rad_lcm_eq_rad_prod_succ ] ; exact h_div_6;
  positivity

/-
Prove that for x > 2, the product x(x+1)(x+2) has a prime factor p >= 5.
-/
theorem exists_prime_ge_5_dvd_prod_consecutive (x : ℕ) (hx : x > 2) :
    ∃ p, Nat.Prime p ∧ p ≥ 5 ∧ p ∣ x * (x + 1) * (x + 2) := by
      -- By contradiction, assume there are no primes p ≥ 5 dividing x(x+1)(x+2).
      by_contra h_no_prime_ge_5
      push_neg at h_no_prime_ge_5
      have h_no_prime_ge_5' : ∀ p, Nat.Prime p → p ≥ 5 → ¬(p ∣ x * (x + 1) * (x + 2)) := by
        assumption;
      -- Then each of x, x+1, and x+2 must be of the form 2^a * 3^b for some non-negative integers a and b.
      have h_form : ∀ n ∈ [x, x + 1, x + 2], ∃ a b : ℕ, n = 2^a * 3^b := by
        intro n hn
        have h_prime_factors : ∀ p, Nat.Prime p → p ∣ n → p = 2 ∨ p = 3 := by
          intro p pp dp; have := Nat.le_of_not_lt fun h => h_no_prime_ge_5' p pp h ( dvd_trans dp ( by fin_cases hn <;> simp +decide [ dvd_mul_of_dvd_left ] ) ) ; interval_cases p <;> simp_all +decide ;
        rw [ ← Nat.factorization_prod_pow_eq_self ( show n ≠ 0 by aesop ) ];
        rw [ Finsupp.prod_of_support_subset ];
        rotate_left;
        exacts [ { 2, 3 }, by intro p hp; simpa using h_prime_factors p ( Nat.prime_of_mem_primeFactors hp ) ( Nat.dvd_of_mem_primeFactors hp ), by norm_num, ⟨ n.factorization 2, n.factorization 3, by simp +decide [ mul_comm ] ⟩ ];
      obtain ⟨ a, b, hx ⟩ := h_form x ( by norm_num ) ; obtain ⟨ c, d, hx' ⟩ := h_form ( x + 1 ) ( by norm_num ) ; obtain ⟨ e, f, hx'' ⟩ := h_form ( x + 2 ) ( by norm_num ) ; simp_all +decide [ Nat.pow_succ', mul_assoc ] ;
      rcases a with ( _ | a ) <;> rcases c with ( _ | c ) <;> rcases e with ( _ | e ) <;> norm_num [ Nat.pow_succ', Nat.mul_assoc ] at *;
      all_goals have := congr_arg ( · % 2 ) hx'; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      · have := congr_arg ( · % 3 ) hx''; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this; rcases b with ( _ | _ | b ) <;> rcases f with ( _ | _ | f ) <;> norm_num at *;
      · have := congr_arg ( · % 2 ) hx''; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      · have := congr_arg ( · % 3 ) hx''; rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ', Nat.pow_mul, Nat.mul_mod, Nat.pow_mod, Nat.add_mod ] at *;
        · grind;
        · omega;
        · have := congr_arg ( · % 4 ) hx''; rcases a with ( _ | _ | a ) <;> norm_num [ Nat.pow_succ', ← mul_assoc, Nat.mul_mod, Nat.pow_mod, Nat.add_mod ] at *;
          · cases b <;> norm_num at *;
          · rcases Nat.even_or_odd' f with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this;
          · rcases Nat.even_or_odd' f with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this;
      · rcases a with ( _ | a ) <;> rcases e with ( _ | e ) <;> norm_num [ Nat.pow_succ', mul_assoc ] at *;
        · rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
        · have := congr_arg ( · % 3 ) hx'; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this; rcases b with ( _ | _ | b ) <;> rcases d with ( _ | _ | d ) <;> norm_num [ Nat.pow_succ', Nat.mul_mod, Nat.pow_mod ] at *;
        · rcases d with ( _ | _ | d ) <;> rcases f with ( _ | _ | f ) <;> norm_num [ Nat.pow_succ' ] at * <;> omega;
        · omega

/-
Prove that for any solution x, y to Erdos 850 with x < y, the difference y - x is at least 12.
-/
theorem diff_ge_12 {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) : y - x ≥ 12 := by
  by_cases hx : x > 2;
  · -- By Lemma 2, there exists a prime factor $p \geq 5$ of $x(x+1)(x+2)$.
    obtain ⟨p, hp_prime, hp_ge_5, hp_div⟩ : ∃ p, Nat.Prime p ∧ p ≥ 5 ∧ p ∣ x * (x + 1) * (x + 2) := exists_prime_ge_5_dvd_prod_consecutive x hx;
    -- By Lemma 3, $p \mid y - x$.
    have hp_div_diff : p ∣ y - x := by
      have hp_div_diff : p ∣ rad_lcm x := by
        have hp_div_rad_lcm : p ∣ rad (x * (x + 1) * (x + 2)) := by
          exact Finset.dvd_prod_of_mem _ ( by aesop );
        exact hp_div_rad_lcm.trans ( by rw [ rad_lcm_eq_rad_prod_succ x ( by linarith ) ] );
      exact dvd_trans hp_div_diff ( diff_divisible_by_rad_lcm h hxy );
    -- Since $p \geq 5$ and $6 \mid y - x$, we have $y - x \geq \text{lcm}(6, p)$.
    have h_lcm : y - x ≥ Nat.lcm 6 p := by
      exact Nat.le_of_dvd ( Nat.sub_pos_of_lt hxy ) ( Nat.lcm_dvd ( show 6 ∣ y - x from diff_divisible_by_six h hxy ) hp_div_diff );
    by_cases hp_ge_12 : p ≥ 12;
    · exact le_trans ( Nat.le_of_dvd ( Nat.lcm_pos ( by decide ) hp_prime.pos ) ( Nat.dvd_lcm_right _ _ ) ) ( h_lcm.trans' ( Nat.le_refl _ ) ) |> le_trans hp_ge_12;
    · interval_cases p <;> norm_num at *;
      · grind;
      · linarith;
      · linarith;
  · interval_cases x <;> simp_all +decide;
    · exact absurd h ( no_solution_x_0 y );
    · exact absurd h ( by exact no_solution_x_1 _ );
    · have := no_solution_x_2_to_4 2 ( by norm_num ) y h; aesop;

/-
Prove that for any solution x, y to Erdos 850 with x < y, the difference y - x is at least 30.
-/
theorem diff_ge_30 {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) : y - x ≥ 30 := by
  -- If $x > 2$, then $x(x+1)(x+2)$ has a prime factor $p \geq 5$.
  by_cases hx_gt_2 : x > 2;
  · -- If $x > 2$, then $x(x+1)(x+2)$ has a prime factor $p \geq 5$, so $p \mid y - x$.
    obtain ⟨p, hp_prime, hp_ge_5, hp_div⟩ : ∃ p, Nat.Prime p ∧ p ≥ 5 ∧ p ∣ x * (x + 1) * (x + 2) := exists_prime_ge_5_dvd_prod_consecutive x hx_gt_2
    have hp_div_diff : p ∣ y - x := by
      have hp_div_diff : p ∣ rad_lcm x := by
        have hp_div_rad_lcm : p ∣ rad (x * (x + 1) * (x + 2)) := by
          exact Finset.dvd_prod_of_mem _ ( by aesop );
        rw [ rad_lcm_eq_rad_prod_succ ] <;> aesop;
      exact dvd_trans hp_div_diff ( diff_divisible_by_rad_lcm h hxy );
    -- Since $p$ divides $y-x$, we have $y-x \geq p$.
    have hp_le_diff : p ≤ y - x := by
      exact Nat.le_of_dvd ( Nat.sub_pos_of_lt hxy ) hp_div_diff;
    have hp_le_diff : 6 ∣ y - x := by
      exact?;
    by_contra h_contra;
    interval_cases _ : y - x <;> simp_all +decide;
    · interval_cases p <;> simp_all +decide;
    · interval_cases p <;> norm_num at *;
    · interval_cases p <;> norm_num at *;
    · interval_cases p <;> norm_num at *;
  · interval_cases x <;> have := h.2 <;> simp_all +decide [ Nat.primeFactors_mul ];
    · exact absurd h ( no_solution_x_0 y );
    · rw [ eq_comm ] at this ; aesop;
    · rcases y with ( _ | _ | _ | _ | _ | _ | _ | _ | _ | _ | y ) <;> simp_all +arith +decide;
      · exact absurd this.2.2 ( by native_decide );
      · exact absurd this.2.2 ( by native_decide );
      · exact le_of_not_gt fun hy => by interval_cases y <;> exact absurd this ( by native_decide ) ;

/-
Define the maximum prime factor and prove that y - x is at least lcm(6, max_prime_factor(x(x+1)(x+2))).
-/
def max_prime_factor (n : ℕ) : ℕ := n.primeFactors.max.getD 1

theorem diff_ge_lcm_6_max_prime {x y : ℕ} (h : is_erdos_850_solution x y) (hxy : x < y) :
    y - x ≥ Nat.lcm 6 (max_prime_factor (x * (x + 1) * (x + 2))) := by
      refine' Nat.le_of_dvd ( Nat.sub_pos_of_lt hxy ) _;
      refine' Nat.lcm_dvd _ _;
      · exact?;
      · have h_max_prime_factor_div : max_prime_factor (x * (x + 1) * (x + 2)) ∣ rad_lcm x := by
          have h_max_prime_factor_div : max_prime_factor (x * (x + 1) * (x + 2)) ∣ rad (x * (x + 1) * (x + 2)) := by
            apply Nat.dvd_of_mem_primeFactors;
            unfold max_prime_factor;
            rcases n : ( x * ( x + 1 ) * ( x + 2 ) |> Nat.primeFactors |> Finset.max ) with ( _ | _ | p ) <;> simp_all +decide [ rad ];
            · rcases x with ( _ | _ | x ) <;> simp_all +decide [ Nat.primeFactors_mul ];
              · exact no_solution_x_0 y h;
              · exact absurd n ( by native_decide );
              · simp_all +decide [ Finset.max ];
                simp_all +decide [ Finset.sup_union ];
                cases h : Finset.sup ( Nat.primeFactors ( x + 1 + 1 ) ) WithBot.some <;> cases h' : Finset.sup ( Nat.primeFactors ( x + 1 + 1 + 1 ) ) WithBot.some <;> cases h'' : Finset.sup ( Nat.primeFactors ( x + 1 + 1 + 2 ) ) WithBot.some <;> simp_all +decide;
                all_goals norm_cast at *;
                exact h' ( Nat.minFac ( x + 1 + 1 + 1 ) ) ( Nat.minFac_prime ( by linarith ) ) ( Nat.minFac_dvd _ );
            · have := Finset.mem_of_max n; aesop;
            · exact ⟨ Nat.prime_of_mem_primeFactors <| Finset.mem_of_max n, Finset.dvd_prod_of_mem _ <| Finset.mem_of_max n, Finset.prod_ne_zero_iff.mpr fun p hp => Nat.ne_of_gt <| Nat.pos_of_mem_primeFactors hp ⟩;
          convert h_max_prime_factor_div using 1;
          exact rad_lcm_eq_rad_prod_succ x ( Nat.ne_of_gt ( Nat.pos_of_ne_zero ( by rintro rfl; exact absurd h.1 ( by have := no_solution_x_0 y; aesop ) ) ) );
        exact dvd_trans h_max_prime_factor_div ( diff_divisible_by_rad_lcm h hxy )

/-
Prove that the only solutions to 2^k - 7^m = 1 are (1, 0) and (3, 1).
-/
theorem solution_pow2_sub_pow7_eq_1 (k m : ℕ) : 2^k - 7^m = 1 ↔ (k = 1 ∧ m = 0) ∨ (k = 3 ∧ m = 1) := by
  by_contra! h_contra;
  rcases h_contra with h_contra | h_contra <;> simp_all +decide [ Nat.pow_succ' ];
  · rw [ Nat.sub_eq_iff_eq_add ] at h_contra;
    · rcases k with ( _ | _ | _ | _ | k ) <;> rcases m with ( _ | _ | _ | m ) <;> norm_num [ Nat.pow_succ' ] at * <;> simp_all +arith +decide;
      any_goals omega;
      have := congr_arg ( · % 16 ) h_contra ; norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod ] at this;
      rcases Nat.even_or_odd' m with ⟨ c, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at this;
    · omega;
  · aesop