/-
Erdos 850: Do there exist distinct x, y such that x and y share the same prime factors, x+1 and y+1 share the same prime factors, AND x+2 and y+2 share the same prime factors?
-/
def Erdos850 : Prop := ∃ x y : ℕ, x ≠ y ∧ x.primeFactors = y.primeFactors
      ∧ (x + 1).primeFactors = (y + 1).primeFactors
      ∧ (x + 2).primeFactors = (y + 2).primeFactors

/-
Search for solutions to Erdos 850 for x, y < 200.
-/
def check_erdos_850 (n : Nat) : Option (Nat × Nat) :=
  let range := List.range n
  let pairs := range.flatMap (fun x => range.map (fun y => (x, y)))
  pairs.find? (fun ⟨x, y⟩ =>
    x < y ∧
    x.primeFactors = y.primeFactors ∧
    (x + 1).primeFactors = (y + 1).primeFactors ∧
    (x + 2).primeFactors = (y + 2).primeFactors)

#eval check_erdos_850 200

/-
Search for solutions to Erdos 850 for x, y < 500.
-/
def check_erdos_850_upto (n : Nat) : Option (Nat × Nat) :=
  let range := List.range n
  let pairs := range.flatMap (fun x => range.map (fun y => (x, y)))
  pairs.find? (fun ⟨x, y⟩ =>
    x < y ∧
    x.primeFactors = y.primeFactors ∧
    (x + 1).primeFactors = (y + 1).primeFactors ∧
    (x + 2).primeFactors = (y + 2).primeFactors)

#eval check_erdos_850_upto 500

/-
Check if UniqueFactorizationMonoid.radical can be used for Nat.
-/
#check (UniqueFactorizationMonoid.radical : ℕ → ℕ)

/-
Define the radical of a natural number as the product of its prime factors, and state that it is always positive.
-/
def rad (n : ℕ) : ℕ := n.primeFactors.prod (fun p => p)

theorem rad_pos (n : ℕ) : 0 < rad n := by
  exact Finset.prod_pos fun p hp => Nat.pos_of_mem_primeFactors hp |> fun h => by aesop;

/-
A prime p divides rad(n) if and only if p divides n (for n ≠ 0).
-/
theorem dvd_rad_iff {n p : ℕ} (h0 : n ≠ 0) (hp : p.Prime) : p ∣ rad n ↔ p ∣ n := by
  simp +zetaDelta at *;
  constructor;
  · exact fun h => Nat.dvd_trans h <| Nat.prod_primeFactors_dvd _;
  · exact fun h => Finset.dvd_prod_of_mem _ ( by aesop )

/-
If x and y have the same prime factors, then rad(x) divides y.
-/
theorem rad_dvd_of_primeFactors_eq {x y : ℕ} (h : x.primeFactors = y.primeFactors) : rad x ∣ y := by
  convert Nat.dvd_trans ?_ ( Nat.prod_primeFactors_dvd y ) using 1;
  unfold rad; aesop;

/-
Define the LCM of the radicals of x, x+1, x+2, and prove that if x and y are a solution to Erdos 850, then x ≡ y (mod rad_lcm x).
-/
def rad_lcm (x : ℕ) : ℕ := Nat.lcm (rad x) (Nat.lcm (rad (x + 1)) (rad (x + 2)))

theorem erdos_850_congruence {x y : ℕ} (hxy : x ≠ y)
    (h1 : x.primeFactors = y.primeFactors)
    (h2 : (x + 1).primeFactors = (y + 1).primeFactors)
    (h3 : (x + 2).primeFactors = (y + 2).primeFactors) :
    Nat.ModEq (rad_lcm x) x y := by
      norm_num [ Nat.modEq_iff_dvd ] at *;
      have h_div : (rad x : ℤ) ∣ (y - x) ∧ (rad (x + 1) : ℤ) ∣ (y - x) ∧ (rad (x + 2) : ℤ) ∣ (y - x) := by
        have h_div_x : (rad x : ℤ) ∣ (y : ℤ) := by
          exact_mod_cast rad_dvd_of_primeFactors_eq h1
        have h_div_x1 : (rad (x + 1) : ℤ) ∣ ((y + 1) : ℤ) := by
          convert rad_dvd_of_primeFactors_eq h2 using 1 ; norm_cast
        have h_div_x2 : (rad (x + 2) : ℤ) ∣ ((y + 2) : ℤ) := by
          exact_mod_cast rad_dvd_of_primeFactors_eq h3;
        refine' ⟨ _, _, _ ⟩;
        · exact dvd_sub h_div_x ( mod_cast rad_dvd_of_primeFactors_eq ( by aesop ) );
        · convert dvd_sub h_div_x1 ( show ( rad ( x + 1 ) : ℤ ) ∣ ( x + 1 : ℤ ) from mod_cast Nat.prod_primeFactors_dvd _ ) using 1 ; ring;
        · convert dvd_sub h_div_x2 ( show ( rad ( x + 2 ) : ℤ ) ∣ ( x + 2 ) from mod_cast Nat.prod_primeFactors_dvd _ ) using 1 ; ring;
      convert Int.coe_lcm_dvd ( Int.coe_lcm_dvd h_div.1 h_div.2.1 ) h_div.2.2 using 1;
      norm_num [ rad_lcm ];
      rw [ Nat.lcm_assoc ]

/-
Prove that the radicals of consecutive numbers are coprime.
-/
theorem rad_coprime_succ (n : ℕ) : Nat.Coprime (rad n) (rad (n + 1)) := by
  by_contra h_not_coprime;
  -- Then there exists a prime $p$ such that $p$ divides both $rad(n)$ and $rad(n+1)$.
  obtain ⟨p, hp_prime, hp_div_n, hp_div_n1⟩ : ∃ p, Nat.Prime p ∧ p ∣ rad n ∧ p ∣ rad (n + 1) := by
    exact Nat.Prime.not_coprime_iff_dvd.mp h_not_coprime;
  -- Since $p$ divides both $rad(n)$ and $rad(n+1)$, it must also divide $n$ and $n+1$.
  have hp_div_n_and_n1 : p ∣ n ∧ p ∣ n + 1 := by
    exact ⟨ dvd_trans hp_div_n ( Nat.prod_primeFactors_dvd _ ), dvd_trans hp_div_n1 ( Nat.prod_primeFactors_dvd _ ) ⟩;
  have := Nat.dvd_gcd hp_div_n_and_n1.1 hp_div_n_and_n1.2; aesop;

/-
Prove that if x is odd, then rad(x) and rad(x+2) are coprime.
-/
theorem rad_coprime_add_two_of_odd {x : ℕ} (h : x % 2 = 1) : Nat.Coprime (rad x) (rad (x + 2)) := by
  -- Since $x$ is odd, $x$ and $x+2$ are consecutive odd numbers. Consecutive odd numbers are coprime.
  have h_coprime : Nat.gcd x (x + 2) = 1 := by
    norm_num [ Nat.gcd_comm ];
    exact Nat.odd_iff.mpr h;
  exact Nat.Coprime.prod_left fun p hp => Nat.Coprime.prod_right fun q hq => Nat.Coprime.coprime_dvd_left ( Nat.dvd_of_mem_primeFactors hp ) ( Nat.Coprime.coprime_dvd_right ( Nat.dvd_of_mem_primeFactors hq ) h_coprime )

/-
Prove that gcd(rad x, rad y) = rad(gcd(x, y)) for non-zero x, y.
-/
theorem gcd_rad_rad (x y : ℕ) (hx : x ≠ 0) (hy : y ≠ 0) : Nat.gcd (rad x) (rad y) = rad (Nat.gcd x y) := by
  unfold rad;
  -- Let $p$ be a prime factor of $\gcd(x, y)$. Then $p$ divides both $x$ and $y$, and hence it divides $\prod_{p \in x.primeFactors} p$ and $\prod_{p \in y.primeFactors} p$.
  have h_prime_factors_gcd : ∀ p, p ∈ (x.gcd y).primeFactors ↔ p ∈ x.primeFactors ∧ p ∈ y.primeFactors := by
    simp +contextual [ Nat.primeFactors_gcd, hx, hy ];
  rw [ ← Finset.prod_inter_mul_prod_diff x.primeFactors y.primeFactors, Nat.gcd_comm ];
  refine' Nat.dvd_antisymm _ _;
  · refine' Nat.Coprime.dvd_of_dvd_mul_right _ _;
    exact ∏ p ∈ x.primeFactors \ y.primeFactors, p;
    · refine' Nat.Coprime.coprime_dvd_left ( Nat.gcd_dvd_left _ _ ) _;
      refine' Nat.Coprime.prod_left fun p hp => Nat.Coprime.prod_right fun q hq => _;
      exact Nat.Coprime.symm ( Nat.Prime.coprime_iff_not_dvd ( Nat.prime_of_mem_primeFactors ( Finset.mem_sdiff.mp hq |>.1 ) ) |>.2 fun h => by have := Nat.prime_dvd_prime_iff_eq ( Nat.prime_of_mem_primeFactors ( Finset.mem_sdiff.mp hq |>.1 ) ) ( Nat.prime_of_mem_primeFactors hp ) ; aesop );
    · rw [ show ( x.gcd y |> Nat.primeFactors ) = x.primeFactors ∩ y.primeFactors from ?_ ];
      · exact Nat.gcd_dvd_right _ _;
      · aesop;
  · refine' Nat.dvd_gcd _ _;
    · apply_rules [ Finset.prod_dvd_prod_of_subset ];
      grind;
    · exact dvd_mul_of_dvd_left ( by rw [ show ( x.gcd y |> Nat.primeFactors ) = x.primeFactors ∩ y.primeFactors by ext; aesop ] ) _

/-
Prove that if x is odd, rad_lcm x is the product of the radicals.
-/
theorem rad_lcm_eq_prod_of_odd {x : ℕ} (h : x % 2 = 1) : rad_lcm x = rad x * rad (x + 1) * rad (x + 2) := by
  -- Since x is odd, rad x, rad (x+1), and rad (x+2) are pairwise coprime.
  have h_coprime : Nat.Coprime (rad x) (rad (x + 1)) ∧ Nat.Coprime (rad x) (rad (x + 2)) ∧ Nat.Coprime (rad (x + 1)) (rad (x + 2)) := by
    exact ⟨ rad_coprime_succ x, rad_coprime_add_two_of_odd h, rad_coprime_succ ( x + 1 ) ⟩;
  unfold rad_lcm; simp_all +decide [ Nat.lcm ] ;
  simp_all +decide [ mul_assoc, Nat.Coprime, Nat.Coprime.symm, Nat.Coprime.gcd_mul ]

/-
Prove that if x is even and non-zero, rad_lcm x is half the product of the radicals.
-/
theorem rad_lcm_eq_half_prod_of_even {x : ℕ} (h : x % 2 = 0) (hx : x ≠ 0) : rad_lcm x = (rad x * rad (x + 1) * rad (x + 2)) / 2 := by
  -- Since $x$ is even, we have $\gcd(x, x+1) = 1$, $\gcd(x+1, x+2) = 1$, and $\gcd(x, x+2) = 2$.
  have h_gcds : Nat.gcd (rad x) (rad (x + 1)) = 1 ∧ Nat.gcd (rad (x + 1)) (rad (x + 2)) = 1 ∧ Nat.gcd (rad x) (rad (x + 2)) = 2 := by
    refine' ⟨ _, _, _ ⟩;
    · exact?;
    · convert rad_coprime_succ ( x + 1 ) using 1;
    · -- Since $x$ is even, we have $\gcd(x, x+2) = 2$.
      have h_gcd_x_x2 : Nat.gcd x (x + 2) = 2 := by
        norm_num [ Nat.gcd_comm, Nat.gcd_add_self_right ];
        exact Nat.gcd_eq_right ( Nat.dvd_of_mod_eq_zero h );
      convert gcd_rad_rad x ( x + 2 ) hx ( Nat.succ_ne_zero _ ) using 1;
      exact h_gcd_x_x2.symm ▸ by native_decide;
  unfold rad_lcm;
  simp_all +decide [ Nat.lcm, Nat.mul_assoc ];
  simp_all +decide [ Nat.Coprime, Nat.Coprime.symm, Nat.Coprime.gcd_mul ]

/-
Prove that rad(xy) = lcm(rad(x), rad(y)) for non-zero x, y.
-/
theorem rad_mul (x y : ℕ) (hx : x ≠ 0) (hy : y ≠ 0) : rad (x * y) = Nat.lcm (rad x) (rad y) := by
  -- By definition of rad, we know that rad(xy) is the product of the prime factors of xy.
  have h_rad_xy : rad (x * y) = ∏ p ∈ x.primeFactors ∪ y.primeFactors, p := by
    unfold rad;
    rw [ Nat.primeFactors_mul hx hy ];
  rw [ h_rad_xy, Nat.lcm ];
  have h_prime_factors_union : ∏ p ∈ x.primeFactors ∪ y.primeFactors, p = (∏ p ∈ x.primeFactors, p) * (∏ p ∈ y.primeFactors, p) / (∏ p ∈ x.primeFactors ∩ y.primeFactors, p) := by
    rw [ ← Finset.prod_union_inter, Nat.mul_div_cancel _ ( Finset.prod_pos fun p hp => Nat.pos_of_mem_primeFactors ( Finset.mem_inter.mp hp |>.1 ) ) ];
  convert h_prime_factors_union using 2;
  rw [ gcd_rad_rad ];
  · rw [ ← Nat.primeFactors_gcd hx hy ];
    rfl;
  · assumption;
  · assumption

/-
Prove that rad_lcm x is equal to the radical of the product x(x+1)(x+2) for non-zero x.
-/
theorem rad_lcm_eq_rad_prod_succ (x : ℕ) (hx : x ≠ 0) : rad_lcm x = rad (x * (x + 1) * (x + 2)) := by
  unfold rad_lcm;
  rw [ ← Nat.lcm_assoc, rad_mul, rad_mul ] <;> positivity;

/-
Prove that if x < y is a solution to Erdos 850, then y - x ≥ rad(x(x+1)(x+2)).
-/
theorem erdos_850_diff_bound {x y : ℕ} (hxy : x < y)
    (h1 : x.primeFactors = y.primeFactors)
    (h2 : (x + 1).primeFactors = (y + 1).primeFactors)
    (h3 : (x + 2).primeFactors = (y + 2).primeFactors) :
    rad (x * (x + 1) * (x + 2)) ≤ y - x := by
      -- By the congruence part of Erdős 850, we have $y - x \geq \text{rad}(x(x + 1)(x + 2))$.
      have h_cong : y - x ≥ rad_lcm x := by
        have := @erdos_850_congruence x y hxy.ne h1 h2 h3;
        rw [ Nat.modEq_iff_dvd ] at this;
        exact Nat.le_of_dvd ( Nat.sub_pos_of_lt hxy ) ( by simpa [ ← Int.natCast_dvd_natCast, hxy.le ] using this );
      by_cases hx : x = 0 <;> simp_all +decide [ rad_lcm_eq_rad_prod_succ ];
      unfold rad; aesop;

/-
Define what it means to be a solution to Erdos 850.
-/
def is_erdos_850_solution (x y : ℕ) : Prop :=
  x ≠ y ∧ x.primeFactors = y.primeFactors ∧
  (x + 1).primeFactors = (y + 1).primeFactors ∧
  (x + 2).primeFactors = (y + 2).primeFactors

/-
Prove that x=0 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_0 : ∀ y, ¬ is_erdos_850_solution 0 y := by
  -- Assume for contradiction that there exists a $y$ such that $0$ and $y$ form a solution.
  intro y
  by_contra h_contra
  obtain ⟨hy_ne, hy_prime_factors, hy1_prime_factors, hy2_prime_factors⟩ := h_contra;
  rw [ eq_comm ] at hy_prime_factors hy1_prime_factors hy2_prime_factors ; aesop

/-
Prove that x=1 is not part of any solution to Erdos 850.
-/
theorem no_solution_x_1 : ∀ y, ¬ is_erdos_850_solution 1 y := by
  intro y hy; obtain ⟨ hxy, h1, h2, h3 ⟩ := hy; rcases y with ( _ | _ | _ | _ | y ) <;> simp_all +arith +decide [ Nat.primeFactors_mul ] ;
  rw [ eq_comm ] at h1 h2 h3 ; aesop

