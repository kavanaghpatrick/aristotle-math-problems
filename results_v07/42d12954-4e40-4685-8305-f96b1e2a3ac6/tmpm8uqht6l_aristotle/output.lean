  ┬À -- By definition of $SeqA$, we know that $SeqA (n + 1) > SeqA n$ for all $n$.
    have h_seqA_inc : ÔêÇ n, SeqA (n + 1) > SeqA n := by
      exact?;
    grind;
  ┬À -- By definition of $SeqA$, we know that $SeqA (n + 1) > SeqA n$ for all $n$.
