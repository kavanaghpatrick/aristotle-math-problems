    rcases n with ( _ | _ | n ) <;> simp_all +arith +decide;
    -- By definition of Pell8_x, we have Pell8_x (n + 8) = 6 * Pell8_x (n + 7) - Pell8_x (n + 6).
    have h_pell8_x_recurrence : Pell8_x (n + 8) = 6 * Pell8_x (n + 7) - Pell8_x (n + 6) := by
      rfl;
    -- Substitute the induction hypotheses into the recurrence relation.
    have h_subst : Pell8_x (n + 8) % 5 = (6 * Pell8_x (n + 1) - Pell8_x n) % 5 := by
      zify [ h_pell8_x_recurrence ];
      rw [ Nat.cast_sub, Nat.cast_sub ] <;> norm_num [ Int.sub_emod, Int.mul_emod, ih ];
