lemma SeqA_complete (v : Ôäò) : (Ôêâ u, 2 * v^2 = u^2 + 1) Ôåö is_SeqA v := by
  constructor;
  ┬À rintro Ôƒ¿ u, hu Ôƒ®;
    -- By definition of SeqA, we know that every solution to 2v^2 = u^2 + 1 is of the form (u, v) = (SeqA_u n, SeqA n) for some n.
    have h_seqA : ÔêÇ v u : Ôäò, 2 * v^2 = u^2 + 1 ÔåÆ Ôêâ n, v = SeqA n Ôêº u = SeqA_u n := by
      intros v u hu
      induction' v using Nat.strong_induction_on with v ih generalizing u;
      rcases v with ( _ | _ | v ) <;> rcases u with ( _ | _ | u ) <;> simp +arith +decide at hu Ôèó;
      ┬À exists 0;
      ┬À -- By the properties of the Pell equation, if $(v+2, u+2)$ is a solution, then $(v, u)$ is also a solution.
        have h_pell : Ôêâ v' u' : Ôäò, 2 * v' ^ 2 = u' ^ 2 + 1 Ôêº v' < v + 2 Ôêº u' < u + 2 Ôêº v + 2 = 3 * v' + 2 * u' Ôêº u + 2 = 4 * v' + 3 * u' := by
          use (3 * (v + 2) - 2 * (u + 2)) / 1, (3 * (u + 2) - 4 * (v + 2)) / 1;
          zify;
          rw [ Nat.cast_sub, Nat.cast_sub ] <;> push_cast <;> repeat nlinarith only [ hu ] ;
          norm_num; exact Ôƒ¿ by nlinarith only [ hu ], by nlinarith only [ hu ], by nlinarith only [ hu ], by nlinarith only [ hu ], by nlinarith only [ hu ] Ôƒ® ;
        obtain Ôƒ¿ v', u', hv', hv'', hu'', hv''', hu''' Ôƒ® := h_pell; obtain Ôƒ¿ n, rfl, rfl Ôƒ® := ih v' ( by linarith ) u' hv'; use n + 1; simp +arith +decide [ *, SeqA, SeqA_u ] ;
        exact Ôƒ¿ by linarith [ SeqA_joint_recurrence n ], by linarith [ SeqA_joint_recurrence n ] Ôƒ®;
    exact Exists.elim ( h_seqA v u hu ) fun n hn => Ôƒ¿ n, hn.1.symm Ôƒ®;
  ┬À rintro Ôƒ¿ n, rfl Ôƒ® ; exact Ôƒ¿ SeqA_u n, by linarith [ SeqA_solution_explicit n ] Ôƒ® ;

lemma SeqB_complete (v : Ôäò) : (Ôêâ d, 3 * v^2 = d^2 + 2) Ôåö is_SeqB v := by
  constructor;
  ┬À rintro Ôƒ¿ d, hd Ôƒ®;
    -- By definition of $SeqB$, we know that if $3v^2 = d^2 + 2$, then $v$ must be in the sequence $SeqB$.
    have h_seqB : ÔêÇ v d : Ôäò, 3 * v^2 = d^2 + 2 ÔåÆ Ôêâ n, v = SeqB n Ôêº d = SeqB_d n := by
      intros v d h_eq
      induction' v using Nat.strong_induction_on with v ih generalizing d;
      by_cases hv : v Ôëñ 5;
      ┬À interval_cases v <;> norm_num at * <;> have := Nat.le_of_lt_succ ( show d < 10 by nlinarith ) <;> interval_cases d <;> simp +decide at h_eq Ôèó;
        ┬À exists 0;
        ┬À exists 1;
      ┬À -- If $v > 5$, then we can find $v'$ and $d'$ such that $3v'^2 = d'^2 + 2$ and $v' < v$.
        obtain Ôƒ¿v', d', hv', hd'Ôƒ® : Ôêâ v' d', 3 * v'^2 = d'^2 + 2 Ôêº v' < v Ôêº v = 2 * v' + d' Ôêº d = 2 * d' + 3 * v' := by
          use (2 * v - d), (2 * d - 3 * v);
          zify;
          rw [ Nat.cast_sub, Nat.cast_sub ] <;> push_cast <;> repeat nlinarith only [ h_eq, hv ] ;
          exact Ôƒ¿ by linarith, by nlinarith only [ hv, h_eq ], by linarith, by linarith Ôƒ®;
        obtain Ôƒ¿ n, hn Ôƒ® := ih v' hd'.1 d' hv';
        use n + 1;
        simp_all +decide [ SeqB_joint_recurrence ];
        ring;
    exact Exists.elim ( h_seqB v d hd ) fun n hn => Ôƒ¿ n, hn.1.symm Ôƒ®;
  ┬À rintro Ôƒ¿ n, rfl Ôƒ® ; exact Ôƒ¿ SeqB_d n, by linarith [ SeqB_solution_explicit n ] Ôƒ® ;

lemma SeqA_descent (v : Ôäò) (u : Ôäò) (h : u^2 = 2 * v^2 - 1) (hv : v > 1) :
    Ôêâ v' u', u'^2 = 2 * v'^2 - 1 Ôêº v' < v Ôêº v = 2 * u' + 3 * v' Ôêº u = 3 * u' + 4 * v' := by
      -- By the properties of the Pell equation, if $(v, u)$ is a solution, then there exists a smaller solution $(v', u')$ such that $v' = 3v - 2u$ and $u' = 3u - 4v$.
      use 3 * v - 2 * u, 3 * u - 4 * v;
      zify at *;
      repeat rw [ Nat.cast_sub ] at * <;> push_cast at * <;> repeat nlinarith;
      ┬À exact Ôƒ¿ by linarith, by nlinarith, by linarith, by linarith Ôƒ®;
      ┬À exact Nat.one_le_iff_ne_zero.mpr ( mul_ne_zero two_ne_zero ( pow_ne_zero 2 ( Nat.sub_ne_zero_of_lt ( by nlinarith ) ) ) );
      ┬À rw [ Nat.cast_sub ] at h <;> push_cast at * <;> nlinarith [ show v > 1 from mod_cast hv ] ;

