lemma SeqA_mod_8 (n : Ôäò) : SeqA n % 8 = [1, 5, 5, 1].get! (n % 4) := by
  induction' n using Nat.strong_induction_on with n ih
  match n with
  | 0 => rfl
  | 1 => rfl
  | 2 => rfl
  | 3 => rfl
  | k + 4 =>
    rw [SeqA]
    -- SeqA (k+4) = 6 * SeqA (k+3) - SeqA (k+2)
    -- We need to show (6 * SeqA (k+3) - SeqA (k+2)) % 8 = [1, 5, 5, 1].get! ((k+4) % 4)
    -- (k+4) % 4 = k % 4
    -- We have IH for k+3 and k+2.
    -- (k+3) % 4 = (k-1) % 4 if k>=1.
    -- This is getting messy with indices.
    -- Let's just use the fact that the sequence is periodic with period 4.
    -- We need to show SeqA (k+4) % 8 = SeqA k % 8.
    -- SeqA (k+4) = 6 A(k+3) - A(k+2)
    -- = 6(6 A(k+2) - A(k+1)) - A(k+2)
    -- = 35 A(k+2) - 6 A(k+1)
    -- = 35(6 A(k+1) - A(k)) - 6 A(k+1)
    -- = 210 A(k+1) - 35 A(k) - 6 A(k+1)
    -- = 204 A(k+1) - 35 A(k)
    -- Mod 8:
    -- 204 = 25 * 8 + 4. So 204 = 4 mod 8.
    -- 35 = 4 * 8 + 3. So 35 = 3 mod 8.
    -- So A(k+4) = 4 A(k+1) - 3 A(k) mod 8.
    -- Wait, this doesn't look like A(k).
    -- Let's recheck.
    -- A(k+4) = 6 A(k+3) - A(k+2)
    -- = -2 A(k+3) - A(k+2)
    -- = -2 (-2 A(k+2) - A(k+1)) - A(k+2)
    -- = 4 A(k+2) + 2 A(k+1) - A(k+2)
    -- = 3 A(k+2) + 2 A(k+1)
    -- = 3 (-2 A(k+1) - A(k)) + 2 A(k+1)
    -- = -6 A(k+1) - 3 A(k) + 2 A(k+1)
    -- = -4 A(k+1) - 3 A(k)
    -- = 4 A(k+1) + 5 A(k)
    -- This still depends on A(k+1).
    -- Let's check values.
    -- 1, 5, 5, 1, 1, 5...
    -- k=0: A(4)=1. 4(5) + 5(1) = 25 = 1. Correct.
    -- k=1: A(5)=5. 4(5) + 5(5) = 45 = 5. Correct.
    -- k=2: A(6)=5. 4(1) + 5(5) = 29 = 5. Correct.
    -- k=3: A(7)=1. 4(1) + 5(1) = 9 = 1. Correct.
    -- So A(k+4) = 4 A(k+1) + 5 A(k).
    -- But we want A(k+4) = A(k).
    -- So we need 4 A(k+1) + 5 A(k) = A(k) mod 8.
    -- 4 A(k+1) + 4 A(k) = 0 mod 8.
    -- 4 (A(k+1) + A(k)) = 0 mod 8.
    -- A(k+1) + A(k) must be even.
    -- 1+5=6 (even). 5+5=10 (even). 5+1=6 (even). 1+1=2 (even).
    -- Yes, A(k) is always odd. So sum is even.
    -- So A(k+4) = A(k) mod 8 is true.
    -- So we can prove SeqA (n+4) % 8 = SeqA n % 8.
    -- Then the result follows.
    zify;
    rw [ Nat.cast_sub ] <;> norm_num [ Int.sub_emod, Int.mul_emod, ih ];
    ┬À norm_cast; norm_num [ Nat.add_mod, Nat.mul_mod, ih ] ; have := Nat.mod_lt k zero_lt_four; interval_cases k % 4 <;> norm_num;
      ┬À decide;
      ┬À decide;
      ┬À decide;
      ┬À decide;
    ┬À linarith [ SeqA_increasing ( k + 2 ), SeqA_increasing ( k + 3 ) ]

lemma SeqA_odd (n : Ôäò) : SeqA n % 2 = 1 := by
  induction' n using Nat.strong_induction_on with n ih;
  rcases n with ( _ | _ | _ | n ) <;> simp +arith +decide [ *, Nat.add_mod, Nat.mul_mod ];
  -- By definition of $SeqA$, we have $SeqA (n + 3) = 6 * SeqA (n + 2) - SeqA (n + 1)$.
  have h_seqA_succ : SeqA (n + 3) = 6 * SeqA (n + 2) - SeqA (n + 1) := by
    rfl;
  zify [ h_seqA_succ ];
  rw [ Nat.cast_sub ] <;> norm_num [ Int.sub_emod, Int.mul_emod, ih ];
  ┬À exact_mod_cast ih _ ( by linarith );
  ┬À linarith [ SeqA_increasing n, SeqA_increasing ( n + 1 ) ]

lemma SeqA_mod_8_periodic (n : Ôäò) : SeqA (n + 4) % 8 = SeqA n % 8 := by
  -- We'll use induction to prove that the sequence $SeqA$ is periodic modulo 8 with period 4.
  induction' n using Nat.strong_induction_on with n ih;
  -- For the inductive step, assume that for all m < n, SeqA (m + 4) Ôëí SeqA m (mod 8).
  by_cases hn : n < 4;
  ┬À interval_cases n <;> trivial;
  ┬À -- Since $n \geq 4$, we can write $n = k + 4$ for some $k$.
    obtain Ôƒ¿k, rflÔƒ® : Ôêâ k, n = k + 4 := by
      exact Ôƒ¿ n - 4, by rw [ Nat.sub_add_cancel ( le_of_not_gt hn ) ] Ôƒ®;
    -- By the definition of SeqA, we have SeqA (k + 8) = 6 * SeqA (k + 7) - SeqA (k + 6) and SeqA (k + 4) = 6 * SeqA (k + 3) - SeqA (k + 2).
    have h_recurrence : SeqA (k + 8) = 6 * SeqA (k + 7) - SeqA (k + 6) Ôêº SeqA (k + 4) = 6 * SeqA (k + 3) - SeqA (k + 2) := by
      exact Ôƒ¿ rfl, rfl Ôƒ®;
    zify [ h_recurrence ];
    rw [ Nat.cast_sub, Nat.cast_sub ] <;> norm_num [ Int.sub_emod, Int.mul_emod ];
    ┬À grind;
    ┬À linarith [ SeqA_increasing ( k + 2 ), SeqA_increasing ( k + 3 ) ];
    ┬À linarith [ SeqA_increasing ( k + 6 ), SeqA_increasing ( k + 7 ) ]

lemma SeqB_mod_8_periodic (n : Ôäò) : SeqB (n + 4) % 8 = SeqB n % 8 := by
  -- By definition of $SeqB$, we know that $SeqB (n + 2) = 4 * SeqB (n + 1) - SeqB n$.
  have h_seqB_rec : ÔêÇ n, SeqB (n + 2) = 4 * SeqB (n + 1) - SeqB n := by
    exact?;
  zify [ h_seqB_rec ];
  repeat rw [ Nat.cast_sub ] <;> push_cast <;> repeat linarith [ SeqB_properties n, SeqB_properties ( n + 1 ) ] ;
  ┬À grind;
  ┬À -- By definition of $SeqB$, we know that $SeqB (n + 1) > SeqB n$.
    have h_seqB_inc : ÔêÇ n, SeqB (n + 1) > SeqB n := by
      exact?;
    grind;
  ┬À -- By definition of $SeqB$, we know that $SeqB (n + 1) > SeqB n$.
    have h_seqB_inc : ÔêÇ n, SeqB (n + 1) > SeqB n := by
      exact?;
    grind

lemma SeqB_mod_8 (n : Ôäò) : SeqB n % 8 = [1, 3, 3, 1].get! (n % 4) := by
  -- We'll use induction to prove that the sequence SeqB is periodic modulo 8 with period 4.
  have h_periodic : ÔêÇ n, SeqB (n + 4) % 8 = SeqB n % 8 := by
    -- Apply the lemma SeqB_mod_8_periodic to conclude the proof.
    apply SeqB_mod_8_periodic;
  induction' n using Nat.strong_induction_on with n ih;
