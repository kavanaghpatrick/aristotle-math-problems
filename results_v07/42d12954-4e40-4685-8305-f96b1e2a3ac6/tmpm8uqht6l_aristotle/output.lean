def SeqC_d (n : Ôäò) : Ôäò :=
  match n with
  | 0 => 1
  | 1 => 11
  | n + 2 => 10 * SeqC_d (n + 1) - SeqC_d n

lemma SeqC_d_increasing (n : Ôäò) : SeqC_d n < SeqC_d (n + 1) := by
  -- By definition of SeqC_d, we know that it is strictly increasing.
  have h_seqC_d_inc : StrictMono SeqC_d := by
    -- We can prove the strict monotonicity of SeqC_d by induction on n.
    have h_inc : ÔêÇ n, SeqC_d (n + 1) > SeqC_d n := by
      intro n
      induction' n using Nat.strong_induction_on with n ih
      generalize_proofs at *;
      rcases n with ( _ | _ | n ) <;> simp +arith +decide [ * ];
      exact lt_tsub_iff_left.mpr ( by linarith! [ ih _ <| Nat.lt_succ_self _, ih _ <| Nat.lt_succ_of_lt <| Nat.lt_succ_self _ ] )
    generalize_proofs at *; exact strictMono_nat_of_lt_succ h_inc;
  generalize_proofs at *; exact h_seqC_d_inc n.lt_succ_self;

lemma SeqC_d_pos (n : Ôäò) : 0 < SeqC_d n := by
  -- By definition of $SeqC_d$, we know that $SeqC_d n > 0$ for all $n$ because it is defined recursively with positive initial terms and a positive recurrence relation.
  have h_pos : ÔêÇ n, 0 < SeqC_d n Ôêº SeqC_d n < SeqC_d (n + 1) := by
    intro n;
    induction n <;> simp +arith +decide [ *, SeqC_d ];
    omega;
  exact h_pos n |>.1

lemma SeqA_mod_5 (n : Ôäò) : SeqA n % 5 = [1, 0, 4, 4, 0, 1].get! (n % 6) := by
