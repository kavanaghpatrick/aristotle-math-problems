lemma SeqA_mod_5_periodic (n : Ôäò) : SeqA (n + 6) % 5 = SeqA n % 5 := by
  -- By definition of $SeqA$, we know that $SeqA (n + 6) = 6 * SeqA (n + 5) - SeqA (n + 4)$.
