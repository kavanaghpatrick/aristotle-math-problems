  ┬À linarith [ show Pell8_x ( n + 4 ) Ôëñ Pell8_x ( n + 5 ) from by { exact monotone_nat_of_le_succ ( fun n => by { exact Nat.recOn n ( by decide ) fun n ihn => by { erw [ show Pell8_x ( n + 2 ) = 6 * Pell8_x ( n + 1 ) - Pell8_x n from rfl ] ; exact le_tsub_of_add_le_left <| by linarith } } ) <| Nat.le_succ _ } ]

lemma Pell8_x_mod_5_periodic (n : Ôäò) : Pell8_x (n + 6) % 5 = Pell8_x n % 5 := by
  -- By definition of Pell8_x, we know that Pell8_x (n + 6) Ôëí Pell8_x n (mod 5).
  have h_mod_5 : ÔêÇ n, Pell8_x (n + 6) % 5 = Pell8_x n % 5 := by
    intro n
