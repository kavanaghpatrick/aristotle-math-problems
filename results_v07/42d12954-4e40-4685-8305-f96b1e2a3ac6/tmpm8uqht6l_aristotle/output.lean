lemma Pell8_x_mod_8 (n : Ôäò) : Pell8_x n % 8 = if n % 2 = 0 then 1 else 3 := by
  induction' n using Nat.strong_induction_on with n ih;
  rcases n with ( _ | _ | _ | _ | n ) <;> simp +arith +decide [ *, Nat.add_mod, Nat.mul_mod ] at *;
  -- By definition of Pell8_x, we have Pell8_x (n + 4) = 6 * Pell8_x (n + 3) - Pell8_x (n + 2).
  have h_recurrence : Pell8_x (n + 4) = 6 * Pell8_x (n + 3) - Pell8_x (n + 2) := by
    rfl;
  zify [ h_recurrence ];
  rw [ Nat.cast_sub ] <;> norm_num [ Int.add_emod, Int.sub_emod, Int.mul_emod, ih ];
  ┬À norm_cast; simp +arith +decide [ *, Nat.add_mod, Nat.mul_mod ] ;
    cases Nat.mod_two_eq_zero_or_one n <;> simp +decide [ *, Nat.dvd_iff_mod_eq_zero ];
  ┬À linarith [ show Pell8_x ( n + 3 ) ÔëÑ Pell8_x ( n + 2 ) from by { exact Nat.recOn n ( by decide ) fun n ihn => by { exact by { rw [ show Pell8_x ( n + 4 ) = 6 * Pell8_x ( n + 3 ) - Pell8_x ( n + 2 ) from rfl ] ; exact le_tsub_of_add_le_left <| by linarith } } } ]

lemma SeqA_mod_8_val (n : Ôäò) : SeqA n % 8 = [1, 5, 5, 1].get! (n % 4) := by
  -- Apply the lemma SeqA_mod_8 to conclude the proof.
