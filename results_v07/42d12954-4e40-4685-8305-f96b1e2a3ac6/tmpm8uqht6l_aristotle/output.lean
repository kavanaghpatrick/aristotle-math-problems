lemma SeqB_properties (n : Ôäò) : 0 < SeqB n Ôêº SeqB n < SeqB (n + 1) := by
  -- By definition of `SeqB`, we know that `SeqB n` is positive and strictly increasing.
  have h_seqB_pos : ÔêÇ n, 0 < SeqB n Ôêº SeqB n < SeqB (n + 1) := by
    -- We'll use induction to prove that SeqB n is positive and strictly increasing for all n.
    intro n
    induction' n with n ih;
    ┬À decide +revert;
    ┬À -- By definition of SeqB, we have SeqB (n + 2) = 4 * SeqB (n + 1) - SeqB n.
      have h_seqB_succ : SeqB (n + 2) = 4 * SeqB (n + 1) - SeqB n := by
        exact?;
