lemma SeqA_properties (n : Ôäò) : 0 < SeqA n Ôêº SeqA n < SeqA (n + 1) := by
  -- By definition of SeqA, we know that SeqA n is positive and strictly increasing.
  have h_pos_inc : ÔêÇ n, 0 < SeqA n Ôêº SeqA n < SeqA (n + 1) := by
