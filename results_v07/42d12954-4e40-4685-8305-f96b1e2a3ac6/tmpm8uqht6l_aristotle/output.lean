    SeqB_d (n + 1) = 2 * SeqB_d n + 3 * SeqB n Ôêº
    SeqB (n + 1) = SeqB_d n + 2 * SeqB n := by
  induction' n with n ih
  ┬À constructor <;> rfl
  ┬À have h_expand : SeqB_d (n + 2) = 4 * SeqB_d (n + 1) - SeqB_d n Ôêº SeqB (n + 2) = 4 * SeqB (n + 1) - SeqB n := by
      exact Ôƒ¿ rfl, rfl Ôƒ®
    grind +ring

lemma SeqB_solution_explicit (n : Ôäò) : (SeqB_d n)^2 + 2 = 3 * (SeqB n)^2 := by
  induction' n with n ih
  ┬À rfl
  ┬À rw [SeqB_joint_recurrence n |>.1, SeqB_joint_recurrence n |>.2]
    linarith

lemma SeqA_solution_exists (n : Ôäò) : Ôêâ u, u^2 = 2 * (SeqA n)^2 - 1 := by
  -- By definition of SeqA, we know that SeqA n satisfies the Pell equation 2 * SeqA n^2 - 1 = u^2. Use this fact.
  apply (SeqA_solution n) |> fun Ôƒ¿u, huÔƒ® => Ôƒ¿u, by linarithÔƒ®

lemma SeqB_solution_exists (n : Ôäò) : Ôêâ d, d^2 = 3 * (SeqB n)^2 - 2 := by
  -- By definition of SeqB, we know that SeqB_d n^2 + 2 = 3 * SeqB n^2.
  have h_seqB_d : SeqB_d n^2 + 2 = 3 * SeqB n^2 := by
    -- Apply the lemma SeqB_solution_explicit to conclude the proof.
    apply SeqB_solution_explicit;
  -- By definition of SeqB_d, we know that SeqB_d n^2 + 2 = 3 * SeqB n^2. Therefore, SeqB_d n^2 = 3 * SeqB n^2 - 2.
  use SeqB_d n
  rw [ÔåÉh_seqB_d]
  norm_num

lemma SeqA_increasing (n : Ôäò) : SeqA n < SeqA (n + 1) := by
  induction' n with n ih <;> norm_num [ *, Nat.mul_succ ];
  ┬À decide +revert;
  ┬À -- By definition of $SeqA$, we have $SeqA (n + 2) = 6 * SeqA (n + 1) - SeqA n$.
    have h_seqA_succ : SeqA (n + 2) = 6 * SeqA (n + 1) - SeqA n := by
      rfl;
    grind

lemma SeqB_increasing (n : Ôäò) : SeqB n < SeqB (n + 1) := by
