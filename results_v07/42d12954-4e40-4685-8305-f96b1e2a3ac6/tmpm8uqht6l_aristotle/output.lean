    ┬À decide +revert;
    ┬À -- By definition of SeqA, we have SeqA (n + 2) = 6 * SeqA (n + 1) - SeqA n.
      have h_seqA_succ : SeqA (n + 2) = 6 * SeqA (n + 1) - SeqA n := by
